# ── VybeFlow Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in REAL values. NEVER commit .env to git.

# ── Core ────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
VYBEFLOW_SECRET_KEY=replace_with_a_long_random_secret
VYBEFLOW_APP_BASE_URL=https://vybeflow.app

# Site origin used for SocketIO CORS — set to your public domain in production
SITE_ORIGIN=https://vybeflow.app

# Set to true in production (cookies only sent over HTTPS)
SESSION_COOKIE_SECURE=true

# Stripe payment keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# GIF search (Tenor v2 API — get a key at https://developers.google.com/tenor)
TENOR_V2_KEY=your_tenor_v2_api_key_here

# Vault PIN pepper — extra server-side secret for PIN hashing (30+ random chars)
VAULT_PIN_PEPPER=replace_with_a_long_random_pepper_string

# SMTP mail delivery (for real professional VybeFlow email links)
VYBEFLOW_SMTP_HOST=smtp.gmail.com
VYBEFLOW_SMTP_PORT=587
VYBEFLOW_SMTP_USER=your_email@example.com
VYBEFLOW_SMTP_PASS=your_email_app_password
VYBEFLOW_SMTP_USE_TLS=true
VYBEFLOW_SMTP_USE_SSL=false
VYBEFLOW_MAIL_FROM=VybeFlow <your_email@example.com>
PASSWORD_RESET_OVERRIDE_EMAIL=
