            # Messaging restriction enforcement
            ("user", "is_shadow_banned", "BOOLEAN DEFAULT 0"),
            ("user", "dm_bypass_attempts", "INTEGER DEFAULT 0"),
            # DM 3-strike global counter (per-pair detail lives in DmStrike table)
            ("user", "dm_strikes", "INTEGER DEFAULT 0"),
            # Violence/threat keyword violation counter (0-3; hard ban at 3)
            ("user", "violation_count", "INTEGER DEFAULT 0"),
            # â”€â”€ Pay-to-message wallet â”€â”€
            ("user", "currency_code",      "VARCHAR(3)  DEFAULT 'USD'"),
            ("user", "wallet_balance",     "REAL        DEFAULT 0.0"),
            ("user", "dm_fee_multiplier",  "REAL        DEFAULT 1.0"),
            # â”€â”€ Inbox Shield Mode â”€â”€
            ("user", "inbox_mode",         "VARCHAR(20) DEFAULT 'free'"),
            ("user", "message_fee",        "REAL        DEFAULT 1.0"),
            ("user", "signup_country",     "VARCHAR(2)  DEFAULT NULL"),
            ("user", "home_currency",      "VARCHAR(3)  DEFAULT 'USD'"),
            # â”€â”€ Vault (client-side AES-GCM encrypted posts) â”€â”€
            ("user", "vault_pin_hash",     "VARCHAR(128)"),
            ("user", "vault_salt",         "VARCHAR(64)"),
            ("post", "is_vault",           "BOOLEAN DEFAULT 0"),
            ("post", "vault_caption_enc",  "TEXT"),
            ("post", "vault_iv",           "VARCHAR(32)"),
            ("post", "vault_media_nonce",  "VARCHAR(32)"),
            # Font color style for post captions
            ("post", "font_color",         "VARCHAR(30)"),
            # â”€â”€ TOTP 2FA â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            ("user", "totp_secret",        "VARCHAR(64)"),
            # â”€â”€ Login lockout (brute-force protection) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            ("user", "login_attempts",     "INTEGER DEFAULT 0"),
            ("user", "lockout_until",      "DATETIME"),
            # â”€â”€ Email verification â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            ("user", "email_verified",     "BOOLEAN DEFAULT 0"),
            ("user", "email_verify_token", "VARCHAR(64)"),
            # â”€â”€ Digital Wellbeing â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            ("user", "daily_usage_limit_mins",   "INTEGER"),
            ("user", "wellbeing_break_reminder", "BOOLEAN DEFAULT 1"),
            # â”€â”€ Onboarding canonical flag â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            ("user", "has_completed_onboarding", "BOOLEAN DEFAULT 0"),
            # Post engagement streak
            ("user", "post_streak",    "INTEGER DEFAULT 0"),
            ("user", "last_post_date", "DATE"),
        ]
        import re as _re
        _IDENT_RE = _re.compile(r'^[a-z_][a-z0-9_]*$')
        for _tbl, _col, _typ in _migrate_cols:
            # Defence-in-depth: only allow safe SQL identifiers
            if not _IDENT_RE.match(_tbl) or not _IDENT_RE.match(_col):
                continue
            try:
                db.session.execute(db.text(f"ALTER TABLE {_tbl} ADD COLUMN {_col} {_typ}"))
                db.session.commit()
            except Exception:
                try:
                    db.session.rollback()
                except Exception:
                    pass

        # â”€â”€ Create dm_payment table if missing â”€â”€
        try:
            db.session.execute(db.text(
                "CREATE TABLE IF NOT EXISTS dm_payment ("
                "  id INTEGER PRIMARY KEY AUTOINCREMENT,"
                "  sender_id INTEGER NOT NULL REFERENCES user(id),"
                "  recipient_id INTEGER NOT NULL REFERENCES user(id),"
                "  stripe_intent_id VARCHAR(128) UNIQUE NOT NULL,"
                "  amount_minor INTEGER NOT NULL,"
                "  currency_code VARCHAR(3) NOT NULL DEFAULT 'usd',"
                "  status VARCHAR(20) NOT NULL DEFAULT 'pending',"
                "  fee_label VARCHAR(80),"
                "  strike_multiplier INTEGER NOT NULL DEFAULT 1,"
                "  hold_reason VARCHAR(80),"
                "  created_at DATETIME DEFAULT CURRENT_TIMESTAMP NOT NULL,"
                "  updated_at DATETIME DEFAULT CURRENT_TIMESTAMP NOT NULL"
                ")"
            ))
            db.session.commit()
        except Exception:
            db.session.rollback()

        # â”€â”€ Create linked_social_account table if missing â”€â”€
        try:
            db.session.execute(db.text(
                "CREATE TABLE IF NOT EXISTS linked_social_account ("
                "  id INTEGER PRIMARY KEY AUTOINCREMENT,"
                "  user_id INTEGER NOT NULL REFERENCES user(id) ON DELETE CASCADE,"
                "  platform VARCHAR(20) NOT NULL,"
                "  platform_uid VARCHAR(128),"
                "  display_name VARCHAR(128),"
                "  access_token TEXT,"
                "  refresh_token TEXT,"
                "  token_expiry DATETIME,"
                "  is_active BOOLEAN DEFAULT 1 NOT NULL,"
                "  linked_at DATETIME DEFAULT CURRENT_TIMESTAMP NOT NULL,"
                "  UNIQUE(user_id, platform)"
                ")"
            ))
            db.session.commit()
        except Exception:
            db.session.rollback()

        # â”€â”€ Purge sensitive DM messages that were never PIN-locked â”€â”€
        # Any nude/sensitive photo sent before PIN enforcement is removed now.
        try:
            db.session.execute(db.text(
                "DELETE FROM message WHERE is_sensitive = 1 "
                "AND (media_pin_hash IS NULL OR media_pin_hash = '')"
            ))
            db.session.commit()
            print("[VybeFlow] Purged unpinned sensitive DM messages")
        except Exception as _pe:
            db.session.rollback()
            print(f"[VybeFlow] Purge warning: {_pe}")

    app.register_blueprint(games_api)

    # â”€â”€ GDPR / CCPA data export â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    @app.route("/api/account/export-data", methods=["GET"])
    def _gdpr_export():
        """
        GDPR Article 20 / CCPA data portability:
        Returns a JSON export of everything the platform holds for the logged-in user.
        Rate-limited to 1 request per 24h (enforced via session timestamp).
        """
        from flask import session as _s, jsonify as _j
        from models import User, Post, Comment, Message, Thread, Notification
        _username = _s.get("username", "")
        if not _username:
            return _j({"error": "Not logged in"}), 401
        _user = User.query.filter_by(username=_username).first()
        if not _user:
            return _j({"error": "User not found"}), 404

        # Simple 24-hour rate gate stored in session (no DB write needed)
        import time as _time
        _last = _s.get("_gdpr_export_ts", 0)
        if _time.time() - _last < 86400:
            return _j({"error": "Data export is available once per 24 hours."}), 429
        _s["_gdpr_export_ts"] = int(_time.time())

        # Collect posts
        _posts = [
            {"id": p.id, "caption": p.caption, "media_url": p.media_url,
             "created_at": str(p.created_at), "visibility": p.visibility}
            for p in Post.query.filter_by(author_id=_user.id).all()
        ]

        # Collect threads & messages the user is a member of
        try:
            from models import ThreadMember
            _thread_ids = [tm.thread_id for tm in
                           ThreadMember.query.filter_by(user_id=_user.id).all()]
            _messages = [
                {"thread_id": m.thread_id, "body": m.body if not getattr(m, "is_burnt", False) else "[deleted]",
                 "sent_at": str(m.created_at)}
                for m in Message.query.filter(Message.thread_id.in_(_thread_ids),
                                              Message.sender_id == _user.id).limit(5000).all()
            ]
        except Exception:
            _messages = []

        export = {
            "export_generated_at": __import__("datetime").datetime.now(timezone.utc).isoformat() + "Z",
            "profile": {
                "username": _user.username,
                "display_name": _user.display_name,
                "email": _user.email,
                "bio": _user.bio,
                "created_at": str(_user.created_at),
                "account_type": _user.account_type,
                "home_currency": _user.home_currency,
                "signup_country": _user.signup_country,
            },
            "posts": _posts,
            "messages_sent": _messages,
        }
        from flask import Response as _Resp
        import json as _json
        return _Resp(
            _json.dumps(export, indent=2, default=str),
            mimetype="application/json",
            headers={"Content-Disposition": f"attachment; filename=vybeflow_export_{_username}.json"},
        ), 200

    @app.route("/api/account/delete", methods=["POST"])
    def _gdpr_delete():
        """
        GDPR Article 17 / CCPA right to erasure.
        Body: { password: "current_password", confirm: "DELETE MY ACCOUNT" }
        Permanently deletes the account and all associated content.
        """
        from flask import session as _s, request as _req, jsonify as _j
        from models import User
        from werkzeug.security import check_password_hash as _cph
        _username = _s.get("username", "")
        if not _username:
            return _j({"error": "Not logged in"}), 401
        _user = User.query.filter_by(username=_username).first()
        if not _user:
            return _j({"error": "User not found"}), 404
        body = _req.get_json(silent=True) or {}
        if body.get("confirm") != "DELETE MY ACCOUNT":
            return _j({"error": "Send confirm: 'DELETE MY ACCOUNT' to proceed."}), 400
        if not _cph(_user.password_hash, body.get("password", "")):
            return _j({"error": "Incorrect password."}), 403
        try:
            db.session.delete(_user)
            db.session.commit()
            _s.clear()
            return _j({"ok": True, "message": "Account permanently deleted."}), 200
        except Exception as _de:
            db.session.rollback()
            return _j({"error": f"Deletion failed: {_de}"}), 500

    # Register story routes and SocketIO handlers
    register_story_routes(app)
