            return redirect(url_for("login"))
        return render_template("create_post.html")

    @app.get("/api/gif/search")
    def api_gif_search():
        """Search Tenor for GIFs to power the feed composer GIF picker.

        Accepts query param `q`; when empty, returns trending GIFs.
        """
        import random
        import time as _time

        q = (request.args.get("q") or "").strip()
        limit = 16

        # â”€â”€ Check cache first â”€â”€
        _cache_key = q.lower() if q else "__trending__"
        _cached = _gif_cache.get(_cache_key)
        if _cached and (_time.time() - _cached["ts"]) < _GIF_CACHE_TTL:
            return jsonify({"results": _cached["results"]}), 200

        # Keep v2 and legacy keys separate so we can route to matching API.
        _tenor_v2_key = TENOR_V2_KEY
        _tenor_v1_key = TENOR_API_KEY

        # If no working API key, return a larger static fallback set
        if not _tenor_v2_key and not _tenor_v1_key:
            fallback = [
                {"title": "Fire", "url": "https://media1.giphy.com/media/3o7TKSjRrfIPjeiVyM/giphy.gif"},
                {"title": "Laugh", "url": "https://media1.giphy.com/media/10JhviFuU2gWD6/giphy.gif"},
                {"title": "Dance", "url": "https://media1.giphy.com/media/l0MYt5jPR6QX5pnqM/giphy.gif"},
                {"title": "Thumbs Up", "url": "https://media1.giphy.com/media/111ebonMs90YLu/giphy.gif"},
                {"title": "Cool", "url": "https://media1.giphy.com/media/62PP2yEIAZF6g/giphy.gif"},
                {"title": "OMG", "url": "https://media1.giphy.com/media/l0MYGb1LuZ3n7dRnO/giphy.gif"},
                {"title": "Wow", "url": "https://media1.giphy.com/media/udmx3pgdiD7tm/giphy.gif"},
                {"title": "Heart", "url": "https://media1.giphy.com/media/26BRv0ThflsHCqDrG/giphy.gif"},
                {"title": "Cry", "url": "https://media1.giphy.com/media/d2lcHJTG5Tscg/giphy.gif"},
                {"title": "Party", "url": "https://media1.giphy.com/media/l0MYt5jPR6QX5pnqM/giphy.gif"},
                {"title": "Hug", "url": "https://media1.giphy.com/media/ZBQhoZC0nqknSviPqT/giphy.gif"},
                {"title": "Eye Roll", "url": "https://media1.giphy.com/media/sbCdjSJEGghGM/giphy.gif"},
            ]
            random.shuffle(fallback)
            return jsonify({"results": fallback[:limit]}), 200

        try:
            results = []

            # â”€â”€ Try Tenor v2 first when a v2 key exists â”€â”€
            if _tenor_v2_key:
                base = "https://tenor.googleapis.com/v2"
                if q:
                    endpoint = f"{base}/search"
                    params = {
                        "q": q,
                        "key": _tenor_v2_key,
                        "limit": str(limit),
                        "media_filter": "tinygif,gif",
                        "client_key": "VybeFlow",
                    }
                else:
                    endpoint = f"{base}/featured"
                    params = {
                        "key": _tenor_v2_key,
                        "limit": str(limit),
                        "media_filter": "tinygif,gif",
                        "client_key": "VybeFlow",
                    }

                resp = requests.get(endpoint, params=params, timeout=6)
                if resp.ok:
                    data = resp.json()
                    for item in data.get("results", []):
                        url = None
                        preview = None
                        # v2 format: media_formats dict
                        media_formats = item.get("media_formats") or {}
                        if "tinygif" in media_formats:
                            url = media_formats["tinygif"].get("url")
                            preview = url
                        elif "gif" in media_formats:
                            url = media_formats["gif"].get("url")
                            preview = url
                        if not url:
                            continue
                        results.append({
                            "title": item.get("title") or item.get("content_description") or q or "GIF",
                            "url": url,
                            "preview": preview,
                        })
                else:
                    current_app.logger.warning(f"Tenor v2 API error {resp.status_code}: {resp.text[:200]}")

            # â”€â”€ If v2 unavailable/empty, try legacy Tenor v1 with TENOR_API_KEY â”€â”€
            if not results and _tenor_v1_key:
                v1_base = "https://g.tenor.com/v1"
                if q:
                    v1_endpoint = f"{v1_base}/search"
                    v1_params = {
                        "q": q,
                        "key": _tenor_v1_key,
                        "limit": str(limit),
                    }
                else:
                    v1_endpoint = f"{v1_base}/trending"
                    v1_params = {
                        "key": _tenor_v1_key,
                        "limit": str(limit),
                    }

                v1_resp = requests.get(v1_endpoint, params=v1_params, timeout=6)
                if v1_resp.ok:
                    v1_data = v1_resp.json()
                    for item in v1_data.get("results", []):
                        media_list = item.get("media") or []
                        media0 = media_list[0] if media_list else {}
                        tiny = media0.get("tinygif") or {}
                        gif = media0.get("gif") or {}
                        nano = media0.get("nanogif") or {}
                        url = tiny.get("url") or gif.get("url")
                        preview = nano.get("url") or tiny.get("url") or gif.get("url")
                        if not url:
                            continue
                        results.append({
                            "title": item.get("title") or item.get("content_description") or q or "GIF",
                            "url": url,
                            "preview": preview,
                        })
                else:
                    current_app.logger.warning(f"Tenor v1 API error {v1_resp.status_code}: {v1_resp.text[:200]}")

            if not results:
                raise ValueError("Tenor returned no results")
            _gif_cache_put(_cache_key, {"results": results, "ts": _time.time()})
            return jsonify({"results": results}), 200
        except Exception as e:
            current_app.logger.warning(f"gif search failed: {e}")
            # Return GIPHY fallback GIFs so users always have something to pick
            emergency = [
                {"title": "Fire", "url": "https://media1.giphy.com/media/3o7TKSjRrfIPjeiVyM/giphy.gif"},
                {"title": "Laugh", "url": "https://media1.giphy.com/media/10JhviFuU2gWD6/giphy.gif"},
                {"title": "Dance", "url": "https://media1.giphy.com/media/l0MYt5jPR6QX5pnqM/giphy.gif"},
                {"title": "Thumbs Up", "url": "https://media1.giphy.com/media/111ebonMs90YLu/giphy.gif"},
                {"title": "Cool", "url": "https://media1.giphy.com/media/62PP2yEIAZF6g/giphy.gif"},
                {"title": "Heart", "url": "https://media1.giphy.com/media/26BRv0ThflsHCqDrG/giphy.gif"},
            ]
            return jsonify({"results": emergency}), 200

