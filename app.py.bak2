    @app.post("/api/user/verify-mature-pin")
    def api_user_verify_mature_pin():
        """Verify the account-level mature PIN and unlock mature content for this session.

        Accepts either ``{"pin": "<digits>"}`` for PIN-based auth, or
        ``{"biometric": true}`` when the client has successfully completed a
        WebAuthn platform-authenticator assertion (user presence is confirmed
        device-side; we trust the client assertion here as the biometric
        verification was already performed by the OS).
        """
        try:
            from models import User

            username = (session.get("username") or "").strip()
            if not username:
                return jsonify({"error": "Not signed in"}), 401

            user = User.query.filter_by(username=username).first()
            if not user:
                return jsonify({"error": "User not found"}), 404

            data = request.get_json(silent=True) or {}

            # Biometric path â€” client performed WebAuthn; we unlock if user has a PIN set
            if data.get("biometric"):
                if getattr(user, "mature_pin", None):
                    session["mature_content_unlocked"] = True
                    return jsonify({"ok": True, "unlocked": True}), 200
                return jsonify({"error": "No mature PIN configured", "unlocked": False}), 400

            if not getattr(user, "mature_pin", None):
                return jsonify({"error": "No mature PIN configured"}), 400

            pin = str(data.get("pin", "")).strip()
            if not pin:
                return jsonify({"error": "PIN required"}), 400

            if check_password_hash(user.mature_pin, pin):
                session["mature_content_unlocked"] = True
                return jsonify({"ok": True, "unlocked": True}), 200
            else:
                return jsonify({"ok": False, "unlocked": False, "error": "Wrong PIN"}), 403
        except Exception:
            current_app.logger.exception("verify_mature_pin failed")
            return jsonify({"error": "Failed to verify PIN"}), 500

    @app.delete("/api/user/mature-pin")
    def api_user_delete_mature_pin():
        """Remove the account-level mature content PIN."""
        try:
            from models import User
