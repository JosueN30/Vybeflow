    @app.get("/messenger")
    def messenger():
        from models import User
        import hashlib, os as _os
        username = session.get("username")
        if not username:
            return redirect(url_for("login"))
        contacts = []
        current_user_data = {"id": None, "username": None, "avatar_url": None}
        try:
            me = User.query.filter_by(username=username).first()
            if not me:
                # Auto-provision so messaging always works
                email = f"{username}@VybeFlow.local"
                pw_hash = hashlib.sha256((username + _os.urandom(16).hex()).encode()).hexdigest()
                me = User(username=username, email=email, password_hash=pw_hash)
                db.session.add(me)
                db.session.commit()
            if me:
                current_user_data = {"id": me.id, "username": me.username,
                                     "display_name": getattr(me, "display_name", None) or me.username,
                                     "avatar_url": getattr(me, "avatar_url", None),
                                     "adult_verified": bool(getattr(me, "adult_verified", False)) and not bool(getattr(me, "adult_access_revoked", False))}
        except Exception:
            pass
        return render_template("messenger.html", contacts=contacts,
                               current_user=current_user_data)

