                    db.session.execute(text(f"ALTER TABLE user ADD COLUMN {col_name} {col_def}"))
                    db.session.commit()
            # ── Trust & Safety columns ──
            for col_name, col_def in [
                ("trust_score", "INTEGER DEFAULT 50"),
                ("is_verified_human", "BOOLEAN DEFAULT 0"),
                ("verified_human_at", "DATETIME"),
                ("message_filter_level", "VARCHAR(20) DEFAULT 'standard'"),
                ("scam_flags", "INTEGER DEFAULT 0"),
            ]:
                if col_name not in cols:
                    db.session.execute(text(f"ALTER TABLE user ADD COLUMN {col_name} {col_def}"))
                    db.session.commit()
            # ── Privacy & Anonymity columns ──
            for col_name, col_def in [
                ("anonymous_posting_enabled", "BOOLEAN DEFAULT 0"),
                ("temp_username", "VARCHAR(80)"),
                ("temp_username_expires", "DATETIME"),
                ("is_burn_account", "BOOLEAN DEFAULT 0"),
                ("burn_expires_at", "DATETIME"),
                ("hidden_profile", "BOOLEAN DEFAULT 0"),
            ]:
                if col_name not in cols:
                    db.session.execute(text(f"ALTER TABLE user ADD COLUMN {col_name} {col_def}"))
                    db.session.commit()
            # ── AI Fake Account Detection columns ──
            for col_name, col_def in [
                ("fake_account_warnings", "INTEGER DEFAULT 0"),
                ("fake_account_reasons", "TEXT"),
                ("is_banned", "BOOLEAN DEFAULT 0"),
                ("banned_at", "DATETIME"),
                ("ban_reason", "TEXT"),
            ]:
                if col_name not in cols:
                    db.session.execute(text(f"ALTER TABLE user ADD COLUMN {col_name} {col_def}"))
                    db.session.commit()
            # ── Suspension / Appeal columns (3-strike system) ──
            for col_name, col_def in [
                ("is_suspended", "BOOLEAN DEFAULT 0"),
                ("appeal_pending", "BOOLEAN DEFAULT 0"),
                ("suspension_reason", "TEXT"),
            ]:
                if col_name not in cols:
                    db.session.execute(text(f"ALTER TABLE user ADD COLUMN {col_name} {col_def}"))
                    db.session.commit()
            # ── Post anonymous columns ──
            if "is_anonymous" not in post_cols:
                db.session.execute(text("ALTER TABLE post ADD COLUMN is_anonymous BOOLEAN DEFAULT 0"))
                db.session.commit()
            if "anonymous_alias" not in post_cols:
                db.session.execute(text("ALTER TABLE post ADD COLUMN anonymous_alias VARCHAR(80)"))
                db.session.commit()
            # ── Reel content-moderation columns ──
            reel_cols = {c["name"] for c in inspector.get_columns("reel")} if "reel" in inspector.get_table_names() else set()
            for col_name, col_def in [
                ("is_adult", "BOOLEAN DEFAULT 0"),
                ("is_nsfw",  "BOOLEAN DEFAULT 0"),
            ]:
                if col_name not in reel_cols:
                    db.session.execute(text(f"ALTER TABLE reel ADD COLUMN {col_name} {col_def}"))
                    db.session.commit()
        except Exception as e:
            print(f"Note: Could not ensure profile_bg_url column: {e}")

    # ── Backwards-compat alias: /api/profile/music/list → /api/music/list ──
    @app.get("/api/profile/music/list")
    def api_profile_music_list():
        from music_api import list_tracks
        return list_tracks()

    # ── Ghost message background sweeper (daemon thread) ──
    import threading as _threading
    def _ghost_sweep_worker():
        import time, requests as _req
        _token = os.environ.get("VF_SWEEP_TOKEN", "vf-internal-sweep-2026")
        while True:
            time.sleep(60)
            try:
                _req.delete(
                    "http://127.0.0.1:5000/api/dm/ghost/sweep",
                    headers={"X-Sweep-Token": _token},
                    timeout=10,
                )
            except Exception:
                pass  # server may not be ready yet — next iteration will retry
    # Only start the sweep thread in the main process (not the reloader child)
    import os as _os_sweep
    if not _os_sweep.environ.get('WERKZEUG_RUN_MAIN'):
        _sweep_thread = _threading.Thread(target=_ghost_sweep_worker, daemon=True, name="ghost-sweeper")
        _sweep_thread.start()

    # ── Expired Block auto-unblock sweeper (daemon thread) ──────────────────
    def _block_sweep_worker():
        import time as _time_bs
        while True:
            _time_bs.sleep(300)  # check every 5 minutes
            try:
                with app.app_context():
                    from models import Block as _Blk
                    from __init__ import db as _db_bs
                    from datetime import datetime as _dt_bs
                    expired = _Blk.query.filter(
                        _Blk.expires_at <= _dt_bs.utcnow(),
                        _Blk.is_active == True,  # noqa: E712
                    ).all()
                    for blk in expired:
                        blk.is_active = False
                    if expired:
                        _db_bs.session.commit()
            except Exception:
                pass  # keep sweeping regardless
    _block_sweep_thread = _threading.Thread(
        target=_block_sweep_worker, daemon=True, name="block-sweeper"
    )
    if not _os_sweep.environ.get('WERKZEUG_RUN_MAIN'):
        _block_sweep_thread.start()

    # ── IP Anonymization daemon (runs every 24h) ──────────────────────────────
    # Replaces raw IP addresses in system_log rows older than 24h with a keyed
    # HMAC-SHA256 truncated hash so the DB contains no trackable identifiers.
    # Set PRIVACY_IP_PEPPER=<64-char-hex> in production for a stable key.
    def _ip_anon_worker():
        import time as _time
        _INTERVAL = 24 * 60 * 60   # 24 hours
        while True:
            _time.sleep(_INTERVAL)
            try:
                with app.app_context():
                    from utils.privacy import anonymize_stale_ips as _anon
                    n = _anon(db, hours=24)
                    if n:
                        print(f"[VybeFlow Privacy] Anonymized {n} IP record(s).")
            except Exception as _e:
                import logging as _lg
                _lg.getLogger("vybeflow.privacy").error(
                    "IP anonymisation daemon error: %s", _e
                )

    _ip_anon_thread = _threading.Thread(
        target=_ip_anon_worker, daemon=True, name="ip-anonymizer"
    )
    if not _os_sweep.environ.get('WERKZEUG_RUN_MAIN'):
        _ip_anon_thread.start()

    # ── Request-ID middleware ─────────────────────────────────────────────────
    # Attaches a UUID to every request so logs, error records, and Sentry-style
    # traces can be correlated across services.
    import uuid as _uuid
    from flask import g as _g

    @app.before_request
    def _attach_request_id():
        _g.request_id = request.headers.get("X-Request-ID") or _uuid.uuid4().hex

    @app.after_request
    def _expose_request_id(response):
        response.headers["X-Request-ID"] = getattr(_g, "request_id", "")
        return response

    # ── Dynamic Seed Token (DST) — per-request rotating auth token ───────────
    # Intercept BEFORE any route handler runs. On mutating requests from logged-in
    # users, validate the X-VF-DST header.  Enforcement mode is controlled by the
    # DST_ENFORCEMENT env var: "advisory" (default) = log only; "strict" = reject.
    from utils.dynamic_token import (
        validate_and_rotate as _dst_validate,
        should_enforce as _dst_should_enforce,
        DST_ENFORCEMENT as _DST_MODE,
    )
    import logging as _dst_log_mod
    _dst_logger = _dst_log_mod.getLogger("vybeflow.dst")

    @app.before_request
    def _dst_validate_request():
        """
        Validate the Dynamic Seed Token on every mutating authenticated request.
        Stores (valid, next_token, error) on flask.g for the after_request hook.
        """
        _g.dst_next_token = None
        _g.dst_valid = True
        _g.dst_error = None

        if not _dst_should_enforce(request, session):
            return  # GET, unauthenticated, or exempt paths skip DST

        incoming_token = request.headers.get("X-VF-DST", "").strip()
        valid, next_token, error = _dst_validate(incoming_token, request, session)

        _g.dst_valid = valid
        _g.dst_next_token = next_token
        _g.dst_error = error

        if not valid:
            _dst_logger.warning(
                "[DST] INVALID token: error=%s uid=%s ip=%s path=%s",
                error,
                session.get("user_id"),
                request.headers.get("X-Forwarded-For", request.remote_addr),
                request.path,
            )
            if _DST_MODE == "strict":
                from flask import jsonify as _jdst
                _status = 401 if error in ("missing_token", "uid_mismatch", "session_id_mismatch") else 409
                return _jdst({
                    "error": "Token expired or already used. Fetch a fresh token from /api/auth/token.",
                    "dst_error": error,
                    "dst_refresh": "/api/auth/token",
                }), _status
            # advisory mode: allow the request through but log the violation

    @app.after_request
    def _dst_inject_next_token(response):
        """Attach the next DST to every response so the client can use it on the next request."""
        next_token = getattr(_g, "dst_next_token", None)
        if next_token:
            response.headers["X-VF-Next-Token"] = next_token
            # Expose to JS via CORS-safe header
            existing_expose = response.headers.get("Access-Control-Expose-Headers", "")
            if "X-VF-Next-Token" not in existing_expose:
                extras = "X-VF-Next-Token, X-Request-ID"
                response.headers["Access-Control-Expose-Headers"] = (
                    f"{existing_expose}, {extras}" if existing_expose else extras
                )
        return response

    # ── DST token-refresh endpoint ────────────────────────────────────────────
    # Called by the frontend after a page load (no prior token available) or
    # after detecting a desync.  Returns a fresh Token[N] without consuming one.
    @app.route("/api/auth/token", methods=["GET"])
    def _dst_get_token():
        from flask import jsonify as _jt, session as _st
        from utils.dynamic_token import generate_token as _gen_tok, init_dst_session as _init_dst
        uid = _st.get("user_id")
        if not uid or not _st.get("logged_in"):
            return _jt({"error": "Not authenticated"}), 401
        # If no DST session yet (e.g. user logged in before DST was deployed), init now
        if not _st.get("dst_session_id"):
            first_token = _init_dst(uid, request, _st)
            return _jt({"token": first_token, "ttl": 30}), 200
        # Issue next token without requiring a previous one (page reload scenario)
        next_seq = _st.get("dst_seq", 0)
        fresh = _gen_tok(uid, _st["dst_session_id"], next_seq, request)
        return _jt({"token": fresh, "ttl": 30}), 200

    # ── CSP nonce generator ───────────────────────────────────────────────────
    # A fresh random nonce is generated per-request; injected into the CSP
    # header and exposed as g.csp_nonce so templates can use it:
    #   <script nonce="{{ g.csp_nonce }}">...</script>
    # When all templates are migrated, remove 'unsafe-inline' from script-src.
    import secrets as _csp_sec
    from flask import g as _csp_g

    @app.before_request
    def _generate_csp_nonce():
        _csp_g.csp_nonce = _csp_sec.token_hex(16)

    # ── Privacy-First Security Headers ───────────────────────────────────────
    # CSP blocks ALL third-party scripts, tracking pixels, and iframes.
    # Referrer-Policy stops URL leakage to external services.
    # Permissions-Policy locks down every sensitive browser API.
    @app.after_request
    def _set_security_headers(response):
        # Content-Security-Policy ─────────────────────────────────────────────
        # nonce-based approach: each response gets a unique nonce. Templates
        # should add nonce="{{ g.csp_nonce }}" to every <script> tag.
        # 'unsafe-inline' is kept here ONLY as a fallback while templates are
        # being migrated to use the nonce attribute; once all templates are
        # migrated, remove 'unsafe-inline' from script-src.
        _nonce = getattr(_csp_g, "csp_nonce", _csp_sec.token_hex(16))
        csp = (
            "default-src 'self'; "
            # Scripts: nonce-gated.  'unsafe-inline' is ignored by browsers that
            # honour nonces, so the nonce is the real enforcement layer.
            f"script-src 'self' 'nonce-{_nonce}' 'unsafe-inline'; "
            # Styles: inline OK + Google Fonts stylesheet (decorative, no data leak)
            "style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; "
            # Images: self + data URIs + blob + Apple/Deezer album art CDNs
            "img-src 'self' data: blob: https://*.mzstatic.com https://*.dzcdn.net; "
            # Media: self + blob for MediaRecorder. External previews are proxied
            # through /api/music/stream so media-src stays locked to self.
            "media-src 'self' blob:; "
            # Fetch / XHR / WebSocket: ONLY to our own origin
            "connect-src 'self' wss:; "
            # Fonts: self + Google Fonts static CDN (used by base.html)
            "font-src 'self' https://fonts.gstatic.com; "
            # No plugins (Flash, Java, PDF inline)
            "object-src 'none'; "
            # No iframes from anywhere
            "frame-src 'none'; "
            # Blocks this page from being framed (clickjacking)
            "frame-ancestors 'none'; "
            # service-worker / manifest: self only
            "worker-src 'self' blob:; "
            "manifest-src 'self'; "
            # Restrict <base> tag to prevent base-URI injection
            "base-uri 'self'; "
            # Only allow form submissions to self
            "form-action 'self'; "
            # Force all sub-resource loads to HTTPS when the page is served over HTTPS.
            # No-op on HTTP (dev), enforced in production.
            "upgrade-insecure-requests;"
        )
        response.headers["Content-Security-Policy"] = csp

        # No framing from any origin (belt + suspenders with frame-ancestors)
        response.headers["X-Frame-Options"] = "DENY"

        # Prevent MIME-type sniffing (stops content-injection via image upload)
        response.headers["X-Content-Type-Options"] = "nosniff"

        # Never send the Referer header to any external page
        response.headers["Referrer-Policy"] = "no-referrer"

        # Block Flash/Silverlight cross-domain access (defense-in-depth)
        response.headers["X-Permitted-Cross-Domain-Policies"] = "none"

        # Lock down sensitive browser capabilities.
        # microphone=(self) and camera=(self) allow the VybeFlow origin to use
        # these APIs (voice notes, video calls) while still blocking third-party
        # iframes from accessing them.
        response.headers["Permissions-Policy"] = (
            "camera=(self), "
            "microphone=(self), "
            "geolocation=(), "
            "payment=(), "
            "usb=(), "
            "bluetooth=(), "
            "interest-cohort=()"    # opt out of Google FLoC / Topics
        )

        # Prevent cross-origin information leakage for top-level navigations
        response.headers["Cross-Origin-Opener-Policy"] = "same-origin"

        # Remove the Server header so the web server brand isn't advertised
        response.headers.remove("Server")

        # HTTP Strict Transport Security — tells browsers to only use HTTPS.
        # max-age=63072000 = 2 years; includeSubDomains covers all subdomains.
        # Only sent over HTTPS (detected via X-Forwarded-Proto or request.is_secure)
        _is_https = (
            request.is_secure
            or request.headers.get("X-Forwarded-Proto", "").lower() == "https"
        )
        if _is_https:
            response.headers["Strict-Transport-Security"] = (
                "max-age=63072000; includeSubDomains; preload"
            )

        return response
    # Any uncaught exception in a route reaches these handlers INSTEAD of
    # printing a raw 500 HTML page.  The error is written to system_log and
    # a clean JSON response is returned to the client.

    def _write_syslog(level, source, message, detail=None, user_id=None):
        """Best-effort write to system_log — never raises."""
        try:
            from models import SystemLog as _SL
            from flask import has_request_context, request as _req, g as _g2
            ip = None
            rid = None
            if has_request_context():
                ip  = (_req.headers.get("X-Forwarded-For") or _req.remote_addr or "")[:45]
                rid = getattr(_g2, "request_id", None)
            entry = _SL(
                level=level,
                source=source,
                message=str(message)[:500],
                detail=str(detail or "")[:4000],
                user_id=user_id,
                ip_address=ip,
                request_id=rid,
            )
            db.session.add(entry)
            db.session.commit()
        except Exception as _sle:
            import logging as _logging
            _logging.getLogger("vybeflow.syslog").error(
                "Could not write to system_log: %s", _sle
            )
            try:
                db.session.rollback()
            except Exception:
                pass

    @app.errorhandler(Exception)
    def handle_unhandled_exception(exc):
        """Catch-all for unhandled exceptions in any route."""
        # Handle CSRF validation failures cleanly — return JSON for API paths
        # so the browser doesn't see a raw black-text HTML error page.
        try:
            from flask_wtf.csrf import CSRFError as _CSRFError
            if isinstance(exc, _CSRFError):
                _is_xhr = (
                    request.path.startswith("/api/") or
                    "application/json" in request.headers.get("Accept", "") or
                    request.headers.get("X-Requested-With", "").lower() == "xmlhttprequest"
                )
                if _is_xhr:
                    return jsonify({
                        "error": "Session token expired — please refresh the page and try again.",
                        "code": "csrf_error",
                    }), 400
                # For HTML form routes, redirect back to the form with a clear message
                try:
                    from flask import flash as _flash
                    if request.path in ("/login", "/register"):
                        _flash(
                            "Your form session expired. This happens when a tab is left open "
                            "for a long time. Please try again — your details were not lost.",
                            "warning"
                        )
                        return redirect(request.path), 302
                    _flash("Session token expired — please try again.", "warning")
                except Exception:
                    pass
                return redirect(request.referrer or "/login"), 302
        except ImportError:
            pass
        import traceback as _tb
        detail = _tb.format_exc()
        uid = None
        try:
            from models import User as _U
            _uname = session.get("username", "")
            if _uname:
                _u = _U.query.filter_by(username=_uname).first()
                if _u:
                    uid = _u.id
        except Exception:
            pass

        source = request.endpoint or request.path or "unknown"
        print(f"[VybeFlow UNHANDLED] {source}: {exc}\n{detail}")
        _write_syslog("error", source, str(exc), detail, uid)

        # Return JSON for API routes, HTML for page routes
        if (request.path.startswith("/api/") or
                "application/json" in request.headers.get("Accept", "")):
            return jsonify({
                "error": "An unexpected error occurred. Our team has been notified.",
                "code": "server_error",
                "request_id": getattr(_g, "request_id", ""),
            }), 500

        try:
            return render_template(
                "500.html",
                error_id=getattr(_g, "request_id", ""),
            ), 500
        except Exception:
            return (
                f"<h1>Something went wrong</h1>"
                f"<p>Error ID: {getattr(_g, 'request_id', '')}</p>",
                500,
            )

    @app.errorhandler(404)
    def handle_404(exc):
        if request.path.startswith("/api/"):
            return jsonify({"error": "Endpoint not found", "code": "not_found"}), 404
        try:
            return render_template("404.html"), 404
        except Exception:
            return "<h1>404 — Page not found</h1>", 404

    @app.errorhandler(413)
    def handle_413(exc):
        if request.path.startswith("/api/"):
            return jsonify({"ok": False, "error": "File too large. Maximum upload size is 4 GB."}), 413
        try:
            return render_template("500.html", error_msg="File too large. Maximum upload size is 4 GB."), 413
        except Exception:
            return "<h1>413 — File too large</h1><p>Maximum upload size is 4 GB.</p>", 413

    @app.errorhandler(405)
    def handle_405(exc):
        if request.path.startswith("/api/"):
            return jsonify({"error": "Method not allowed", "code": "method_not_allowed"}), 405
        try:
            return render_template("405.html"), 405
        except Exception:
            return "<h1>405 — Method not allowed</h1>", 405

