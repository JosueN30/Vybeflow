    @app.get("/create_story")
    def create_story():
        if not session.get("username"):
            return redirect(url_for("login") + "?next=/create_story")
        story_id = uuid.uuid4().hex[:12]
        # Load recent stories for the rail
        _stories = []
        try:
            from models import Story as _St
            from datetime import datetime as _stdt
            _stories = _St.query.filter(
                _St.expires_at > _stdt.utcnow()
            ).order_by(_St.created_at.desc()).limit(20).all()
        except Exception:
            pass
        return render_template("story_create.html", story_id=story_id, stories=_stories)

    @app.get("/story/<int:story_id>")
    def view_story(story_id: int):
        """Story viewer â€” redirect to the full stories viewer page.

        The /stories page has a proper full-screen story viewer with
        segments, reactions, replies, seen list, etc.
        """
        return redirect(url_for("story_routes.stories_page") + "?open=" + str(story_id))

    @app.post("/story/create")
    def story_create_post():
        try:
            from models import Story, StoryItem, User
            from __init__ import db
            import hashlib
            import os

            # â”€â”€ Auth guard: stories require a valid session â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            _sess_username = (session.get('username') or '').strip()
            if not _sess_username:
                return jsonify({"error": "You must be signed in to share a story.", "auth": False}), 401

            caption = (request.form.get("caption") or "").strip()

            # â”€â”€ AI moderation: scan caption for hate speech & directed negativity â”€â”€
            if caption:
                from moderation_engine import moderate_text as _mod_text
                mod = _mod_text(caption)
                if mod.decision in ("block", "warn", "quarantine"):
                    # Fetch user early to apply strike
                    _uname = _sess_username
                    _story_user = User.query.filter_by(username=_uname).first()
                    if _story_user:
                        # Ban gate
                        if getattr(_story_user, 'is_banned', False) or getattr(_story_user, 'is_suspended', False):
                            return jsonify({"ok": False, "error": "Your account is BANNED. Submit an appeal to regain access.", "banned": True, "appeal_available": True}), 403
                        return _apply_strike(_story_user, mod.reason, "story")
                    return jsonify({"error": "Your story was auto-removed for violating community guidelines."}), 403

            # Visibility supports Public, Followers, Only Me (draft)
            raw_visibility = (request.form.get("visibility") or "Public").strip()
            def normalize_visibility(value: str) -> str:
                key = (value or "Public").strip().lower()
                if key in ("public", "everyone"):
                    return "Public"
                if key in ("followers", "follower"):
                    return "Followers"
                if key in ("only me", "only_me", "private", "draft"):
                    return "Only Me"
                return "Public"
            visibility = normalize_visibility(raw_visibility)
            music_track = (request.form.get("music_track") or "").strip()
            music_preview_url = (request.form.get("music_preview_url") or "").strip()
            # Discard blob: URLs â€” they only work in the browser that created them
            if music_preview_url.startswith("blob:"):
                music_preview_url = ""
            story_font = (request.form.get("story_font") or "neon").strip()

            media_file = request.files.get("media") or request.files.get("theme_video") or request.files.get("selfie_capture")

            # Also accept camera-captured photos sent as base64 data URLs
            camera_data = (request.form.get("camera_photo_data") or "").strip()
            # Also accept doodle drawings sent as base64 data URLs
            doodle_data = (request.form.get("doodle_data") or "").strip()
            # Accept uploaded music file as story media
            music_file = request.files.get("music_file")

            media_url = None
            media_type = "image"
            poster_url = None
            video_job = None
            music_file_url = None

            # Save uploaded music file first (can coexist with visual media)
            if music_file and music_file.filename:
                music_file_url = _save_audio_upload(music_file)

            if media_file and media_file.filename:
                media_url, media_type, poster_url, video_job = _save_upload(media_file)
            elif camera_data and len(camera_data) > 10:
                # Cap base64 payload at ~30 MB decoded (40 MB base64)
                if len(camera_data) > 40 * 1024 * 1024:
                    return jsonify({"error": "Camera photo too large (max 30 MB)."}), 400
                # Decode the base64 data-URL from the camera canvas
                import base64 as _b64
                # Strip data:image/png;base64, prefix if present
                if "," in camera_data:
                    camera_data = camera_data.split(",", 1)[1]
                img_bytes = _b64.b64decode(camera_data)
                unique = f"{uuid.uuid4().hex}.png"
                disk_path = os.path.join(current_app.config["POST_UPLOAD_ABS"], unique)
                os.makedirs(os.path.dirname(disk_path), exist_ok=True)
                with open(disk_path, "wb") as f:
                    f.write(img_bytes)
                media_url = current_app.config["UPLOAD_URL_PREFIX"] + unique
                media_type = "image"
            elif doodle_data and len(doodle_data) > 10:
                # Cap base64 payload at ~30 MB decoded (40 MB base64)
                if len(doodle_data) > 40 * 1024 * 1024:
                    return jsonify({"error": "Doodle image too large (max 30 MB)."}), 400
                # Decode the base64 data-URL from the doodle canvas
                import base64 as _b64
                raw = doodle_data
                if "," in raw:
                    raw = raw.split(",", 1)[1]
                img_bytes = _b64.b64decode(raw)
                unique = f"{uuid.uuid4().hex}_doodle.png"
                disk_path = os.path.join(current_app.config["POST_UPLOAD_ABS"], unique)
                os.makedirs(os.path.dirname(disk_path), exist_ok=True)
                with open(disk_path, "wb") as f:
                    f.write(img_bytes)
                media_url = current_app.config["UPLOAD_URL_PREFIX"] + unique
                media_type = "image"
            elif music_file_url:
                # Music-only story: use the already-saved audio file
                media_url = music_file_url
                media_type = "audio"
            elif music_preview_url:
                # Music clip story â€” use the preview URL as the media source
                media_url = music_preview_url
                media_type = "audio"
            elif caption:
                # Text-only story â€” generate a colored background image
                import base64 as _b64
                # Create a simple 1080x1920 PNG placeholder (1x1 pixel, the frontend renders the text overlay)
                # Use a minimal PNG that the story viewer will style
                media_url = "data:text-story"
                media_type = "text"
            else:
                return jsonify({"error": "Missing story media. Add a photo, video, doodle, music, or text."}), 400

            # â”€â”€ Resolve authenticated user â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            from sqlalchemy import func as _func
            user = User.query.filter(_func.lower(User.username) == _sess_username.lower()).first()
            if not user:
                return jsonify({"error": "Account not found. Please sign in again.", "auth": False}), 401

            if media_type == "video" and video_job and music_preview_url:
                video_job["audio_url"] = music_preview_url

            # â”€â”€ AI content moderation scan â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            is_nsfw = False
            content_label = "clean"
            content_flags_json = "[]"
            content_flags_list: list = []

            if media_url and media_type in ("image", "video"):
                try:
                    abs_media = media_url
                    if media_url.startswith("/"):
                        abs_media = os.path.join(current_app.root_path, media_url.lstrip("/"))

                    from content_scanner import scan_content, flags_to_json
                    scan = scan_content(
                        media_path=abs_media if os.path.isfile(abs_media) else None,
                        caption=caption or "",
                        media_type=media_type or "image",
                    )

                    content_label = scan["label"]
                    content_flags_list = scan["flags"]
                    content_flags_json = flags_to_json(content_flags_list)

                    if scan["blocked"]:
                        return jsonify({
                            "error": "Your story contains content that violates our community guidelines and cannot be posted.",
                            "reason": scan["details"],
                            "flags": content_flags_list,
                        }), 403

                    if content_label == "mature":
                        is_nsfw = True

                except Exception as _ce:
                    current_app.logger.warning(f"Content scan error: {_ce}")
            elif caption:
                # Text-only stories: still check the caption
                try:
                    from content_scanner import scan_content, flags_to_json
                    scan = scan_content(media_path=None, caption=caption or "", media_type="image")
                    content_label = scan["label"]
                    content_flags_list = scan["flags"]
                    content_flags_json = flags_to_json(content_flags_list)
                    if scan["blocked"]:
                        return jsonify({
                            "error": "Your story caption contains content that violates our community guidelines.",
                            "reason": scan["details"],
                            "flags": content_flags_list,
                        }), 403
                    if content_label == "mature":
                        is_nsfw = True
                except Exception as _ce:
                    current_app.logger.warning(f"Caption content scan error: {_ce}")

            # â”€â”€ Auto-resolve music preview URL when track selected but no audio source â”€â”€
            if music_track and not music_preview_url and not music_file_url:
                try:
                    from music_api import _itunes_search, _deezer_search
                    hits = _itunes_search(music_track, limit=3)
                    if not hits:
                        hits = _deezer_search(music_track, limit=3)
                    if hits:
                        music_preview_url = hits[0].get("preview_url", "")
                        current_app.logger.info(f"Auto-resolved music preview for '{music_track}': {music_preview_url[:80]}")
                except Exception as _e:
                    current_app.logger.warning(f"Music auto-resolve failed: {_e}")

            story = Story(
                author_id=user.id,
                user_id=user.id,
                caption=caption or "Shared a story on VybeFlow",
                media_url=media_url,
                visibility=visibility,  # Added visibility parameter
                music_track=music_track or None,
                music_preview_url=music_preview_url or None,
                music_file_url=music_file_url or None,
                story_font=story_font or "neon",
                is_nsfw=is_nsfw,
                content_label=content_label,
                content_flags=content_flags_json,
            )
            db.session.add(story)
            db.session.flush()

            story_item = StoryItem(
                story_id=story.id,
                media_type=media_type or "image",
                media_url=media_url,
                caption=caption or None,
                position=0,
            )
            db.session.add(story_item)
            db.session.commit()

            return jsonify({"ok": True, "story_id": story.id, "story_item_id": story_item.id, "is_nsfw": is_nsfw, "content_label": content_label, "content_flags": content_flags_list}), 201
        except Exception as _sc_err:
            current_app.logger.exception("story_create_post failed: %s", _sc_err)
            try:
                db.session.rollback()
            except Exception:
                pass
            return jsonify({"error": "Failed to share story", "detail": str(_sc_err)}), 500

    @app.delete("/api/stories/<int:story_id>")
    def api_stories_delete(story_id: int):
        """Delete a story (and its items) for the current user.

        Used by the feed UI so creators can remove their own stories.
        """
        try:
            from models import Story, StoryItem, User
            from __init__ import db

            username = (session.get("username") or "").strip()
            if not username:
                return jsonify({"error": "Not signed in"}), 401

            user = User.query.filter_by(username=username).first()
            if not user:
                return jsonify({"error": "User not found"}), 404

            story = db.session.get(Story, story_id)
            if not story:
                return jsonify({"error": "Story not found"}), 404

            if story.author_id not in (user.id, None) and story.user_id not in (user.id, None):
                return jsonify({"error": "Not allowed"}), 403

            StoryItem.query.filter_by(story_id=story.id).delete()
            db.session.delete(story)
            db.session.commit()
            return jsonify({"ok": True}), 200
        except Exception as e:
            current_app.logger.exception("api_stories_delete failed")
            return jsonify({"error": "Unable to delete story"}), 400

    @app.post("/api/story/<int:story_id>/set-nsfw-pin")
    def api_story_set_nsfw_pin(story_id: int):
        """Allow the story creator to set a PIN on NSFW content."""
        try:
            from models import Story, User
            from __init__ import db

            username = (session.get("username") or "").strip()
            if not username:
                return jsonify({"error": "Not signed in"}), 401

            user = User.query.filter_by(username=username).first()
            if not user:
                return jsonify({"error": "User not found"}), 404

            story = db.session.get(Story, story_id)
            if not story:
                return jsonify({"error": "Story not found"}), 404

            if story.author_id not in (user.id, None) and story.user_id not in (user.id, None):
                return jsonify({"error": "Not allowed"}), 403

            data = request.get_json(silent=True) or {}
            pin = str(data.get("pin", "")).strip()
            if not pin or len(pin) < 4 or len(pin) > 8 or not pin.isdigit():
                return jsonify({"error": "PIN must be 4-8 digits"}), 400

            story.is_nsfw = True
            story.nsfw_pin = generate_password_hash(pin, method='pbkdf2:sha256:260000')
            db.session.commit()
            return jsonify({"ok": True}), 200
        except Exception:
            current_app.logger.exception("set_nsfw_pin failed")
            return jsonify({"error": "Failed to set PIN"}), 500

    @app.post("/api/story/<int:story_id>/verify-nsfw-pin")
    def api_story_verify_nsfw_pin(story_id: int):
        """Verify the PIN to unlock NSFW story content."""
        try:
            from models import Story

            story = db.session.get(Story, story_id)
            if not story:
                return jsonify({"error": "Story not found"}), 404

            if not story.is_nsfw:
                return jsonify({"ok": True, "unlocked": True}), 200

            if not story.nsfw_pin:
                return jsonify({"ok": True, "unlocked": True}), 200

            data = request.get_json(silent=True) or {}
            pin = str(data.get("pin", "")).strip()
            if not pin:
                return jsonify({"error": "PIN required"}), 400

            if check_password_hash(story.nsfw_pin, pin):
                # Store unlock in session so they don't re-enter
                unlocked = session.get("nsfw_unlocked", [])
                if story_id not in unlocked:
                    unlocked.append(story_id)
                    session["nsfw_unlocked"] = unlocked
                return jsonify({"ok": True, "unlocked": True}), 200
            else:
                return jsonify({"ok": False, "unlocked": False, "error": "Wrong PIN"}), 403
        except Exception:
            current_app.logger.exception("verify_nsfw_pin failed")
            return jsonify({"error": "Failed to verify PIN"}), 500

