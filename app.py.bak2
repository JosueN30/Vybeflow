def _clean_env_key(val: str) -> str:
    """Normalize API keys loaded from env/.env (strip spaces and wrapping quotes)."""
    v = (val or "").strip()
    if (v.startswith('"') and v.endswith('"')) or (v.startswith("'") and v.endswith("'")):
        v = v[1:-1].strip()
    return v


TENOR_API_KEY = _clean_env_key(os.getenv("TENOR_API_KEY", ""))
