        supportive = [
            "You're killing it! ðŸ™Œ",
            "Keep going, this is amazing ðŸ’ª",
            "W post, W person ðŸ†",
        ]
        curious = [
            "Where was this?? ðŸ‘€",
            "How did you do this? ðŸ¤”",
            "Need the details! ðŸ“",
        ]
        hype = [
            "THIS IS IT 🔥🔥🔥",
            "Nobody's doing it like you ðŸ†",
            "Main character behavior ðŸŒŸ",
        ]

        pool = list(generic)
        if any(w in text for w in ("love", "â¤", "heart", "miss", "feel")):
            pool.extend(supportive)
        if any(w in text for w in ("🔥", "fire", "lit", "heat", "flex")):
            pool.extend(hype)
        if any(w in text for w in ("trip", "travel", "food", "fit", "photo")):
            pool.extend(curious)

        random.shuffle(pool)
        return pool[:4]

