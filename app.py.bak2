    @app.get("/profile/<username>")
    @check_block_status
    def user_profile(username):
        from models import User, ShieldMode, FriendRequest, Block
        from sqlalchemy import func
        # â”€â”€ Case-insensitive lookup so /profile/Alice and /profile/alice both resolve â”€â”€
        user = User.query.filter(func.lower(User.username) == username.lower()).first()
        if not user:
            return "User not found", 404
        current_username = session.get('username')
        current_user = (
            User.query.filter(func.lower(User.username) == current_username.lower()).first()
            if current_username else None
        )
        is_own_profile = current_user and current_user.id == user.id
        # Check friendship status
        is_friend = False
        friend_status = 'none'  # none | pending_sent | pending_received | accepted
        pending_request_id = None
        if current_user and not is_own_profile:
            fr = FriendRequest.query.filter(
                ((FriendRequest.sender_id == current_user.id) & (FriendRequest.receiver_id == user.id)) |
                ((FriendRequest.sender_id == user.id) & (FriendRequest.receiver_id == current_user.id))
            ).first()
            if fr:
                if fr.status == 'accepted':
                    is_friend = True
                    friend_status = 'accepted'
                elif fr.status == 'pending' and fr.sender_id == current_user.id:
                    friend_status = 'pending_sent'
                elif fr.status == 'pending' and fr.receiver_id == current_user.id:
                    friend_status = 'pending_received'
                    pending_request_id = fr.id
        # Enforce privacy â€” hidden/banned profiles return 404 to non-owners
        if not is_own_profile:
            if getattr(user, 'is_banned', False) or getattr(user, 'is_suspended', False):
                return "User not found", 404
            if getattr(user, 'hidden_profile', False):
                return "User not found", 404
            if getattr(user, 'profile_visibility', 'public') == 'hidden':
                return "User not found", 404
            # â”€â”€ Block check: if VIEWER blocked the TARGET, hide the profile (404).
            #    If TARGET blocked VIEWER, the @check_block_status decorator already
            #    redirected them to the broken-screen page before reaching here.
            if current_user:
                try:
                    if Block.is_blocked(current_user.id, user.id):
                        return "User not found", 404
                except Exception as _be:
                    current_app.logger.warning("block-check error on profile: %s", _be)
            # Shield mode hides profile from non-friends
            shield = ShieldMode.query.filter_by(user_id=user.id, is_active=True).first()
            if shield and not shield.is_expired and shield.hide_from_search and not is_friend:
                return "User not found", 404
        profile_bg_url = getattr(user, "profile_bg_url", "") or ""
        wp_config = {
            'type': getattr(user, 'wallpaper_type', 'none') or 'none',
            'color1': getattr(user, 'wallpaper_color1', '#0a0810') or '#0a0810',
            'color2': getattr(user, 'wallpaper_color2', '#1a1030') or '#1a1030',
            'pattern': getattr(user, 'wallpaper_pattern', 'none') or 'none',
            'animation': getattr(user, 'wallpaper_animation', 'none') or 'none',
            'motion': getattr(user, 'wallpaper_motion', 'none') or 'none',
            'glitter': bool(getattr(user, 'wallpaper_glitter', False)),
            'music_sync': bool(getattr(user, 'wallpaper_music_sync', False)),
            'image_url': getattr(user, 'wallpaper_image_url', '') or '',
        }
        # Build active_theme vars from the VIEWER's theme (not the profile owner's)
        # so the page-wide CSS matches the logged-in user's preference.
        _at = {}
        try:
            import json as _json_at
            _viewer = current_user if current_user else user
            _tc_at = {}
            _raw_tc_at = getattr(_viewer, 'theme_colors', None)
            if _raw_tc_at:
                _tc_at = _json_at.loads(_raw_tc_at)
            _at = {
                '--bg':     _tc_at.get('bg', '#0a0810'),
                '--brand1': _tc_at.get('brand1', '#ff9a3d'),
                '--brand2': _tc_at.get('brand2', '#ff6a00'),
                '--brand3': _tc_at.get('brand3', '#ff4800'),
                '--line':   'rgba(255,173,117,.20)',
            }
        except Exception:
            _at = {}
        return render_template("account.html", user=user, current_user=current_user, profile_bg_url=profile_bg_url, wp=wp_config, is_own_profile=is_own_profile, is_friend=is_friend, friend_status=friend_status, pending_request_id=pending_request_id, active_theme=_at,
            profile_font=(getattr(user, 'profile_font', '') or ''),
            graffiti_tags=__import__('json').loads(getattr(user, 'graffiti_tags', None) or '[]'),
        )

