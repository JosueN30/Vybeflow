            "dark": ["ðŸ–¤", "ðŸŒ‘", "ðŸ¦‡", "â˜ ï¸", "âš¡"],
            "space": ["ðŸš€", "ðŸŒ", "â­", "ðŸ›¸", "â˜„ï¸", "ðŸŒŒ"],
            "galaxy": ["ðŸŒŒ", "âœ¨", "ðŸ’«", "ðŸ”®", "ðŸŒ "],
            "forest": ["ðŸŒ²", "ðŸƒ", "ðŸ¦Š", "ðŸ„", "ðŸŒ¿"],
