    @app.post("/api/moderate_content", endpoint="moderate_content_api")
    def moderate_content_api():
        """Pre-flight content moderation check.  Applies a strike when the
        moderation engine flags the text, so the client-side block also
        increments the user's strike count toward the 3-strike BAN."""
        try:
            data = request.get_json(silent=True) or {}
            text = (data.get("text") or "").strip()
            if not text:
                return jsonify({"ok": True, "approved": True}), 200

            from moderation_engine import moderate_text as _mod_text
            mod = _mod_text(text)

            # ── Hard violations: instant strike ── ─────────────────────────────────
            # Only unambiguous hate speech, threats, doxxing, and scams trigger a
            # strike immediately. Everything else is sent to the pending-review queue
            # so a human can review it before any penalty is applied.
            HARD_BLOCK_REASONS = {
                'hate_speech_slur',
                'threat_or_self_harm_encouragement',
                'possible_doxxing',
                'scam_detected',
            }
            if mod.decision == "block" and mod.reason in HARD_BLOCK_REASONS:
                username = (session.get("username") or "").strip()
                if username:
                    from models import User
                    user = User.query.filter_by(username=username).first()
                    if user:
                        strike_resp = _apply_strike(user, mod.reason, "post")
                        return strike_resp
                # Fallback: block without strike if user not found
                return jsonify({
                    "ok": False,
                    "removed": True,
                    "reason": mod.reason,
                    "moderation": {"decision": mod.decision, "reason": mod.reason}
                }), 403

            # ── Soft violations: pending review — no automatic strike ───────────────
            # Warn / quarantine / borderline decisions go to human review.
            # Post is not published until approved; user gets an informational message.
            if mod.decision in ("warn", "quarantine") or mod.decision == "block":
                return jsonify({
                    "ok": False,
                    "pending_review": True,
                    "reason": mod.reason,
                    "message": "Your post has been flagged for review and will be visible once a moderator approves it.",
                    "moderation": {"decision": mod.decision, "reason": mod.reason}
                }), 202

            return jsonify({"ok": True, "approved": True}), 200
        except Exception as e:
            return jsonify({"ok": True, "approved": True, "error": str(e)}), 200

    @app.post("/api/moderation/reset-strikes")
    def api_reset_strikes():
        """Admin endpoint: clear false-positive strikes for a user.
        Body: { "username": "..." }
        Requires the caller to be logged in as an admin."""
        try:
            caller = (session.get("username") or "").strip()
            if not caller:
                return jsonify({"ok": False, "error": "Not authenticated"}), 401
            from models import User
            admin_user = User.query.filter_by(username=caller).first()
            if not admin_user or not getattr(admin_user, 'is_admin', False):
                return jsonify({"ok": False, "error": "Admin access required"}), 403
            data = request.get_json(silent=True) or {}
            target_username = (data.get("username") or "").strip()
            if not target_username:
                return jsonify({"ok": False, "error": "username required"}), 400
            target = User.query.filter_by(username=target_username).first()
            if not target:
                return jsonify({"ok": False, "error": "User not found"}), 404
            prev = getattr(target, 'negativity_warnings', 0) or 0
            target.negativity_warnings = 0
            target.is_banned = False
            target.is_suspended = False
            target.ban_reason = None
            target.suspension_reason = None
            db.session.commit()
            print(f"[VybeFlow ADMIN] {caller} reset strikes for {target_username} (was {prev})")
            return jsonify({"ok": True, "previous_strikes": prev, "username": target_username}), 200
        except Exception as e:
            db.session.rollback()
            return jsonify({"ok": False, "error": str(e)}), 500

    @app.post("/api/scan-media")
    def api_scan_media():
        """Client-side AI content scan for a locally-served media URL.
        Returns {ok, label, restricted, flags}.
        Only scans files reachable via the app's static/upload folders."""
        try:
            data = request.get_json(silent=True) or {}
            media_url = (data.get("media_url") or "").strip()
            if not media_url:
                return jsonify({"ok": True, "label": "clean", "restricted": False, "flags": []}), 200

            from urllib.parse import urlparse
            url_path = urlparse(media_url).path  # e.g. /static/uploads/file.jpg

            static_folder = current_app.static_folder or ""
            upload_folder = current_app.config.get(
                "UPLOAD_FOLDER",
                os.path.join(static_folder, "uploads")
            )

            local_path = None
            if url_path.startswith("/static/"):
                local_path = os.path.join(static_folder, url_path[len("/static/"):].lstrip("/"))
            elif url_path.startswith("/uploads/"):
                local_path = os.path.join(upload_folder, url_path[len("/uploads/"):].lstrip("/"))

            if not local_path or not os.path.isfile(local_path):
                # Can't scan — treat as clean so we don't block unfetchable URLs
                return jsonify({"ok": True, "label": "clean", "restricted": False, "flags": []}), 200

            ext = os.path.splitext(local_path)[1].lower()
            media_type = "video" if ext in (".mp4", ".mov", ".webm", ".m4v") else "image"

            import content_scanner as _cs
            result = _cs.scan_content(media_path=local_path, caption="", media_type=media_type)
            restricted = result.get("label") in ("mature", "blocked")
            return jsonify({
                "ok": True,
                "label": result.get("label", "clean"),
                "restricted": restricted,
                "flags": result.get("flags", []),
            }), 200
        except Exception as e:
            current_app.logger.error(f"[scan-media] {e}")
            return jsonify({"ok": True, "label": "clean", "restricted": False, "flags": []}), 200

