    @app.get("/api/user/state")
    def api_user_state():
        """Return the current user's moderation state for client-side global context.
        Used by UserContext.jsx / feed.html to sync strike count, ban status, and
        age-verification across the whole page without page reloads."""
        username = (session.get("username") or "").strip()
        if not username:
            return jsonify({
                "authenticated": False,
                "strikes": 0,
                "is_banned": False,
                "is_suspended": False,
                "is_verified": False,
                "appeal_pending": False,
                "account_status": "active",
            }), 200

        from models import User
        user = User.query.filter_by(username=username).first()
        if not user:
            return jsonify({
                "authenticated": False,
                "strikes": 0,
                "is_banned": False,
                "is_suspended": False,
                "is_verified": False,
                "appeal_pending": False,
                "account_status": "active",
            }), 200

        strikes = getattr(user, "negativity_warnings", 0) or 0
        banned = bool(getattr(user, "is_banned", False))
        suspended = bool(getattr(user, "is_suspended", False))
        verified = bool(getattr(user, "adult_verified", False))
        pending = bool(getattr(user, "appeal_pending", False))

        if banned:
            status = "Banned"
        elif suspended:
            status = "Suspended"
        elif strikes > 0:
            status = "Warned"
        else:
            status = "active"

        return jsonify({
            "authenticated": True,
            "user": {
                "id":             user.id,
                "username":       user.username,
                "trust_score":    getattr(user, "trust_score", 50),
                "home_currency":  getattr(user, "home_currency", "USD"),
                "currency_code":  getattr(user, "currency_code", "USD"),
                "signup_country": getattr(user, "signup_country", None),
                "inbox_mode":     getattr(user, "inbox_mode", "free"),
                "strike_count":   getattr(user, "negativity_warnings", 0) or 0,
            },
            "strikes": strikes,
            "is_banned": banned,
            "is_suspended": suspended,
            "is_verified": verified,
            "appeal_pending": pending,
            "account_status": status,
        }), 200

    @app.get("/api/age-verify/status")
    def api_age_verify_status():
        """Return whether the current user is 18+ verified."""
        from models import User
        username = (session.get("username") or "").strip()
        if not username:
            return jsonify({"age_verified": False, "logged_in": False}), 200
        user = User.query.filter_by(username=username).first()
        if not user:
            return jsonify({"age_verified": False, "logged_in": True}), 200
        verified = bool(getattr(user, "adult_verified", False)) and \
                   not bool(getattr(user, "adult_access_revoked", False))
        return jsonify({"age_verified": verified, "logged_in": True}), 200

    @app.post("/api/age-verify")
    def api_age_verify_submit():
        """Self-declared DOB age verification for feed adult content.

        Body: { "date_of_birth": "YYYY-MM-DD" }
        Requires the user to be 18+.  Sets adult_verified=True on success.
        This is self-declaration only â€” no ID document required for feed viewing.
        """
        from models import User
        from datetime import date, datetime as _dt

        username = (session.get("username") or "").strip()
        if not username:
            return jsonify({"ok": False, "error": "Login required"}), 401
        user = User.query.filter_by(username=username).first()
        if not user:
            return jsonify({"ok": False, "error": "User not found"}), 401

        # Already verified â€” nothing to do
        if bool(getattr(user, "adult_verified", False)) and \
           not bool(getattr(user, "adult_access_revoked", False)):
            return jsonify({"ok": True, "already_verified": True}), 200

        data = request.get_json(silent=True) or {}
        dob_str = str(data.get("date_of_birth") or "").strip()
        try:
            dob = _dt.strptime(dob_str, "%Y-%m-%d").date()
        except ValueError:
            return jsonify({"ok": False, "error": "Invalid date. Use YYYY-MM-DD format."}), 400

        today = date.today()
        age = today.year - dob.year - ((today.month, today.day) < (dob.month, dob.day))
        if age < 18:
            return jsonify({"ok": False, "error": "You must be 18 or older to view this content."}), 403

        try:
            user.adult_verified = True
            user.adult_verified_at = _dt.utcnow()
            user.adult_verification_provider = "self_declared"
            user.adult_verification_ref = "feed-dob-gate"
            if hasattr(user, "date_of_birth"):
                user.date_of_birth = dob
            db.session.commit()
        except Exception as e:
            db.session.rollback()
            current_app.logger.error(f"[age-verify] commit failed: {e}")
            return jsonify({"ok": False, "error": "Verification failed. Please try again."}), 500

        return jsonify({"ok": True, "age_verified": True}), 200

    # â”€â”€ Media access token â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    # Issued after PIN-check or direct reveal; lets the client fetch the
    # actual media URL without exposing it in the DOM before auth.

    @app.post("/api/media/token")
    def api_media_token():
        """Issue a short-lived signed token granting access to an adult post's media.

        Requires: viewer is adult_verified.
        A PIN-check (verify-pin) is done separately; the client calls this after
        a successful PIN verify (or for no-PIN posts, directly).
        """
        import secrets, time
        from models import Post, User

        username = (session.get("username") or "").strip()
        if not username:
            return jsonify({"ok": False, "error": "Login required"}), 401
        user = User.query.filter_by(username=username).first()
        if not user:
            return jsonify({"ok": False, "error": "User not found"}), 401

        if not bool(getattr(user, "adult_verified", False)):
            return jsonify({"ok": False, "error": "Age verification required", "code": "adult_required"}), 403

        data = request.get_json(silent=True) or {}
        post_id = int(data.get("post_id") or 0)
        if not post_id:
            return jsonify({"ok": False, "error": "post_id required"}), 400

        post = db.session.get(Post, post_id)
        if not post:
            return jsonify({"ok": False, "error": "Post not found"}), 404
        if not (getattr(post, "is_adult", False) or getattr(post, "needs_review", False)):
            return jsonify({"ok": False, "error": "Not an adult post"}), 400

        # Issue a one-time token stored in the session (expires in 5 minutes)
        token = secrets.token_urlsafe(32)
        _key = f"media_token_{token}"
        session[_key] = {"post_id": post_id, "expires": time.time() + 300}
        return jsonify({"ok": True, "token": token}), 200

    @app.get("/m/<token>")
    def media_token_view(token):
        """Serve the adult media for a valid token, then invalidate it."""
        import time
        from models import Post

        _key = f"media_token_{token}"
        tok = session.get(_key)
        if not tok:
            return "Invalid or expired media link.", 403
        if time.time() > tok.get("expires", 0):
            session.pop(_key, None)
            return "Media link expired.", 403

        post = db.session.get(Post, tok["post_id"])
        if not post or not getattr(post, "media_url", None):
            session.pop(_key, None)
            return "Media not found.", 404

        # Invalidate the token (one-time use)
        session.pop(_key, None)

        # Redirect to the actual static media URL
        from flask import redirect as _redir
        return _redir(post.media_url)

