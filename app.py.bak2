    @app.get("/api/messenger/thread")
    def api_messenger_thread():
        """Legacy endpoint — redirects to /api/dm/threads API."""
        try:
            with_user = request.args.get('with')
            if not with_user:
                return jsonify({"messages": []}), 200
            from models import User, Thread, ThreadMember, Message
            sender_username = (session.get('username') or '').strip()
            if not sender_username:
                return jsonify({"error": "Not authenticated"}), 401
            sender = User.query.filter_by(username=sender_username).first()
            recipient = User.query.filter_by(username=with_user).first()
            if not sender or not recipient:
                return jsonify({"messages": []}), 200
            # Find existing thread between these two users
            memberships = ThreadMember.query.filter_by(user_id=sender.id).all()
            thread_id = None
            for m in memberships:
                other = ThreadMember.query.filter(
                    ThreadMember.thread_id == m.thread_id,
                    ThreadMember.user_id == recipient.id
                ).first()
                if other:
                    thread_id = m.thread_id
                    break
            if not thread_id:
                return jsonify({"messages": []}), 200
            messages = Message.query.filter_by(thread_id=thread_id).order_by(Message.created_at.asc()).limit(100).all()
            result = []
            for msg in messages:
                s = User.query.get(msg.sender_id)
                result.append({
                    "id": msg.id,
                    "content": msg.content,
                    "sender": getattr(s, 'username', 'unknown'),
                    "sender_avatar": getattr(s, 'avatar_url', None),
                    "created_at": msg.created_at.isoformat() + 'Z' if msg.created_at else None,
                    "media_type": msg.media_type,
                    "media_url": msg.media_url,
                })
            return jsonify({"messages": result}), 200
        except Exception as e:
            return jsonify({"error": str(e)}), 500

    @app.post("/api/messenger/send")
    def api_messenger_send():
        """Legacy send endpoint — creates a thread if needed and saves the message."""
        try:
            data = request.get_json()
            recipient = (data.get('recipient') or '').strip()
            text = (data.get('text') or '').strip()
            if not recipient or not text:
                return jsonify({"error": "Missing recipient or text"}), 400
            from moderation_engine import scan_scam_score, moderate_text
            scam = scan_scam_score(text)
            if scam['decision'] == 'block':
                return jsonify({
                    "error": "Message blocked — scam detected by our AI safety system.",
                    "scam_scan": scam,
                }), 403
            mod = moderate_text(text)
            if mod.decision == 'block':
                return jsonify({
                    "error": f"Message blocked: {mod.reason}",
                    "moderation": {"decision": mod.decision, "reason": mod.reason},
                }), 403
            from models import User, Thread, ThreadMember, Message
            from datetime import datetime
            sender_username = (session.get('username') or '').strip()
            sender_user = User.query.filter_by(username=sender_username).first() if sender_username else None
            if not sender_user:
                return jsonify({"error": "Not authenticated"}), 401
            recipient_user = User.query.filter_by(username=recipient).first()
            if not recipient_user:
                return jsonify({"error": "Recipient not found"}), 404

            # Check if sender is banned
            if getattr(sender_user, 'is_banned', False):
                return jsonify({"error": "Your account has been banned."}), 403

            # ── Hard Block gate ────────────────────────────────────────────
            # If recipient has permanently blocked the sender, redirect to the
            # cracked-screen page instead of giving a generic error.
            from models import Block as _BlkModel
            _perm_blk = _BlkModel.query.filter_by(
                blocker_id=recipient_user.id,
                blocked_id=sender_user.id,
                is_active=True,
            ).first()
            if _perm_blk and not _perm_blk.is_expired and not _perm_blk.expires_at:
                return jsonify({
                    "error": "You have been blocked by this user.",
                    "code": "hard_blocked",
                    "redirect_url": f"/blocked-screen/{recipient_user.username}",
                }), 403
            # ──────────────────────────────────────────────────────────────
            # ──────────────────────────────────────────────────────────────

            # Stranger message gating
            delivery = "direct"
            from platform_rules import check_message_permission
            perm = check_message_permission(sender_user.id, recipient_user.id)
            delivery = perm["delivery"]

            # Strict filter
            filter_level = getattr(recipient_user, 'message_filter_level', 'standard')
            if filter_level == 'strict' and scam['score'] > 0.15:
                return jsonify({
                    "error": "This user has strict message filtering enabled.",
                    "scam_scan": scam,
                }), 403

            # Find or create thread
            thread_id = None
            memberships = ThreadMember.query.filter_by(user_id=sender_user.id).all()
            for m in memberships:
                other = ThreadMember.query.filter(
                    ThreadMember.thread_id == m.thread_id,
                    ThreadMember.user_id == recipient_user.id
                ).first()
                if other:
                    thread_id = m.thread_id
                    break
            if not thread_id:
                thread = Thread(is_encrypted=False)
                db.session.add(thread)
                db.session.flush()
                db.session.add(ThreadMember(thread_id=thread.id, user_id=sender_user.id))
                db.session.add(ThreadMember(thread_id=thread.id, user_id=recipient_user.id))
                thread_id = thread.id

            # Save the message
            thread = Thread.query.get(thread_id)
            msg = Message(
                thread_id=thread_id,
                sender_id=sender_user.id,
                content=text,
                is_encrypted=False,
                moderation_status='clean',
            )
            db.session.add(msg)
            thread.last_message_at = datetime.utcnow()
            member = ThreadMember.query.filter_by(thread_id=thread_id, user_id=sender_user.id).first()
            if member:
                member.last_read_at = datetime.utcnow()
            db.session.commit()

            return jsonify({
                "ok": True,
                "message_id": msg.id,
                "thread_id": thread_id,
                "delivery": delivery,
                "message_request": delivery == "request",
                "scam_warning": scam if scam['decision'] == 'warn' else None,
            }), 201
        except Exception as e:
            db.session.rollback()
            return jsonify({"error": str(e)}), 500

    @app.post("/messenger/send")
    def messenger_send():
        """Redirect POST to the API endpoint."""
        return redirect(url_for('api_messenger_send'), code=307)

    # ═══════════════════════════════════════════════════════
    #  Friends API Endpoints  (4-space indent = top of create_app)
