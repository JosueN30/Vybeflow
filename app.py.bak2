            "water": ["ðŸ’§", "ðŸŒŠ", "ðŸ’¦", "ðŸŠ", "ðŸ«§"],
            "sunset": ["ðŸŒ…", "ðŸŒ‡", "ðŸ§¡", "â˜€ï¸", "ðŸŒ¤ï¸"],
            "sunrise": ["ðŸŒ„", "â˜€ï¸", "ðŸŒ…", "âœ¨", "ðŸŒ¤ï¸"],
