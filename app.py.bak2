    # ── Global context processor: inject active_theme into EVERY template ──
    # This is the authoritative source-of-truth injection. Individual routes may
    # also pass active_theme= (that takes precedence). The context_processor
    # covers all routes that don't, e.g. messenger, games, circles, etc.
    @app.context_processor
    def _inject_active_theme():
        _uname = session.get('username')
        if not _uname:
            return {'active_theme': {}, 'current_user': None}
        try:
            import json as _j_cp
            from models import User as _UCp
            _u = _UCp.query.filter_by(username=_uname).first()
            if not _u:
                return {'active_theme': {}, 'current_user': None}
            _raw = getattr(_u, 'theme_colors', None)
            _tc = _j_cp.loads(_raw) if _raw else {}
            if not _tc:
                return {'active_theme': {}, 'current_user': _u}
            return {'active_theme': {
                '--bg':     _tc.get('bg',     '#0a0810'),
                '--brand1': _tc.get('brand1', '#ff9a3d'),
                '--brand2': _tc.get('brand2', '#ff6a00'),
                '--brand3': _tc.get('brand3', '#ff4800'),
                '--line':   _tc.get('line',   'rgba(255,173,117,.20)'),
            }, 'current_user': _u}
        except Exception:
            return {'active_theme': {}, 'current_user': None}

    # ── Onboarding: mark tour as complete ────────────────────────────────────
    @app.post("/api/onboarding/complete")
    def api_onboarding_complete():
        """Flip is_new_user → False and has_completed_onboarding → True
        after the first-time walkthrough is dismissed."""
        from models import User as _U
        _uname = (session.get('username') or '').strip()
        if not _uname:
            return jsonify({"error": "Not authenticated"}), 401
        try:
            _u = _U.query.filter_by(username=_uname).first()
            if _u:
                _u.is_new_user = False
                _u.has_completed_onboarding = True
                db.session.commit()
            return jsonify({"ok": True})
        except Exception as _e:
            db.session.rollback()
            return jsonify({"ok": False, "error": str(_e)}), 500

    # ── Digital Wellbeing API ─────────────────────────────────────────────────

    @app.post("/api/wellbeing/settings")
    def api_wellbeing_settings():
        """Save the user's digital-wellbeing preferences."""
        from models import User as _U
        _uname = (session.get('username') or '').strip()
        if not _uname:
            return jsonify({"error": "Not authenticated"}), 401
        _u = _U.query.filter_by(username=_uname).first()
        if not _u:
            return jsonify({"error": "User not found"}), 404
        try:
            data = request.get_json(silent=True) or {}
            # daily_usage_limit_mins: int (0 means disabled / None)
            raw_limit = data.get("daily_usage_limit_mins")
            if raw_limit is None or raw_limit == 0:
                _u.daily_usage_limit_mins = None
            else:
                limit = int(raw_limit)
                if limit < 0 or limit > 1440:
                    return jsonify({"error": "Invalid limit"}), 400
                _u.daily_usage_limit_mins = limit
            # wellbeing_break_reminder: bool
            if "wellbeing_break_reminder" in data:
                _u.wellbeing_break_reminder = bool(data["wellbeing_break_reminder"])
            db.session.commit()
            return jsonify({"ok": True})
        except Exception as _e:
            db.session.rollback()
            current_app.logger.error(f"wellbeing/settings error: {_e}")
            return jsonify({"ok": False, "error": str(_e)}), 500

    @app.get("/api/wellbeing/settings")
    def api_wellbeing_settings_get():
        """Return the current user's digital-wellbeing preferences."""
        from models import User as _U
        _uname = (session.get('username') or '').strip()
        if not _uname:
            return jsonify({"error": "Not authenticated"}), 401
        _u = _U.query.filter_by(username=_uname).first()
        if not _u:
            return jsonify({"error": "User not found"}), 404
        return jsonify({
            "daily_usage_limit_mins": getattr(_u, "daily_usage_limit_mins", None),
            "wellbeing_break_reminder": bool(getattr(_u, "wellbeing_break_reminder", True)),
        })

    # ── Pro Verification: user applies, admin approves ───────────────────────
    @app.post("/api/pro/apply")
    def api_pro_apply():
        """
        User submits a Professional verification application.
        Creates a VybePulse notification to admin(s) for review.
        """
        from models import User as _U
        _uname = (session.get('username') or '').strip()
        if not _uname:
            return jsonify({"error": "Not authenticated"}), 401
        _u = _U.query.filter_by(username=_uname).first()
        if not _u:
            return jsonify({"error": "User not found"}), 404
        if getattr(_u, 'account_type', 'regular') != 'professional':
            return jsonify({"error": "Switch to a Professional account first"}), 400
        if getattr(_u, 'professional_verified', False):
            return jsonify({"ok": True, "message": "Already verified"}), 200

        # Notify all admins via Vybe Pulse
        try:
            from routes.notifications import create_pulse
            _admins = _U.query.filter_by(is_admin=True).all()
            for _admin in _admins:
                create_pulse(
                    recipient_id=_admin.id,
                    actor_id=_u.id,
                    pulse_type="pro_apply",
                    message=f"@{_u.username} applied for PRO badge verification",
                    emoji="⭐",
                    push=True,
                )
        except Exception:
            pass

        return jsonify({"ok": True, "message": "Application submitted! Admins have been notified."}), 200

    @app.post("/api/admin/pro/verify")
    def api_admin_pro_verify():
        """Admin: grant or revoke the Certified PRO badge for a user."""
        from models import User as _U
        _uname = (session.get('username') or '').strip()
        if not _uname:
            return jsonify({"error": "Not authenticated"}), 401
        _me = _U.query.filter_by(username=_uname).first()
        if not _me or not getattr(_me, 'is_admin', False):
            return jsonify({"error": "Admin access required"}), 403
        data = request.get_json(silent=True) or {}
        target_username = (data.get('username') or '').strip()
        action = (data.get('action') or 'grant').strip()  # 'grant' | 'revoke'
        if not target_username:
            return jsonify({"error": "username required"}), 400
        _target = _U.query.filter_by(username=target_username).first()
        if not _target:
            return jsonify({"error": "User not found"}), 404
        try:
            _target.professional_verified = (action == 'grant')
            if action == 'grant':
                _target.account_type = 'professional'
            db.session.commit()
            # Notify the user
            try:
                from routes.notifications import create_pulse
                _msg = (f"🎉 You've been granted the Certified PRO badge!"
                        if action == 'grant'
                        else "Your PRO badge has been revoked.")
                create_pulse(
                    recipient_id=_target.id,
                    actor_id=_me.id,
                    pulse_type="pro_badge",
                    message=_msg,
                    emoji="⭐" if action == 'grant' else "❌",
                    push=True,
                )
            except Exception:
                pass
            return jsonify({"ok": True, "verified": _target.professional_verified}), 200
        except Exception as _e:
            db.session.rollback()
            return jsonify({"error": str(_e)}), 500

    return app, socketio

def _media_type_from_filename(filename: str) -> str:
    from story_routes import ALLOWED_VIDEO_EXT as _VID_EXT
    ext = filename.rsplit(".", 1)[1].lower() if "." in filename else ""
    return "video" if ext in _VID_EXT else "image"

def _allowed_file(filename: str) -> bool:
    """Validate upload extension for images/videos using story_routes' allowlist."""
    from story_routes import ALLOWED_IMAGE_EXT as _IMG_EXT, ALLOWED_VIDEO_EXT as _VID_EXT
    if not filename or "." not in filename:
        return False
    ext = filename.rsplit(".", 1)[1].lower()
    return ext in _IMG_EXT or ext in _VID_EXT

def _save_upload(file_storage):
    original = secure_filename(file_storage.filename or "")
    if not original or not _allowed_file(original):
        raise ValueError("Unsupported file type.")

    ext = original.rsplit(".", 1)[1].lower()
    unique = f"{uuid.uuid4().hex}.{ext}"
    disk_path = os.path.join(current_app.config["POST_UPLOAD_ABS"], unique)
    file_storage.save(disk_path)

    # If video, defer heavy processing to speed up post creation
    poster_url = None
    video_job = None
    from story_routes import ALLOWED_VIDEO_EXT as _VID_EXT
    if ext in _VID_EXT:
        mp4_name = f"{uuid.uuid4().hex}.mp4"
        mp4_path = os.path.join(current_app.config["POST_UPLOAD_ABS"], mp4_name)
        try:
            # Defer transcode/poster for faster post creation
            video_job = {
                "disk_path": disk_path,
                "ext": ext,
                "mp4_path": mp4_path,
                "mp4_name": mp4_name,
                "needs_transcode": ext != "mp4",
            }
        except Exception as e:
            current_app.logger.warning(f"ffmpeg transcode/thumbnail failed: {e}")
            # fallback: serve original

    public_url = current_app.config["UPLOAD_URL_PREFIX"] + unique
    return (public_url, _media_type_from_filename(original), poster_url, video_job)

def _save_audio_upload(file_storage):
    original = secure_filename(file_storage.filename or "")
    if not original or "." not in original:
        raise ValueError("Unsupported audio type.")

    ext = original.rsplit(".", 1)[1].lower()
    # Basic audio allowlist for voice notes / clips
    allowed = {"mp3", "m4a", "aac", "wav", "ogg", "webm"}
    if ext not in allowed:
        raise ValueError("Unsupported audio type.")
    unique = f"voice/{uuid.uuid4().hex}.{ext}"
    disk_path = os.path.join(current_app.config["POST_UPLOAD_ABS"], unique)
    os.makedirs(os.path.dirname(disk_path), exist_ok=True)
    file_storage.save(disk_path)
    return current_app.config["UPLOAD_URL_PREFIX"] + unique

# Create app instance for WSGI compatibility (skipped when running under pytest)
import sys as _sys
if 'pytest' not in _sys.modules:
    app, socketio = create_app()

# Ensure 'app' is available at top-level for WSGI
__all__ = ['app']

if __name__ == '__main__':
    # Run with SocketIO support on localhost
    print('\n' + '='*60)
    print('VybeFlow Server Starting...')
    print('='*60)
    print('Server running at: http://127.0.0.1:5000')
    print('Access from browser: http://127.0.0.1:5000')
    print('Press CTRL+C to stop the server')
    print('='*60 + '\n')
    try:
        socketio.run(app, host='127.0.0.1', port=5000, debug=True, allow_unsafe_werkzeug=True)
    except KeyboardInterrupt:
        print('\nVybeFlow server stopped gracefully')
    except Exception as e:
        print(f'\nServer error: {e}')
        raise
