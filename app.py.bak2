            "fake_account_warnings": getattr(user, 'fake_account_warnings', 0),
            "max_warnings": 3,
            "warnings_remaining": max(0, 3 - (getattr(user, 'fake_account_warnings', 0) or 0)),
            "warning_history": reasons,
            "trust_score": getattr(user, 'trust_score', 50),
        }), 200

