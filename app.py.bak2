    @app.route("/blocked-scammer", methods=["GET"])
    def blocked_scammer():
        """Scam hard-ban stamp page â€” shown to users banned by the DM scam filter.
        Clears their session and IP-flags them if not already flagged."""
        from datetime import datetime as _dt
        _ip = request.headers.get("X-Forwarded-For", request.remote_addr or "")
        _ip_clean = _ip.split(",")[0].strip()
        if _ip_clean:
            try:
                from models import BlacklistedIP
                if not BlacklistedIP.is_blocked(_ip_clean):
                    BlacklistedIP.add(
                        ip=_ip_clean,
                        reason="scam_ban:page_visit",
                    )
            except Exception:
                _swallow_exc("blacklist scam_ban ip", level="warning")
        session.clear()
        return render_template("blocked_bitch.html", now=_dt.utcnow())

    @app.route("/forgot_password", methods=["GET", "POST"])
    def forgot_password():
        from email_utils import generate_reset_token, send_reset_email
        if request.method == "POST":
            identifier = (request.form.get('email') or request.form.get('username') or '').strip()

            if not identifier:
                flash("Enter your username or email.", "error")
                return redirect(url_for('forgot_password'))

            from models import User
            user = User.query.filter_by(username=identifier).first()
            if not user:
                user = User.query.filter_by(email=identifier).first()

            if user and user.email:
                token = generate_reset_token(user.email)
                # Build reset URL using the actual host the user is browsing from
                reset_url = request.host_url.rstrip('/') + f"/reset_password/{token}"

                # Always try to send email (even for @VybeFlow.local, show on-screen too)
                if _is_real_email(user.email):
                    import threading
                    def _send_bg(addr, url):
                        try:
                            sent = send_reset_email(addr, url)
                            if sent:
                                print(f"[VybeFlow RESET] Email sent to {addr}")
                        except Exception as e:
                            print(f"[VybeFlow RESET] Email send error: {e}")
                    threading.Thread(target=_send_bg, args=(user.email, reset_url), daemon=True).start()

                # Always show the reset link on page as immediate fallback
                print(f"[VybeFlow RESET] Showing reset link on-screen for user={user.username!r}")
                has_real_email = _is_real_email(user.email)
                if has_real_email:
                    flash("A reset link has been sent to your email. You can also use the button below:", "success")
                else:
                    flash("Click the button below to reset your password:", "success")
                return render_template("forgot_password.html", email_sent=True, reset_link=reset_url, has_real_email=has_real_email)

            # User not found â€” generic message to prevent enumeration
            flash("If an account with that username or email exists, a password reset link has been sent.", "success")
            return render_template("forgot_password.html", email_sent=True)

        tmpl = os.path.join(app.root_path, "templates", "forgot_password.html")
        return render_template("forgot_password.html") if os.path.exists(tmpl) else redirect(url_for("login"))

    @app.route("/reset_password/<token>", methods=["GET", "POST"])
    def reset_password(token):
        """Password reset via secure time-limited token."""
        from email_utils import verify_reset_token
        from models import User

        email = verify_reset_token(token)
        if not email:
            flash("This reset link is invalid or has expired. Please request a new one.", "error")
            return redirect(url_for("forgot_password"))

        user = User.query.filter_by(email=email).first()
        if not user:
            flash("Account not found. Please request a new reset link.", "error")
            return redirect(url_for("forgot_password"))

        if request.method == "POST":
            password = (request.form.get('password') or '').strip()
            confirm_password = (request.form.get('confirm_password') or '').strip()

            if not password or len(password) < 6:
                flash("Password must be at least 6 characters.", "error")
                return render_template("reset_password.html", token=token)
            if password != confirm_password:
                flash("Passwords do not match.", "error")
                return render_template("reset_password.html", token=token)

            user.password_hash = generate_password_hash(password, method='pbkdf2:sha256:260000')
            try:
                db.session.commit()
                flash("Password reset successfully! You can now log in.", "success")
                return redirect(url_for('login'))
            except Exception as _e:
                db.session.rollback()
                print(f"[VybeFlow RESET] db commit failed: {_e}")
                flash("An error occurred saving your password. Please try again.", "error")
                return render_template("reset_password.html", token=token)

        return render_template("reset_password.html", token=token)

    @app.route("/search", methods=["GET", "POST"])
    def search():
        """Explore/search page used by the topbar and "Your Vybes" chips."""
        from models import User, Post, Story

        # Pull query from either form or querystring
        q = (request.values.get("query") or request.args.get("q") or "").strip()

        if request.method == "POST":
            # Redirect POSTs to a clean GET URL so refresh works
            if not q:
                return redirect(url_for("search"))
            return redirect(url_for("search", q=q))

        # No query yet -> render the simple search landing page
        if not q:
            return render_template("search.html")

        # Build lightweight results payload expected by search_results.html
        users = []
        posts = []
        stories = []

        try:
            from models import ShieldMode, Block
            from sqlalchemy import or_
            # Build block exclusion set for the searching user
            _searcher_blocked_ids: set = set()
            _searcher_id = None
            try:
                _s_uname = (session.get("username") or "").strip()
                if _s_uname:
                    _s_user = User.query.filter_by(username=_s_uname).first()
                    if _s_user:
                        _searcher_id = _s_user.id
                        _bb = Block.query.filter_by(blocker_id=_searcher_id, is_active=True).with_entities(Block.blocked_id).all()
                        _searcher_blocked_ids.update(r[0] for r in _bb)
                        _bo = Block.query.filter_by(blocked_id=_searcher_id, is_active=True).with_entities(Block.blocker_id).all()
                        _searcher_blocked_ids.update(r[0] for r in _bo)
            except Exception:
                pass
            # Also search with spaces removed so "vibe team" matches "Thevibeteam"
            q_ns = q.replace(" ", "")
            conditions = [
                User.username.ilike(f"%{q}%"),
                User.display_name.ilike(f"%{q}%"),
            ]
            if q_ns != q:
                conditions.extend([
                    User.username.ilike(f"%{q_ns}%"),
                    User.display_name.ilike(f"%{q_ns}%"),
                ])
            user_rows = (
                User.query
                .filter(or_(*conditions))
                .limit(40)
                .all()
            ) if User is not None else []
            # Filter out hidden / banned / blocked / shielded users
            for u in user_rows:
                if getattr(u, 'is_banned', False) or getattr(u, 'is_suspended', False):
                    continue
                if u.id in _searcher_blocked_ids:
                    continue
                if getattr(u, 'hidden_profile', False):
                    continue
                if getattr(u, 'profile_visibility', 'public') == 'hidden':
                    continue
                shield = ShieldMode.query.filter_by(user_id=u.id, is_active=True).first()
                if shield and not shield.is_expired and shield.hide_from_search:
                    continue
                users.append(u)
                if len(users) >= 12:
                    break
        except Exception:
            users = []

        try:
            post_rows = (
                Post.query
                .filter(Post.caption.ilike(f"%{q}%"))
                .order_by(Post.id.desc())
                .limit(20)
                .all()
            ) if Post is not None else []
            posts = [p.caption or "(no caption)" for p in post_rows]
        except Exception:
            posts = []

        try:
            story_rows = (
                Story.query
                .filter(
                    Story.caption.ilike(f"%{q}%"),
                    Story.expires_at > datetime.now(timezone.utc) if hasattr(Story, "expires_at") else True,
                )
                .order_by(Story.id.desc())
                .limit(20)
                .all()
            ) if Story is not None else []
            for s in story_rows:
                stories.append({
                    "title": getattr(s, "caption", "") or "Story",
                    "username": getattr(getattr(s, "author", None), "username", None)
                                 or getattr(getattr(s, "user", None), "username", None)
                                 or "user",
                    "location": getattr(s, "location", None) or "",
                    "mentions": [],
                    "music_track": getattr(s, "music_track", None) or "",
                    "effects": [],
                    "graphics": [],
                })
        except Exception:
            stories = []

        results = {
            "users": users,
            "topics": [],
            "posts": posts,
            "stories": stories,
            "gifs": [],
            "curse_terms": [],
        }

        current_username = (session.get("username") or "").lower()

        # Build real friend usernames list
        friend_usernames = []
        pending_usernames = []
        try:
            from models import FriendRequest
            me = User.query.filter(User.username.ilike(current_username)).first() if current_username else None
            if me:
                # Accepted = friends
                for fr in FriendRequest.query.filter_by(sender_id=me.id, status='accepted').all():
                    u = db.session.get(User, fr.receiver_id)
                    if u: friend_usernames.append(u.username.lower())
                for fr in FriendRequest.query.filter_by(receiver_id=me.id, status='accepted').all():
                    u = db.session.get(User, fr.sender_id)
                    if u: friend_usernames.append(u.username.lower())
                # Pending sent = awaiting response
                for fr in FriendRequest.query.filter_by(sender_id=me.id, status='pending').all():
                    u = db.session.get(User, fr.receiver_id)
                    if u: pending_usernames.append(u.username.lower())
        except Exception:
            pass

        # Build set of usernames the current user has blocked (for BLOCKED badge)
        blocked_usernames: list[str] = []
        try:
            from models import Block
            me2 = User.query.filter(User.username.ilike(current_username)).first() if current_username else None
            if me2:
                for b in Block.query.filter_by(blocker_id=me2.id, is_active=True).all():
                    bu = db.session.get(User, b.blocked_id)
                    if bu:
                        blocked_usernames.append(bu.username.lower())
        except Exception:
            pass

        return render_template(
            "search_results.html",
            query=q,
            results=results,
            friend_usernames=friend_usernames,
            pending_usernames=pending_usernames,
            current_username=current_username,
            blocked_usernames=blocked_usernames,
        )

    @app.get("/api/search/users")
    def api_search_users():
        """Live typeahead: returns matching users as JSON.
        Friends/follows always appear regardless of profile visibility settings.
        """
        from models import User, ShieldMode, Follow, Block
        from sqlalchemy import or_
        q = (request.args.get("q") or "").strip()

        # Build set of user IDs the current user follows so they always appear
        me_id = None
        follow_ids: set = set()
        # IDs of users who have blocked the viewer OR the viewer has blocked â€” always hidden
        blocked_ids: set = set()
        try:
            _me_username = session.get("username")
            if _me_username:
                _me = User.query.filter_by(username=_me_username).first()
                if _me:
                    me_id = _me.id
                    # IDs of people this user follows
                    _fwd = Follow.query.filter_by(follower_id=me_id).with_entities(Follow.following_id).all()
                    follow_ids = {r[0] for r in _fwd}
                    # Also include people who follow the current user (mutual visibility)
                    _rev = Follow.query.filter_by(following_id=me_id).with_entities(Follow.follower_id).all()
                    follow_ids.update(r[0] for r in _rev)
                    # Build bidirectional block exclusion set
                    _b_by_me = Block.query.filter_by(blocker_id=me_id, is_active=True).with_entities(Block.blocked_id).all()
                    blocked_ids.update(r[0] for r in _b_by_me)
                    _b_of_me = Block.query.filter_by(blocked_id=me_id, is_active=True).with_entities(Block.blocker_id).all()
                    blocked_ids.update(r[0] for r in _b_of_me)
                    # Remove expired blocks from the exclusion set
                    expired = Block.query.filter(
                        Block.is_active == True,
                        Block.expires_at != None,
                        Block.expires_at < __import__('datetime').datetime.now(timezone.utc)
                    ).all()
                    for _b in expired:
                        _b.is_active = False
                        blocked_ids.discard(_b.blocked_id)
                        blocked_ids.discard(_b.blocker_id)
                    if expired:
                        db.session.commit()
        except Exception:
            _swallow_exc("search block-expiry commit")

        _DEFAULT_BIOS = {
            "vybeflow member âœ¨", "vybeflow member.", "vybeflow member",
        }

        def _is_visible(u):
            """Return True if this user should appear in search results."""
            if getattr(u, 'is_banned', False) or getattr(u, 'is_suspended', False):
                return False
            # Never surface users involved in an active block (either direction)
            if u.id in blocked_ids:
                return False
            # Hide internal/test accounts (usernames prefixed with _)
            if (u.username or "").startswith("_"):
                return False
            # Follows/followers always visible regardless of privacy
            if u.id in follow_ids:
                return True
            if getattr(u, 'hidden_profile', False):
                return False
            if getattr(u, 'profile_visibility', 'public') == 'hidden':
                return False
            return True

        def _build_result(u):
            # Guard every field against None so the JSON is always valid
            uname = u.username or ""
            # Strip the generic default bio â€” only show real user-written bios
            raw_bio = (u.bio or "").strip()
            bio_out = "" if raw_bio.lower() in _DEFAULT_BIOS else raw_bio[:120]
            return {
                "id": u.id,
                "username": uname,
                "display_name": u.display_name or uname,
                "avatar_url": u.avatar_url or "",
                "bio": bio_out,
                "pro": u.account_type == "professional",
                "following": u.id in follow_ids,
            }

        if not q:
            # Return suggestions when search box is empty/focused.
            # Prioritise people the current user follows.
            try:
                suggestions = []
                # Follows first (up to 8)
                if follow_ids:
                    follow_users = User.query.filter(User.id.in_(follow_ids)).order_by(User.username).limit(20).all()
                    for u in follow_users:
                        if getattr(u, 'is_banned', False) or getattr(u, 'is_suspended', False):
                            continue
                        if u.id in blocked_ids:
                            continue
                        suggestions.append(_build_result(u))
                        if len(suggestions) >= 8:
                            break
                # Fill remaining slots with public users
                if len(suggestions) < 8:
                    rows = User.query.order_by(User.username).limit(30).all()
                    for u in rows:
                        if len(suggestions) >= 8:
                            break
                        if u.id in follow_ids:
                            continue  # already added
                        if not _is_visible(u):
                            continue
                        suggestions.append(_build_result(u))
                return jsonify(suggestions)
            except Exception:
                return jsonify([])

        try:
            # Also search with spaces removed so "vibe team" matches "Thevibeteam"
            q_no_spaces = q.replace(" ", "")
            conditions = [
                User.username.ilike(f"{q}%"),
                User.display_name.ilike(f"{q}%"),
                User.username.ilike(f"%{q}%"),
                User.display_name.ilike(f"%{q}%"),
                User.bio.ilike(f"%{q}%"),
                User.email.ilike(f"{q}%"),
                User.email.ilike(f"%{q}%"),
            ]
            if q_no_spaces != q:
                conditions.extend([
                    User.username.ilike(f"{q_no_spaces}%"),
                    User.display_name.ilike(f"{q_no_spaces}%"),
                    User.username.ilike(f"%{q_no_spaces}%"),
                    User.display_name.ilike(f"%{q_no_spaces}%"),
                ])
            user_rows = (
                User.query
                .filter(or_(*conditions))
                .limit(60)
                .all()
            )
            # Follows/friends first, then prefix matches, then substring
            friends_prefix = []
            friends_sub = []
            prefix = []
            substring = []
            for u in user_rows:
                if getattr(u, 'is_banned', False) or getattr(u, 'is_suspended', False):
                    continue
                if u.id not in follow_ids:
                    if getattr(u, 'hidden_profile', False):
                        continue
                    if getattr(u, 'profile_visibility', 'public') == 'hidden':
                        continue
                    shield = ShieldMode.query.filter_by(user_id=u.id, is_active=True).first()
                    if shield and not getattr(shield, 'is_expired', False) and getattr(shield, 'hide_from_search', False):
                        continue
                uname_l = (u.username or "").lower()
                dname_l = (u.display_name or "").lower()
                ql = q.lower()
                is_prefix = uname_l.startswith(ql) or dname_l.startswith(ql)
                if u.id in follow_ids:
                    (friends_prefix if is_prefix else friends_sub).append(u)
                else:
                    (prefix if is_prefix else substring).append(u)
            results = (friends_prefix + friends_sub + prefix + substring)[:15]
            return jsonify([_build_result(u) for u in results])
        except Exception as e:
            print(f'[Search] Error: {e}')
            return jsonify([])

    @app.get("/api/users/by-id/<int:user_id>")
    def api_user_by_id(user_id):
        """Minimal public user card for id-based DM deep links."""
        try:
            from models import User, Block
            u = db.session.get(User, user_id)
            if not u or getattr(u, 'is_banned', False) or getattr(u, 'is_suspended', False):
                return jsonify({"error": "User not found"}), 404

            # Respect hidden profile settings for anonymous/public lookups.
            if getattr(u, 'hidden_profile', False) or getattr(u, 'profile_visibility', 'public') == 'hidden':
                return jsonify({"error": "User not found"}), 404

            viewer_username = session.get("username")
            if viewer_username:
                viewer = User.query.filter_by(username=viewer_username).first()
                if viewer:
                    blocked = Block.query.filter(
                        Block.is_active == True,
                        ((Block.blocker_id == viewer.id) & (Block.blocked_id == u.id)) |
                        ((Block.blocker_id == u.id) & (Block.blocked_id == viewer.id))
                    ).first()
                    if blocked:
                        return jsonify({"error": "User not found"}), 404

            return jsonify({
                "id": u.id,
                "username": u.username or "",
                "display_name": (u.display_name or u.username or ""),
                "avatar_url": u.avatar_url or "",
            }), 200
        except Exception:
            return jsonify({"error": "User not found"}), 404

