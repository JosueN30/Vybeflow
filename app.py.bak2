    @app.patch("/api/posts/<int:post_id>")
    def api_posts_edit(post_id):
        """Edit a post by ID."""
        try:
            from models import Post, User
            from __init__ import db

            current_username = (session.get('username') or '').strip()
            if not current_username:
                return jsonify({"error": "Not signed in"}), 401

            post = db.session.get(Post, post_id)
            if not post:
                return jsonify({"error": "Post not found"}), 404

            owner = User.query.filter_by(username=current_username).first()
            if not owner or post.author_id != owner.id:
                return jsonify({"error": "Not allowed"}), 403

            data = request.get_json() if request.is_json else request.form

            if 'caption' in data:
                post.caption = data['caption']
            if 'bg_style' in data:
                post.bg_style = data['bg_style']
            if 'bg_color' in data:
                import re as _re_bgpatch
                _raw_bgc = (data.get('bg_color') or '').strip()[:20]
                post.bg_color = _raw_bgc if (_raw_bgc and _re_bgpatch.match(r'^#[0-9a-fA-F]{3}(?:[0-9a-fA-F]{3})?$', _raw_bgc)) else None
            if 'visibility' in data:
                post.visibility = data['visibility']

            try:
                db.session.commit()
            except Exception as _ce:
                db.session.rollback()
                return jsonify({"error": "Database error"}), 500

            return jsonify({"success": True, "post": {
                "id": post.id,
                "caption": post.caption,
                "bg_style": getattr(post, 'bg_style', 'default'),
                "bg_color": getattr(post, 'bg_color', None),
                "visibility": post.visibility
            }}), 200
        except Exception as e:
            print(f"Error editing post {post_id}: {e}")
            return jsonify({"error": str(e)}), 400

    @app.delete("/api/posts/<int:post_id>")
    def api_posts_delete_by_id(post_id):
        """Permanently delete a post by ID (REST style)."""
        try:
            from models import Post, User, Comment
            from __init__ import db

