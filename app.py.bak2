    # â”€â”€ Auto-Lift Daemon: lifts expired UserRestriction + muted_until every 60s â”€â”€
    # Only temporary blocks (1h/1d/1w) expire here â€” permanent/shadowban never auto-clear.
    def _block_expiry_daemon():
        import time as _time
        import threading as _threading

        def _run_loop():
            while True:
                _time.sleep(60)
                try:
                    with app.app_context():
                        from datetime import datetime as _dt_now
                        from models import User
                        from models_moderation import UserRestriction

                        _now = _dt_now.utcnow()
                        _lifted = []

                        # --- Check UserRestriction.restricted_until ---
                        expired_restrictions = UserRestriction.query.filter(
                            UserRestriction.restricted_until != None,
                            UserRestriction.restricted_until <= _now,
                        ).all()
                        for _r in expired_restrictions:
                            _r.restricted_until = None
                            _r.can_post_after = None
                            _r.can_comment_after = None
                            _r.last_message_at = None
                            db.session.flush()
                            _lifted.append(("restriction", _r.user_id))

                        # --- Check User.muted_until ---
                        expired_mutes = User.query.filter(
                            User.muted_until != None,
                            User.muted_until <= _now,
                        ).all()
                        for _u in expired_mutes:
                            _u.muted_until = None
                            db.session.flush()
                            _lifted.append(("mute", _u.id))

                        # --- Clear expired timed Block records (is_restricted â†’ False) ---
                        # This is the exact-second auto-lift: when the timer hits zero,
                        # is_active becomes False so they can chat freely again.
                        try:
                            from models import Block as _Block
                            expired_blocks = _Block.query.filter(
                                _Block.expires_at != None,
                                _Block.expires_at <= _now,
                                _Block.is_active == True,
                            ).all()
                            for _b in expired_blocks:
                                _b.is_active = False
                                db.session.flush()
                                _lifted.append(("block_lifted", _b.blocker_id))
                        except Exception as _be:
                            print(f"[AutoLift] block sweep error: {_be}")

                        if _lifted:
                            db.session.commit()

                        # Always release the DB connection back to the pool
                        db.session.remove()

                        # --- Emit vibe_restored to each affected user ---
                        for (_kind, _uid) in _lifted:
                            try:
                                _target = db.session.get(User, _uid)
                                if not _target:
                                    continue
                                _theme = getattr(_target, 'theme', 'default') or 'default'
                                _theme_colors = {
                                    'default':  '#ff993a',
                                    'sunset':   '#ff7c4d',
                                    'neon':     '#00f5ff',
                                    'ocean':    '#1e90ff',
                                    'forest':   '#3ecf8e',
                                    'galaxy':   '#c084fc',
                                    'candy':    '#ff6ec7',
                                    'midnight': '#334155',
                                    'rose':     '#fda4af',
                                    'gold':     '#d4a000',
                                    'lava':     '#ff4500',
                                    'mono':     '#ffffff',
                                }
                                _color = _theme_colors.get(_theme, '#ff993a')
                                socketio.emit('vibe_restored', {
                                    'message': "âœ… Your Vibe is Restored â€” you're back in the mix!",
                                    'theme_color': _color,
                                    'theme': _theme,
                                    'kind': _kind,
                                }, room=f'user:{_uid}')
                                print(f"[AutoLift] Lifted {_kind} for {_target.username}, notified via WS")
                            except Exception as _ne:
                                print(f"[AutoLift] Notify error for uid={_uid}: {_ne}")

                except Exception as _e:
                    print(f"[AutoLift] daemon error: {_e}")

        _t = _threading.Thread(target=_run_loop, daemon=True, name="VybeBlockAutoLift")
        _t.start()
        print("[VybeFlow] Auto-lift daemon started (checks every 60s)")

    # Only run in the main/parent process, not the Werkzeug reloader child.
    # Never start this background daemon in test mode: test databases are often
    # partial (in-memory) and may not include moderation tables such as
    # user_restriction, which causes noisy thread errors and non-zero exits.
    import os as _os_autolift
    if (not app.config.get("TESTING")) and (not _os_autolift.environ.get('WERKZEUG_RUN_MAIN')):
        _block_expiry_daemon()

    # â”€â”€ Reusable strike helper: 1 strike per hateful/profane/toxic content â”€â”€
    def _apply_strike(user, mod_reason, content_type="post"):
        """Add 1 strike for hateful/profane content. At 3 strikes â†’ BANNED.
        Returns (response_json, status_code) or None if user can continue."""
        current_warnings = getattr(user, 'negativity_warnings', None)
        if current_warnings is None:
            current_warnings = 0
        current_warnings = int(current_warnings) + 1
        try:
            user.negativity_warnings = current_warnings
            db.session.commit()
        except Exception:
            db.session.rollback()
            # Re-read to stay consistent if commit failed
            current_warnings = getattr(user, 'negativity_warnings', current_warnings) or current_warnings

        _guideline_labels = {
            'scam_detected': 'No Scams or Fraud',
            'hate_speech_slur': 'No Hate Speech or Slurs',
            'threat_or_self_harm_encouragement': 'No Threats or Self-Harm Encouragement',
            'possible_doxxing': 'No Sharing of Personal Information (Doxxing)',
            'spam_detected': 'No Spam or Repetitive Content',
            'negative_content': 'Be Kind & Respectful',
            'mild_negativity': 'Be Kind & Respectful',
            'high_toxicity_borderline': 'No Toxic or Abusive Language',
        }
        _violated = _guideline_labels.get(mod_reason, 'Be Kind & Respectful')

        if current_warnings >= 3:
            user.is_banned = True
            user.ban_reason = f"BANNED: 3 strikes for {_violated}"
            user.is_suspended = True
            user.suspension_reason = f"BANNED: 3 strikes â€” {mod_reason}"
            try:
                from datetime import datetime as _dt
                user.banned_at = _dt.utcnow()
                db.session.commit()
            except Exception:
                db.session.rollback()
            print(f"[VybeFlow BAN] {user.username} BANNED after 3 strikes (reason: {mod_reason})")
            return jsonify({
                "ok": False,
                "error": "You have been BANNED. 3 strikes for hateful or abusive content. You may submit an appeal.",
                "banned": True,
                "suspended": True,
                "appeal_available": True,
                "moderation": {"decision": "banned", "reason": mod_reason, "strikes": current_warnings}
            }), 403

        print(f"[VybeFlow STRIKE] {user.username} got strike {current_warnings}/3 (reason: {mod_reason})")
        return jsonify({
            "ok": False,
            "auto_deleted": True,
            "warning": {
                "warning_number": current_warnings,
                "warnings_remaining": 3 - current_warnings,
                "reason": mod_reason,
                "guideline": _violated,
                "message": f"\u26a0\ufe0f Strike {current_warnings}/3: Your {content_type} was automatically removed for violating: {_violated}. You have {3 - current_warnings} strike(s) remaining before you are BANNED."
            }
        }), 403

    # Home, auth, and Explore / search
    @app.get("/favicon.ico")
    def favicon():
        return send_from_directory(
            os.path.join(app.root_path, "static"),
            "favicon.ico", mimetype="image/vnd.microsoft.icon"
        )

    @app.get("/")
    def home():
        # Avoid an extra redirect hop for anonymous users.
        if session.get("logged_in") and session.get("username"):
            return redirect(url_for("feed.feed_page"))
        return redirect(url_for("login"))

    @app.route("/login", methods=["GET", "POST"])
    def login():
        # â”€â”€ Rate limiting via Flask-Limiter â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
        _lim = getattr(current_app, '_vybeflow_limiter', None)
        if _lim:
            try:
                from flask_limiter.errors import RateLimitExceeded as _RLE
            except ImportError:
                _RLE = None
        if request.method == "POST":
            # â”€â”€ 2FA continuation: user already passed password check â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            _pending_2fa_user = session.get('_2fa_pending_user')
            _totp_input = request.form.get('totp_code', '').strip()
            if _pending_2fa_user and _totp_input and not request.form.get('password'):
                from models import User as _U2FA
                _u2fa = _U2FA.query.filter_by(username=_pending_2fa_user).first()
                if _u2fa and getattr(_u2fa, 'totp_secret', None):
                    try:
                        import pyotp as _pyotp2fa
                        if _pyotp2fa.TOTP(_u2fa.totp_secret).verify(_totp_input, valid_window=1):
                            session.pop('_2fa_pending_user', None)
                            session.permanent = True
                            session['username'] = _u2fa.username
                            session['display_name'] = _u2fa.display_name or _u2fa.username
                            session['user_id'] = _u2fa.id
                            session['avatar_url'] = _u2fa.avatar_url or ''
                            session['logged_in'] = True
                            return redirect(url_for('feed.feed_page'))
                        else:
                            flash('Invalid 2FA code. Please try again.', 'error')
                            return render_template('login_2fa.html', username=_pending_2fa_user)
                    except Exception as _2fa_ex:
                        flash('2FA verification failed. Please log in again.', 'error')
                        session.pop('_2fa_pending_user', None)
                        return redirect(url_for('login'))
                else:
                    session.pop('_2fa_pending_user', None)
                    return redirect(url_for('login'))
            # â”€â”€ Normal login flow â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            username = request.form.get("username", "").strip()
            password = request.form.get("password", "")
            if not username:
                flash("Please enter your username or email address.", "error")
                return render_template("login.html")
            if not password:
                flash("Please enter your password.", "error")
                return render_template("login.html", last_login_identifier=username)
            if username:
                from models import User
                from sqlalchemy import func as _sa_func
                # Allow login by username or email (case-insensitive)
                user = User.query.filter(_sa_func.lower(User.username) == username.lower()).first()
                if not user:
                    user = User.query.filter(_sa_func.lower(User.email) == username.lower()).first()

                # â”€â”€ Check lockout BEFORE doing any password work â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
                if user and getattr(user, "lockout_until", None):
                    from datetime import datetime as _dt_lock
                    if user.lockout_until > _dt_lock.utcnow():
                        _remaining = int((user.lockout_until - _dt_lock.utcnow()).total_seconds() // 60) + 1
                        flash(
                            f"Too many failed attempts. Account locked for {_remaining} more minute(s). "
                            f"Use 'Forgot password?' below to reset your password and unlock immediately.",
                            "error"
                        )
                        # Auto-send a reset email so they can unlock immediately
                        try:
                            if _is_real_email(user.email):
                                from email_utils import generate_reset_token, send_reset_email
                                import threading as _lockmail_th
                                _lock_token = generate_reset_token(user.email)
                                _lock_url = request.host_url.rstrip('/') + f"/reset_password/{_lock_token}"
                                _lockmail_th.Thread(target=send_reset_email, args=(user.email, _lock_url), daemon=True).start()
                                print(f"[VybeFlow LOGIN] Auto-sent reset email to locked user={username!r}")
                        except Exception as _lock_email_err:
                            print(f"[VybeFlow LOGIN] lockout email error: {_lock_email_err}")
                        return render_template("login.html", last_login_identifier=username)
                    else:
                        # Lock has expired â€” clear it
                        try:
                            user.lockout_until = None
                            user.login_attempts = 0
                            db.session.commit()
                        except Exception:
                            db.session.rollback()

                # â”€â”€ Password verification â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
                import re as _re
                _raw_sha256 = _re.compile(r'^[0-9a-f]{64}$')
                _password_ok = False
                _auto_account = False

                # â”€â”€ Detect accounts with empty or corrupt hash BEFORE checking password â”€â”€
                # This prevents a silent, unrecoverable lockout. Send the user to
                # the password-reset flow instead of showing a generic bad-password error.
                if user and not user.password_hash:
                    print(f"[VybeFlow LOGIN] EMPTY-HASH  username={username!r} â€” directing to reset")
                    flash("Your account needs a password reset. Please use the 'Forgot password?' link below.", "warning")
                    return render_template("login.html", last_login_identifier=username)

                if user and user.password_hash and password:
                    _hash = user.password_hash
                    _is_werkzeug = _hash.startswith('pbkdf2:') or _hash.startswith('scrypt:') or '$' in _hash
                    if _is_werkzeug:
                        try:
                            _password_ok = check_password_hash(_hash, password)
                        except Exception as _e:
                            print(f"[VybeFlow LOGIN] hash-check error: {_e}")
                            _password_ok = False
                    elif _raw_sha256.match(_hash):
                        # Account auto-created (story/reel posted without login).
                        # It has a random SHA-256 "password" that was never given to the
                        # user.  Allow the user to claim the account by setting a real
                        # password on first login.
                        if len(password) >= 6:
                            user.password_hash = generate_password_hash(password, method='pbkdf2:sha256:260000')
                            try:
                                db.session.commit()
                                _password_ok = True
                                _auto_account = True
                                print(f"[VybeFlow LOGIN] CLAIMED auto-account {username!r} â€” password now set")
                            except Exception as _e:
                                db.session.rollback()
                                print(f"[VybeFlow LOGIN] claim-commit error: {_e}")
                        else:
                            flash("Password must be at least 6 characters.", "error")
                            return render_template("login.html", last_login_identifier=username)
                    else:
                        # Unknown hash format â€” account exists but password can't be verified.
                        # Locking out silently would permanently strand the user; tell them
                        # to reset instead.
                        print(f"[VybeFlow LOGIN] UNKNOWN-HASH  username={username!r}: {_hash[:20]}â€¦")
                        flash("Your account needs a password reset. Please use the 'Forgot password?' link below.", "warning")
                        return render_template("login.html", last_login_identifier=username)

                if _password_ok:
                    # Lazy rehash: upgrade only the very old 1M-iteration pbkdf2 hashes to
                    # the current 260k-iteration format.  All other formats (scrypt, modern
                    # pbkdf2) are already secure and are handled natively by werkzeug â€”
                    # we do NOT migrate them here to avoid unnecessary DB writes on every login.
                    if not _auto_account and ':1000000$' in user.password_hash:
                        try:
                            user.password_hash = generate_password_hash(password, method='pbkdf2:sha256:260000')
                            db.session.commit()
                        except Exception:
                            db.session.rollback()
                    # â”€â”€ IP logging (informational only â€” VybeFlow allows login from ANY IP) â”€â”€
                    # C-06: rely on socket-level remote_addr; X-Forwarded-For can be spoofed.
                    _login_ip = request.remote_addr or ""
                    try:
                        from models import BlacklistedIP as _BIP
                        if _login_ip and _BIP.is_blocked(_login_ip):
                            # Log for visibility but do NOT block â€” the platform explicitly
                            # allows login from any device/network, and a user who entered
                            # valid credentials must always be able to access their account.
                            print(f"[VybeFlow LOGIN] IP-NOTE  ip={_login_ip!r} is blacklisted but login not blocked (platform policy)")
                    except Exception as _ip_err:
                        print(f"[VybeFlow LOGIN] IP check error: {_ip_err}")
                    # â”€â”€ Ban check (hard ban after 3 AI fake-account strikes) â”€â”€
                    # is_banned = permanent block. is_suspended = negativity timeout;
                    # suspended users may still log in so they can see and appeal.
                    if getattr(user, 'is_banned', False):
                        _ban_reason = getattr(user, 'ban_reason', 'Account banned for repeated violations.')
                        print(f"[VybeFlow LOGIN] BANNED  username={username!r} reason={_ban_reason!r}")
                        # Scam bans â†’ aggressive stamp page; other bans â†’ standard blocked page
                        if str(_ban_reason).startswith("SCAM BAN"):
                            from datetime import datetime as _dt2
                            session.clear()
                            return redirect(url_for("blocked_scammer"))
                        session.clear()
                        from datetime import datetime as _dt
                        return render_template("blocked.html",
                            username=user.username,
                            reason=_ban_reason,
                            warnings=getattr(user, 'fake_account_warnings', None),
                            now=_dt.now().strftime('%B %d, %Y'))
                    # â”€â”€ Allow login â€” set session â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
                    # â”€â”€ TOTP 2FA check â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
                    if getattr(user, 'two_factor', False) and getattr(user, 'totp_secret', None):
                        _totp_code = request.form.get('totp_code', '').strip()
                        if not _totp_code:
                            # Stash partial auth in session; redirect to 2FA page
                            session['_2fa_pending_user'] = user.username
                            return render_template('login_2fa.html', username=user.username)
                        try:
                            import pyotp as _pyotp
                            _totp = _pyotp.TOTP(user.totp_secret)
                            if not _totp.verify(_totp_code, valid_window=1):
                                flash('Invalid 2FA code. Check your authenticator app.', 'error')
                                return render_template('login.html', last_login_identifier=username)
                        except Exception as _2fa_err:
                            print(f'[VybeFlow 2FA] verify error: {_2fa_err}')
                            flash('2FA verification failed. Please try again.', 'error')
                            return render_template('login.html', last_login_identifier=username)

                    # â”€â”€ Reset lockout on successful login â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
                    try:
                        user.login_attempts = 0
                        user.lockout_until = None
                        db.session.commit()
                    except Exception:
                        db.session.rollback()

                    # â”€â”€ Regenerate session to prevent session-fixation attacks â”€â”€
                    _old_csrf = session.get('csrf_token')
                    session.clear()
                    if _old_csrf:
                        session['csrf_token'] = _old_csrf
                    session.permanent = (request.form.get("remember_me") == "1")  # honor Remember Me
                    session["username"] = user.username
                    session["display_name"] = user.display_name or user.username
                    session["user_id"] = user.id
                    session["avatar_url"] = user.avatar_url or ""
                    session["logged_in"] = True
                    # Verify session was actually written
                    if not session.get("logged_in"):
                        flash("Session could not be created. Please clear your cookies and try again.", "error")
                        return render_template("login.html", last_login_identifier=username)
                    print(f"[VybeFlow LOGIN] SUCCESS  username={user.username!r} id={user.id}")

                    # â”€â”€ Bootstrap the Dynamic Seed Token chain â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
                    try:
                        from utils.dynamic_token import init_dst_session as _init_dst
                        g.dst_next_token = _init_dst(user.id, request, session)
                    except Exception as _dst_err:
                        print(f"[VybeFlow DST] init error (non-fatal): {_dst_err}")

                    # â”€â”€ Zero-Trust: score this login and record the event â”€â”€â”€â”€â”€â”€â”€
                    try:
                        from utils.zero_trust import score_request as _zt_score, record_risk_event as _zt_record
                        _zt_assessment = _zt_score(user.id, "login", request, session)
                        if _zt_assessment["log_event"]:
                            _zt_record(user.id, "login", _zt_assessment, request, session)
                        # Store current risk level in session for adaptive client-side behaviour
                        session["_zt_risk_level"] = _zt_assessment["level"]
                    except Exception as _zt_err:
                        print(f"[VybeFlow ZT] risk score error (non-fatal): {_zt_err}")
                    # Suspended users must verify their identity via live DOB camera scan
                    # before regaining access.  We never show the home feed to a suspended user.
                    if getattr(user, 'is_suspended', False):
                        print(f"[VybeFlow LOGIN] SUSPENDED  username={user.username!r} â€” redirecting to camera DOB verification")
                        return redirect(url_for("verification.camera_dob"))
                    # Flag the feed to offer passkey enrollment after this password login
                    session['offer_passkey_enrollment'] = True
                    return redirect(url_for("feed.feed_page"))
                else:
                    _hash_fmt = "none"
                    if user and user.password_hash:
                        _h = user.password_hash
                        if _h.startswith('pbkdf2:'): _hash_fmt = "pbkdf2"
                        elif _raw_sha256.match(_h): _hash_fmt = "raw-sha256"
                        else: _hash_fmt = "unknown"
                    print(f"[VybeFlow LOGIN] FAILED   username={username!r} user_found={user is not None} hash_fmt={_hash_fmt}")
                    # â”€â”€ Increment lockout counter on failure â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
                    if user:
                        try:
                            from datetime import datetime as _dt_fail, timedelta as _td_fail
                            _attempts = getattr(user, 'login_attempts', 0) + 1
                            user.login_attempts = _attempts
                            _LOCKOUT_AFTER = 10   # failures before lockout (generous for real users)
                            _LOCKOUT_MINS  = 15   # minutes locked
                            if _attempts >= _LOCKOUT_AFTER:
                                user.lockout_until = _dt_fail.utcnow() + _td_fail(minutes=_LOCKOUT_MINS)
                                user.login_attempts = 0  # reset counter so next window starts fresh
                                print(f"[VybeFlow LOGIN] LOCKED  username={username!r} until={user.lockout_until}")
                                # Auto-send reset email on lockout
                                try:
                                    if _is_real_email(user.email):
                                        from email_utils import generate_reset_token, send_reset_email
                                        import threading as _lockmail_th2
                                        _lk_token = generate_reset_token(user.email)
                                        _lk_url = request.host_url.rstrip('/') + f"/reset_password/{_lk_token}"
                                        _lockmail_th2.Thread(target=send_reset_email, args=(user.email, _lk_url), daemon=True).start()
                                except Exception:
                                    _swallow_exc("lockout reset-email send", level="warning")
                            db.session.commit()
                        except Exception as _lk_err:
                            db.session.rollback()
                            print(f"[VybeFlow LOGIN] lockout-update error: {_lk_err}")
                    # After 3+ failures, nudge toward password reset
                    # [H-05 FIX] Unified error message to prevent account enumeration
                    flash("Invalid username or password.", "error")
                    return render_template("login.html", last_login_identifier=username)
        return render_template("login.html") if os.path.exists(os.path.join(app.root_path, "templates", "login.html")) else "Login", 200

    # Apply login rate limit (15/min per IP) after the function is defined
    _login_lim = getattr(app, "_vybeflow_limiter", None)
    if _login_lim:
        try:
            _login_lim.limit("15 per minute")(login)
        except Exception as _login_rl_err:
            _sec_logger.debug("Login rate-limit attach: %s", _login_rl_err)

    # Hard limit: 5 registrations per hour per IP â€” stops bulk bot creation.
    # The honeypot + timing check (inside the route) add invisible bot signals
    # on top of this, so coordinated bots are stopped at the network+behavioral layer.
    _reg_limiter = getattr(app, "_vybeflow_limiter", None)

    @app.route("/register", methods=["GET", "POST"])
    def register():
        if request.method == "POST":
            # â”€â”€ Bot & spam protection â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            # 1. Honeypot: bots fill hidden fields that humans never see.
            #    The field is named "website" â€” looks legitimate to spiders.
            if request.form.get("website", ""):
                # Silently pretend success â€” don't tell bots they were caught
                return redirect(url_for("feed.feed_page"))

            # 2. Timing check: legitimate humans take >0.5s to fill a form.
            #    Submissions in <0.5s are almost certainly automated (not a
            #    real threshold for password managers, which fill quickly but
            #    still take a moment before submit).
            _form_ts = request.form.get("_ts", "")
            try:
                import time as _t_mod
                if _form_ts and ((_t_mod.time() - float(_form_ts)) < 0.5):
                    # Silently redirect â€” don't expose the check
                    return redirect(url_for("register"))
            except (ValueError, TypeError):
                pass

            # 3. IP rate limit: maximum 5 registrations per hour per IP (server-side, not session-based).
            _reg_ip_key = request.remote_addr or "unknown"
            if _reg_ip_rate_limit(f"register:{_reg_ip_key}", max_calls=5, window_seconds=3600):
                flash("Too many account creation attempts. Please try again in an hour.", "error")
                return redirect(url_for("register"))

            username = request.form.get("username", "").strip()
            email = request.form.get("email", "").strip()
            password = request.form.get("password", "")
            account_type = request.form.get("account_type", "regular").strip()
            dob_str = request.form.get("date_of_birth", "").strip()

            # Age gate (COPPA: must be 13+)
            # DOB is required -- never skip the check when the field is absent.
            if not dob_str:
                flash("Date of birth is required to create an account.", "error")
                return redirect(url_for("register"))
            try:
                from datetime import date
                dob = date.fromisoformat(dob_str)
                today = date.today()
                age = today.year - dob.year - ((today.month, today.day) < (dob.month, dob.day))
                if age < 13:
                    flash("You must be at least 13 years old to use VybeFlow.", "error")
                    return redirect(url_for("register"))
            except ValueError:
                flash("Invalid date of birth. Please use YYYY-MM-DD format.", "error")
                return redirect(url_for("register"))

            if not username:
                flash("Username is required.", "error")
                return redirect(url_for("register"))
            if not password or len(password) < 8:
                flash("Password must be at least 8 characters.", "error")
                return redirect(url_for("register"))
            if not email:
                email = f"{username}@VybeFlow.local"

            from models import User
            from sqlalchemy import func as _sa_func
            # Check for existing user (case-insensitive)
            existing = User.query.filter(_sa_func.lower(User.username) == username.lower()).first()
            if existing:
                flash("An account with those details already exists.", "error")
                return redirect(url_for("register"))
            if email and email != f"{username}@VybeFlow.local":
                existing_email = User.query.filter(_sa_func.lower(User.email) == email.lower()).first()
                if existing_email:
                    flash("An account with those details already exists.", "error")
                    return redirect(url_for("register"))

            # â”€â”€ Block-evasion: IP + email/phone hash blacklist â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            _reg_ip = (request.headers.get("X-Forwarded-For", "").split(",")[0].strip()
                       or request.remote_addr or "")
            try:
                from models import BlacklistedIP as _BIP, IdentityHashBlacklist as _IHB
                if _reg_ip and _BIP.is_blocked(_reg_ip):
                    return render_template("blocked.html",
                        username=username,
                        reason="Account creation is not allowed from this network.",
                        warnings=None,
                        now=__import__('datetime').datetime.now().strftime('%B %d, %Y'))
                if email and email != f"{username}@VybeFlow.local":
                    if _IHB.is_blocked("email", email):
                        flash("This email address cannot be used to create a new account.", "error")
                        return redirect(url_for("register"))
                _reg_phone = request.form.get("phone", "").strip()
                if _reg_phone and _IHB.is_blocked("phone", _reg_phone):
                    flash("This phone number cannot be used to create a new account.", "error")
                    return redirect(url_for("register"))
            except Exception as _ev_err:
                print(f"[VybeFlow REGISTER] evasion-check error: {_ev_err}")
            # AI: Check for fake identity / impersonation in username
            from platform_rules import check_fake_identity
            display = request.form.get("display_name", "").strip()
            identity_check = check_fake_identity(display_name=display or username, bio="")
            if identity_check["is_impersonation"]:
                flash("That name appears to impersonate an official role or identity. You can use any creative name, but impersonation is not allowed.", "error")
                return redirect(url_for("register"))

            # Create user with hashed password
            hashed = generate_password_hash(password, method='pbkdf2:sha256:260000')
            # â”€â”€ IP â†’ country â†’ home currency detection at signup â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            # Use remote_addr to avoid X-Forwarded-For spoofing
            _signup_ip = request.remote_addr or "127.0.0.1"
            try:
                from utils.geo_currency import detect_currency_for_ip
                _geo = detect_currency_for_ip(_signup_ip)
                _signup_country  = _geo.get("country_code", "US")
                _home_currency   = _geo.get("currency_code", "USD").upper()
            except Exception:
                _signup_country, _home_currency = "US", "USD"

            user = User(
                username=username,
                email=email,
                password_hash=hashed,
                bio="",
                avatar_url=url_for('static', filename='VFlogo_clean.png'),
                signup_country=_signup_country,
                home_currency=_home_currency,
                currency_code=_home_currency,
            )
            if account_type in ("regular", "professional"):
                user.account_type = account_type
            # â”€â”€ Professional-specific fields â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            if account_type == "professional":
                _biz = (request.form.get("business_category") or "").strip()
                if _biz:
                    user.business_category = _biz[:80]
                _port = (request.form.get("portfolio_url") or "").strip()
                if _port:
                    # Enforce https:// prefix for safety
                    if _port and not _port.startswith(("http://", "https://")):
                        _port = "https://" + _port
                    user.portfolio_url = _port[:255]
                _skills = (request.form.get("skills_list") or "").strip()
                if _skills:
                    user.skills_list = _skills[:300]
            # â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            if dob_str:
                try:
                    user.date_of_birth = date.fromisoformat(dob_str)
                except Exception:
                    pass
            # New accounts always get the onboarding tour
            user.is_new_user = True
            db.session.add(user)
            try:
                db.session.commit()
            except Exception as _db_err:
                db.session.rollback()
                print(f"[VybeFlow REGISTER] DB write failed: {_db_err}")
                flash("Registration failed â€” could not save your account. Please try again.", "error")
                return redirect(url_for("register"))

            # Clear any stale session from a previous login so old
            # account data (avatar, preferences, etc.) doesn't leak into
            # the brand-new account.
            session.clear()
            session.permanent = True   # stay logged in for PERMANENT_SESSION_LIFETIME
            session["username"] = user.username
            session["display_name"] = user.display_name or user.username
            session["user_id"] = user.id
            session["avatar_url"] = user.avatar_url or ""
            session["logged_in"] = True
            # Verify session was actually written (sanity check)
            if not session.get("logged_in"):
                flash("Session could not be created. Please try again.", "error")
                return render_template("register.html")

            # Send verification email + (non-blocking) welcome email
            # Skip test/fake emails to avoid bouncing from SMTP
            if _is_real_email(user.email):
                try:
                    from email_utils import (
                        send_welcome_email, generate_email_verify_token, send_email_verification
                    )
                    import threading as _eth
                    # Generate itsdangerous token (signed, no DB needed)
                    _ev_token = generate_email_verify_token(user.id, user.email)
                    _ev_url   = url_for("verify_email", token=_ev_token, _external=True)
                    _email, _uname, _dname = user.email, user.username, user.display_name or user.username
                    def _send_both(_em, _un, _dn, _url):
                        try:
                            send_email_verification(_em, _dn, _url)
                        except Exception:
                            _swallow_exc("send_email_verification", level="warning")
                        try:
                            send_welcome_email(_em, _un)
                        except Exception:
                            _swallow_exc("send_welcome_email", level="warning")
                    _eth.Thread(target=_send_both, args=(_email, _uname, _dname, _ev_url), daemon=True).start()
                except Exception as e:
                    print(f"[VybeFlow] Verification/welcome email skipped: {e}")

            print(f"[VybeFlow REGISTER] NEW USER  username={user.username!r} email={user.email!r} id={user.id}")
            flash("Account created! Welcome to VybeFlow 🔥 â€” check your email to verify your address.", "success")
            return redirect(url_for("feed.feed_page"))
        return render_template("register.html") if os.path.exists(os.path.join(app.root_path, "templates", "register.html")) else redirect(url_for("login"))

    # Apply registration rate limit (5/hour per IP) after the function is defined
    _reg_lim2 = getattr(app, "_vybeflow_limiter", None)
    if _reg_lim2:
        try:
            _reg_lim2.limit("5 per hour")(register)
        except Exception as _rl3:
            _sec_logger.debug("Register rate-limit attach: %s", _rl3)

    @app.route("/verify-email/<token>")
    def verify_email(token: str):
        """Confirm a user's email address from the link sent at registration."""
        from email_utils import verify_email_token
        from models import User
        payload = verify_email_token(token)
        if not payload:
            flash("This verification link is invalid or has expired. Please request a new one.", "warning")
            return redirect(url_for("login"))
        user = db.session.get(User, payload.get("uid"))
        if not user:
            flash("Account not found.", "error")
            return redirect(url_for("login"))
        if user.email != payload.get("email"):
            flash("This link is for a different email address.", "warning")
            return redirect(url_for("login"))
        if not getattr(user, "email_verified", False):
            user.email_verified = True
            try:
                db.session.commit()
            except Exception:
                db.session.rollback()
            print(f"[VybeFlow] EMAIL VERIFIED  user={user.username!r} email={user.email!r}")
        flash("Email verified! You can now send messages and post freely.", "success")
        return redirect(url_for("feed.feed_page"))

    @app.route("/api/auth/resend-verification", methods=["POST"])
    def resend_verification():
        """Resend the email verification link to the logged-in user."""
        uid = session.get("user_id")
        if not uid:
            return jsonify({"error": "Not logged in"}), 401
        from models import User
        user = db.session.get(User, uid)
        if not user:
            return jsonify({"error": "User not found"}), 404
        if getattr(user, "email_verified", False):
            return jsonify({"ok": True, "message": "Email is already verified."}), 200
        if not _is_real_email(user.email):
            return jsonify({"error": "No email address on file."}), 400
        try:
            from email_utils import generate_email_verify_token, send_email_verification
            token = generate_email_verify_token(user.id, user.email)
            url_  = url_for("verify_email", token=token, _external=True)
            import threading as _resend_th
            _resend_th.Thread(
                target=send_email_verification,
                args=(user.email, user.display_name or user.username, url_),
                daemon=True,
            ).start()
        except Exception as exc:
            print(f"[VybeFlow] resend-verification error: {exc}")
        return jsonify({"ok": True, "message": "Verification email sent â€” check your inbox."}), 200

