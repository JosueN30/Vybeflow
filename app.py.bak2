    # â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    # GRAFFITI WALL â€” Squad members spray tags onto a friend's profile bg
    # â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    _GRAFFITI_MAX = 6          # max tags per profile
    _GRAFFITI_MAX_BYTES = 512 * 1024   # 512 KB per PNG

    @app.post("/api/graffiti/upload/<target_username>")
    def api_graffiti_upload(target_username):
        """Upload a transparent PNG graffiti tag onto a friend's profile wall.

        Expects multipart/form-data with field ``tag_image`` (PNG file)
        OR JSON body with ``tag_data_url`` (data:image/png;base64,â€¦ string).

        Rules:
          - Uploader must be logged in + must be a friend/follower of target
          - Target profile must not have Hard Blocked the uploader
          - Max 6 tags per profile (oldest is dropped when capacity is reached)
          - PNG only; max 512 KB
        """
        import json as _j
        from models import User, FriendRequest, Block
        from __init__ import db
        caller_username = session.get("username")
        if not caller_username:
            return _j.dumps({"ok": False, "error": "login_required"}), 401, {"Content-Type": "application/json"}
        caller = User.query.filter_by(username=caller_username).first()
        target = User.query.filter_by(username=target_username).first()
        if not caller or not target:
            return _j.dumps({"ok": False, "error": "not_found"}), 404, {"Content-Type": "application/json"}
        # Must be friends
        fr = FriendRequest.query.filter(
            ((FriendRequest.sender_id == caller.id) & (FriendRequest.receiver_id == target.id)) |
            ((FriendRequest.sender_id == target.id) & (FriendRequest.receiver_id == caller.id)),
            FriendRequest.status == "accepted"
        ).first()
        if not fr and caller.id != target.id:
            return _j.dumps({"ok": False, "error": "not_friends"}), 403, {"Content-Type": "application/json"}
        # Block check
        if Block.is_blocked(caller.id, target.id) or Block.is_blocked(target.id, caller.id):
            return _j.dumps({"ok": False, "error": "blocked"}), 403, {"Content-Type": "application/json"}

        # Receive image
        tag_url = ""
        try:
            tag_file = request.files.get("tag_image")
            tag_data_url = (request.form.get("tag_data_url") or "").strip()
            if tag_data_url and tag_data_url.startswith("data:image/png;base64,"):
                import base64, uuid as _uuid
                raw = base64.b64decode(tag_data_url.split(",", 1)[1])
                if len(raw) > _GRAFFITI_MAX_BYTES:
                    return _j.dumps({"ok": False, "error": "file_too_large"}), 400, {"Content-Type": "application/json"}
                fname = f"graffiti/{_uuid.uuid4().hex}.png"
                abs_p = os.path.join(current_app.config["POST_UPLOAD_ABS"], fname)
                os.makedirs(os.path.dirname(abs_p), exist_ok=True)
                with open(abs_p, "wb") as fh:
                    fh.write(raw)
                tag_url = current_app.config["UPLOAD_URL_PREFIX"] + fname
            elif tag_file and tag_file.filename:
                if not tag_file.filename.lower().endswith(".png"):
                    return _j.dumps({"ok": False, "error": "png_only"}), 400, {"Content-Type": "application/json"}
                import uuid as _uuid
                chunk = tag_file.read(_GRAFFITI_MAX_BYTES + 1)
                if len(chunk) > _GRAFFITI_MAX_BYTES:
                    return _j.dumps({"ok": False, "error": "file_too_large"}), 400, {"Content-Type": "application/json"}
                fname = f"graffiti/{_uuid.uuid4().hex}.png"
                abs_p = os.path.join(current_app.config["POST_UPLOAD_ABS"], fname)
                os.makedirs(os.path.dirname(abs_p), exist_ok=True)
                with open(abs_p, "wb") as fh:
                    fh.write(chunk)
                tag_url = current_app.config["UPLOAD_URL_PREFIX"] + fname
            else:
                return _j.dumps({"ok": False, "error": "no_image"}), 400, {"Content-Type": "application/json"}
        except Exception as _ue:
            current_app.logger.error(f"graffiti upload error: {_ue}")
            return _j.dumps({"ok": False, "error": "upload_failed"}), 500, {"Content-Type": "application/json"}

        # Append to graffiti_tags list (capped at _GRAFFITI_MAX)
        import uuid as _uuid2, datetime as _dt2
        try:
            tags = _j.loads(target.graffiti_tags or "[]")
        except Exception:
            tags = []
        new_tag = {
            "id": _uuid2.uuid4().hex,
            "url": tag_url,
            "author_username": caller_username,
            "uploaded_at": _dt2.datetime.now(timezone.utc).isoformat(),
        }
        tags.append(new_tag)
        if len(tags) > _GRAFFITI_MAX:
            tags = tags[-_GRAFFITI_MAX:]  # keep newest
        target.graffiti_tags = _j.dumps(tags)
        db.session.commit()
        return _j.dumps({"ok": True, "tag": new_tag}), 200, {"Content-Type": "application/json"}

    @app.delete("/api/graffiti/<target_username>/<tag_id>")
    def api_graffiti_delete(target_username, tag_id):
        """Remove a graffiti tag. Only the tag author OR the profile owner can delete."""
        import json as _j
        from models import User
        from __init__ import db
        caller_username = session.get("username")
        if not caller_username:
            return _j.dumps({"ok": False, "error": "login_required"}), 401, {"Content-Type": "application/json"}
        target = User.query.filter_by(username=target_username).first()
        if not target:
            return _j.dumps({"ok": False, "error": "not_found"}), 404, {"Content-Type": "application/json"}
        try:
            tags = _j.loads(target.graffiti_tags or "[]")
        except Exception:
            tags = []
        tag = next((t for t in tags if t.get("id") == tag_id), None)
        if not tag:
            return _j.dumps({"ok": False, "error": "not_found"}), 404, {"Content-Type": "application/json"}
        if caller_username != tag.get("author_username") and caller_username != target_username:
            return _j.dumps({"ok": False, "error": "forbidden"}), 403, {"Content-Type": "application/json"}
        tags = [t for t in tags if t.get("id") != tag_id]
        target.graffiti_tags = _j.dumps(tags)
        db.session.commit()
        return _j.dumps({"ok": True}), 200, {"Content-Type": "application/json"}

    # H-07: Strict hex-color validator — prevents CSS injection via theme fields
    import re as _re_theme
    _CSS_HEX_RE = _re_theme.compile(r'^#[0-9a-fA-F]{3}(?:[0-9a-fA-F]{3})?$')
    _CSS_RGBA_RE = _re_theme.compile(
        r'^rgba?\(\s*\d{1,3}\s*,\s*\d{1,3}\s*,\s*\d{1,3}\s*(?:,\s*(?:0|1|0?\.\d+)\s*)?\)$'
    )

    def _safe_css_color(val: str) -> str:
        """Return val if it is a safe CSS color, empty string otherwise."""
        v = (val or '').strip()
        if _CSS_HEX_RE.match(v) or _CSS_RGBA_RE.match(v):
            return v
        return ''

    @app.route("/api/update_theme", methods=["POST"])
    def api_update_theme():
        """Save the user's chosen theme preset + colors to the database."""
        username = session.get('username')
        if not username:
            return jsonify({"ok": False, "error": "Not logged in"}), 401
        from models import User
        from __init__ import db
        import json as _json_ut
        user_ut = User.query.filter_by(username=username).first()
        if not user_ut:
            return jsonify({"ok": False, "error": "User not found"}), 404
        try:
            data = request.get_json(silent=True) or {}
            preset = str(data.get('preset', '') or '').strip()[:120]
            user_ut.theme = preset
            _tc_ut = {}
            # H-07: Only accept valid CSS hex or rgba() values — reject any other string
            for _k, _f in [('bg', 'bg'), ('brand1', 'brand1'), ('brand2', 'brand2'), ('brand3', 'brand3'), ('line', 'line')]:
                _v = _safe_css_color(str(data.get(_k, '') or ''))
                if _v:
                    _tc_ut[_f] = _v
            if _tc_ut:
                user_ut.theme_colors = _json_ut.dumps(_tc_ut)
            # Explicitly mark the object modified and flush to ensure SQLite sees it
            db.session.add(user_ut)
            db.session.flush()
            db.session.commit()
            return jsonify({"ok": True})
        except Exception as _e:
            db.session.rollback()
            current_app.logger.error(f"update_theme failed: {_e}")
            return jsonify({"ok": False, "error": "Save failed"}), 500

    @app.route("/settings", methods=["GET", "POST"])
    def settings():
        from models import User
        from __init__ import db
        import base64
        import uuid

        def _save_data_url(data_url: str, folder: str) -> str:
            """Safely decode a data-URL and write it to uploads/<folder>/.

            Security controls (C-02, C-05, H-08):
              • 5 MB size cap enforced BEFORE decoding the full buffer
              • Magic-byte whitelist: only jpeg/png/webp/gif accepted
              • folder is validated to an allowlist — no path traversal
            """
            import re as _re_du
            if not data_url or "," not in data_url:
                return ""

            # ── Size cap: estimate raw bytes from b64 length before allocating ──
            _MAX_RAW = 5 * 1024 * 1024  # 5 MB
            _b64_part = data_url.split(",", 1)[1]
            if len(_b64_part) > (_MAX_RAW * 4 // 3) + 64:
                current_app.logger.warning("_save_data_url: oversized upload rejected (b64 len=%d)", len(_b64_part))
                return ""

            try:
                raw = base64.b64decode(_b64_part, validate=True)
            except Exception:
                return ""

            if len(raw) > _MAX_RAW:
                return ""

            # ── Magic-byte check: derive extension from file content, not header ──
            _MAGIC = [
                (b'\xff\xd8\xff', 'jpg'),
                (b'\x89PNG\r\n\x1a\n', 'png'),
                (b'GIF87a', 'gif'),
                (b'GIF89a', 'gif'),
            ]
            ext = None
            for sig, e in _MAGIC:
                if raw[:len(sig)] == sig:
                    ext = e
                    break
            # RIFF/WEBP has an 8-byte gap before the subtype
            if ext is None and raw[:4] == b'RIFF' and raw[8:12] == b'WEBP':
                ext = 'webp'
            if ext is None:
                current_app.logger.warning("_save_data_url: rejected non-image magic bytes")
                return ""

            # ── Folder allowlist: prevent path traversal ──
            _ALLOWED = {'wallpapers', 'avatars', 'covers', 'uploads'}
            _clean_folder = os.path.basename(folder.rstrip('/\\'))
            if _clean_folder not in _ALLOWED:
                _clean_folder = 'uploads'

            filename = f"{_clean_folder}/{uuid.uuid4().hex}.{ext}"
            abs_path = os.path.join(current_app.config["POST_UPLOAD_ABS"], filename)
            # Final path traversal guard: ensure resolved path stays inside upload root
            _upload_root = os.path.realpath(current_app.config["POST_UPLOAD_ABS"])
            if not os.path.realpath(abs_path).startswith(_upload_root + os.sep):
                return ""
            os.makedirs(os.path.dirname(abs_path), exist_ok=True)
            with open(abs_path, "wb") as f:
                f.write(raw)
            return current_app.config["UPLOAD_URL_PREFIX"] + filename

        username = session.get('username')
        user = User.query.filter_by(username=username).first() if username else None
        if not user:
            flash("Please log in to access settings.", "error")
            return redirect(url_for("login"))

        def _clean_music_text(value: str, max_len: int = 180) -> str:
            text = " ".join((value or "").strip().split())
            if not text:
                return ""
            return text[:max_len]

        def _clean_profile_music_url(value: str, allow_relative: bool = False, max_len: int = 2048) -> str:
            from urllib.parse import urlparse

            raw = (value or "").strip()
            if not raw:
                return ""
            if len(raw) > max_len:
                return ""
            if any(ch in raw for ch in ("\r", "\n", "\x00")):
                return ""

            parsed = urlparse(raw)
            if allow_relative and not parsed.scheme and raw.startswith("/"):
                return raw
            if parsed.scheme not in ("http", "https") or not parsed.netloc:
                return ""
            return raw

        def _clean_profile_text(value: str, max_len: int) -> str:
            text = " ".join((value or "").strip().split())
            if not text:
                return ""
            return text[:max_len]

        def _redirect_settings_with_active_tab(default_tab: str = "settings-account"):
            _tab = (request.form.get('_active_tab') or default_tab).strip()
            _redir = url_for("settings")
            if _tab:
                _redir += "#" + _tab
            return redirect(_redir)

        if request.method == "POST":
            # â”€â”€ Delete account handler â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            _action = request.form.get('action', '').strip()
            if _action == 'delete_account':
                _confirm = request.form.get('delete_confirm', '').strip()
                _del_pwd = request.form.get('delete_password', '')
                if _confirm != 'DELETE':
                    flash("Type DELETE (all caps) to confirm account deletion.", "error")
                    return redirect(url_for('settings') + '#settings-delete')
                # H-06: Require current password before destroying account
                from werkzeug.security import check_password_hash as _del_cph
                if not _del_pwd or not user or not _del_cph(user.password_hash, _del_pwd):
                    flash("Current password is required to delete your account.", "error")
                    return redirect(url_for('settings') + '#settings-delete')
                if user:
                    try:
                        db.session.delete(user)
                        db.session.commit()
                        session.clear()
                        flash("Your account has been permanently deleted.", "info")
                    except Exception as _del_err:
                        db.session.rollback()
                        current_app.logger.error(f"Account deletion failed: {_del_err}")
                        flash("Account deletion failed. Please try again.", "error")
                        return redirect(url_for('settings') + '#settings-delete')
                return redirect(url_for('home'))
            # â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
            if user:
                try:
                    form_type = (request.form.get('_form_type') or '').strip()
                    is_wallpaper_only = (form_type == 'wallpaper')

                    display_name = _clean_profile_text(request.form.get('display_name'), max_len=60)
                    bio = _clean_profile_text(request.form.get('bio'), max_len=200)
                    avatar_crop = (request.form.get('avatar_crop_data') or '').strip()
                    cover_crop = (request.form.get('cover_crop_data') or '').strip()
                    avatar_file = request.files.get('profile_avatar')
                    cover_file = request.files.get('profile_background')

                    music_title = _clean_music_text(request.form.get('profile_music_title'), max_len=180)
                    music_artist = _clean_music_text(request.form.get('profile_music_artist'), max_len=180)
                    music_preview = _clean_profile_music_url(request.form.get('profile_music_preview'), allow_relative=False)
                    music_artwork = _clean_profile_music_url(request.form.get('profile_music_artwork'), allow_relative=True)
                except Exception as form_read_err:
                    current_app.logger.error(f"Error reading form data: {form_read_err}")
                    flash("Error reading form data. Please try again.", "error")
                    return _redirect_settings_with_active_tab()

                if not is_wallpaper_only:
                    # Toggle-style preferences
                    try:
                        ai_assist_enabled = 'ai_assist' in request.form
                        retro_enabled = 'retro_2011' in request.form
                        safe_mode_enabled = 'safe_mode' in request.form
                        email_notif_enabled = 'email_notifications' in request.form
                        live_collab_enabled = 'live_collab' in request.form
                        auto_captions_enabled = 'auto_captions' in request.form
                        default_visibility = (request.form.get('default_visibility') or 'public').lower()
                        if default_visibility not in ("public", "followers", "private"):
                            default_visibility = "public"
                    except Exception as toggle_err:
                        current_app.logger.warning(f"Error reading toggle preferences: {toggle_err}")
                        # Use defaults
                        ai_assist_enabled = False
                        retro_enabled = False
                        safe_mode_enabled = False
                        email_notif_enabled = False
                        live_collab_enabled = False
                        auto_captions_enabled = False
                        default_visibility = "public"

                    # â”€â”€ New privacy settings â”€â”€
                    profile_visibility = (request.form.get('profile_visibility') or 'public').lower()
                    if profile_visibility not in ('public', 'private', 'hidden'):
                        profile_visibility = 'public'
                    follow_approval = 'follow_approval' in request.form
                    show_activity_status = 'show_activity_status' in request.form
                    who_can_message = (request.form.get('who_can_message') or 'everyone').lower()
                    who_can_comment = (request.form.get('who_can_comment') or 'everyone').lower()
                    who_can_tag = (request.form.get('who_can_tag') or 'everyone').lower()
                    read_receipts = 'read_receipts' in request.form
                    allow_story_sharing = 'allow_story_sharing' in request.form
                    story_replies = (request.form.get('story_replies') or 'everyone').lower()
                    hide_story_from = (request.form.get('hide_story_from') or '').strip()
                    allow_reel_remix = 'allow_reel_remix' in request.form
                    allow_reel_download = 'allow_reel_download' in request.form
                    hide_like_counts = 'hide_like_counts' in request.form
                    blocked_words = (request.form.get('blocked_words') or '').strip()
                    restrict_unknown = 'restrict_unknown' in request.form
                    two_factor = 'two_factor' in request.form
                    login_alerts = 'login_alerts' in request.form
                    # â”€â”€ New trust/safety/privacy fields â”€â”€
                    anonymous_posting_enabled = 'anonymous_posting_enabled' in request.form
                    message_filter_level = (request.form.get('message_filter_level') or 'standard').lower()
                    if message_filter_level not in ('open', 'standard', 'strict'):
                        message_filter_level = 'standard'
                    hidden_profile = 'hidden_profile' in request.form
                    energy_filter_enabled = 'energy_filter_enabled' in request.form
                    temp_username_val = (request.form.get('temp_username') or '').strip()

                if not is_wallpaper_only:
                    # AI: Check for fake identity / impersonation in name/bio changes
                    from platform_rules import check_fake_identity
                    identity_check = check_fake_identity(
                        display_name=display_name or user.username,
                        bio=bio or '',
                    )
                    if identity_check["is_impersonation"]:
                        flash("Your name or bio appears to impersonate an official role or identity. Creative names are welcome, but impersonation is not allowed.", "error")
                        return _redirect_settings_with_active_tab()

                    # Copy-paste scam guard: reject bios already reused by many accounts.
                    # We intentionally only trigger on sufficiently long bios to avoid
                    # false positives for short phrases like "Hi" or "New here".
                    try:
                        from sqlalchemy import func as _sa_func
                        _bio_norm = " ".join((bio or "").strip().lower().split())
                        if len(_bio_norm) >= 24:
                            _dup_count = (
                                User.query
                                .filter(User.id != user.id)
                                .filter(_sa_func.lower(_sa_func.trim(User.bio)) == _bio_norm)
                                .count()
                            )
                            if _dup_count >= 4:
                                current_app.logger.warning(
                                    "Blocked duplicate bio save user_id=%s norm_len=%s dup_count=%s",
                                    getattr(user, "id", None), len(_bio_norm), _dup_count + 1
                                )
                                flash(
                                    "This bio appears to be copied across many accounts. Please personalize it before saving.",
                                    "error",
                                )
                                return _redirect_settings_with_active_tab()
                    except Exception as bio_dup_err:
                        current_app.logger.warning(f"bio duplicate check failed: {bio_dup_err}")

                    # Only update display_name if user provided a non-empty value
                    if display_name:
                        user.display_name = display_name
                    # Always save bio (allow clearing)
                    user.bio = bio

                    # Save date of birth if provided (no cooldown / no limit)
                    dob_val = (request.form.get('date_of_birth') or '').strip()
                    if dob_val:
                        try:
                            from datetime import date as _date
                            _dob = _date.fromisoformat(dob_val)
                            _today = _date.today()
                            _min_date = _date(1900, 1, 1)
                            _max_allowed = _date(_today.year - 13, _today.month, _today.day)

                            if _dob < _min_date:
                                flash("Year must be 1900 or later.", "error")
                                return _redirect_settings_with_active_tab()
                            if _dob > _today:
                                flash("Date of birth cannot be in the future.", "error")
                                return _redirect_settings_with_active_tab()
                            if _dob > _max_allowed:
                                flash("You must be at least 13 years old to use VybeFlow.", "error")
                                return _redirect_settings_with_active_tab()

                            user.date_of_birth = _dob
                        except Exception:
                            flash("Please enter a valid date of birth.", "error")
                            return _redirect_settings_with_active_tab()
                    elif request.form.get('date_of_birth') == '':
                        user.date_of_birth = None

                    # Account type (regular / professional)
                    account_type = (request.form.get('account_type') or '').strip().lower()
                    if account_type in ('regular', 'professional'):
                        try:
                            user.account_type = account_type
                        except Exception:
                            pass

                    # Persist toggles on the user model
                    try:
                        user.ai_assist = ai_assist_enabled
                        user.retro_2011 = retro_enabled
                        user.safe_mode = safe_mode_enabled
                        user.energy_filter_enabled = energy_filter_enabled
                        user.email_notifications = email_notif_enabled
                        user.live_collab = live_collab_enabled
                        user.auto_captions = auto_captions_enabled
                        user.default_visibility = default_visibility
                    except Exception as pref_err:
                        current_app.logger.warning(f"settings toggle save failed: {pref_err}")

                    # Persist privacy / safety settings
                    try:
                        user.profile_visibility = profile_visibility
                        user.follow_approval = follow_approval
                        user.show_activity_status = show_activity_status
                        user.who_can_message = who_can_message
                        user.who_can_comment = who_can_comment
                        user.who_can_tag = who_can_tag
                        user.read_receipts = read_receipts
                        user.allow_story_sharing = allow_story_sharing
                        user.story_replies = story_replies
                        user.hide_story_from = hide_story_from
                        user.allow_reel_remix = allow_reel_remix
                        user.allow_reel_download = allow_reel_download
                        user.hide_like_counts = hide_like_counts
                        user.blocked_words = blocked_words
                        user.restrict_unknown = restrict_unknown
                        user.two_factor = two_factor
                        user.login_alerts = login_alerts
                    except Exception as privacy_err:
                        current_app.logger.warning(f"privacy settings save failed: {privacy_err}")

                    # Mature content PIN (account-level)
                    try:
                        new_mature_pin = (request.form.get("mature_pin") or "").strip()
                        remove_mature_pin = request.form.get("remove_mature_pin") == "1"
                        if remove_mature_pin:
                            user.mature_pin = None
                            session.pop("mature_content_unlocked", None)
                        elif new_mature_pin:
                            if len(new_mature_pin) >= 4 and len(new_mature_pin) <= 8 and new_mature_pin.isdigit():
                                user.mature_pin = generate_password_hash(new_mature_pin, method="pbkdf2:sha256:260000")
                    except Exception as pin_err:
                        current_app.logger.warning(f"mature_pin save failed: {pin_err}")

                    # Persist trust/safety/privacy settings
                    try:
                        user.anonymous_posting_enabled = anonymous_posting_enabled
                        user.message_filter_level = message_filter_level
                        user.hidden_profile = hidden_profile
                        if temp_username_val:
                            user.temp_username = temp_username_val[:80]
                            from datetime import datetime as _dt, timedelta as _td
                            user.temp_username_expires = _dt.utcnow() + _td(days=7)
                        elif request.form.get('temp_username') == '':
                            user.temp_username = None
                            user.temp_username_expires = None
                        # Recalculate trust score on settings save
                        from moderation_engine import calculate_trust_score
                        user.trust_score = calculate_trust_score(user)
                    except Exception as trust_err:
                        current_app.logger.warning(f"trust/safety settings save failed: {trust_err}")

                # â”€â”€ Wallpaper / MySpace customization â”€â”€
                try:
                    wp_type = (request.form.get('wallpaper_type') or '').strip()
                    if wp_type in ('none','color','gradient','pattern','image','street'):
                        user.wallpaper_type = wp_type
                    wp_c1 = _safe_css_color(request.form.get('wallpaper_color1') or '')
                    if wp_c1: user.wallpaper_color1 = wp_c1
                    wp_c2 = _safe_css_color(request.form.get('wallpaper_color2') or '')
                    if wp_c2: user.wallpaper_color2 = wp_c2
                    wp_pat = (request.form.get('wallpaper_pattern') or '').strip()
                    if wp_pat: user.wallpaper_pattern = wp_pat[:40]
                    wp_anim = (request.form.get('wallpaper_animation') or '').strip()
                    if wp_anim: user.wallpaper_animation = wp_anim[:40]
                    wp_motion = (request.form.get('wallpaper_motion') or '').strip()
                    if wp_motion: user.wallpaper_motion = wp_motion[:40]
                    user.wallpaper_glitter = 'wallpaper_glitter' in request.form
                    user.wallpaper_music_sync = 'wallpaper_music_sync' in request.form
                    wp_img_data = (request.form.get('wallpaper_image_data') or '').strip()
                    if wp_img_data:
                        wp_url = _save_data_url(wp_img_data, "wallpapers")
                        if wp_url: user.wallpaper_image_url = wp_url
                    wp_img_file = request.files.get('wallpaper_image')
                    if wp_img_file and wp_img_file.filename:
                        fn = secure_filename(wp_img_file.filename)
                        wp_unique = f"wallpapers/{uuid.uuid4().hex}_{fn}"
                        wp_abs = os.path.join(current_app.config["POST_UPLOAD_ABS"], wp_unique)
                        os.makedirs(os.path.dirname(wp_abs), exist_ok=True)
                        wp_img_file.save(wp_abs)
                        user.wallpaper_image_url = current_app.config["UPLOAD_URL_PREFIX"] + wp_unique
                except Exception as wp_err:
                    current_app.logger.warning(f"wallpaper settings save failed: {wp_err}")

                if not is_wallpaper_only:
                    if avatar_crop:
                        avatar_url = _save_data_url(avatar_crop, "avatars")
                        if avatar_url:
                            user.avatar_url = avatar_url
                            session['avatar_url'] = avatar_url
                    elif avatar_file and avatar_file.filename:
                        filename = secure_filename(avatar_file.filename)
                        unique = f"avatars/{uuid.uuid4().hex}_{filename}"
                        abs_path = os.path.join(current_app.config["POST_UPLOAD_ABS"], unique)
                        os.makedirs(os.path.dirname(abs_path), exist_ok=True)
                        avatar_file.save(abs_path)
                        avatar_url = current_app.config["UPLOAD_URL_PREFIX"] + unique
                        user.avatar_url = avatar_url
                        session['avatar_url'] = avatar_url

                    if cover_crop:
                        cover_url = _save_data_url(cover_crop, "covers")
                        if cover_url:
                            user.profile_bg_url = cover_url
                    elif cover_file and cover_file.filename:
                        filename = secure_filename(cover_file.filename)
                        unique = f"covers/{uuid.uuid4().hex}_{filename}"
                        abs_path = os.path.join(current_app.config["POST_UPLOAD_ABS"], unique)
                        os.makedirs(os.path.dirname(abs_path), exist_ok=True)
                        cover_file.save(abs_path)
                        cover_url = current_app.config["UPLOAD_URL_PREFIX"] + unique
                        user.profile_bg_url = cover_url

                    # Save profile music directly on the user
                    if music_title:
                        try:
                            user.profile_music_title = music_title
                            user.profile_music_artist = music_artist
                            user.profile_music_preview = music_preview
                            user.profile_music_artwork = music_artwork or None
                        except Exception as e:
                            current_app.logger.warning(f"profile music save failed: {e}")
                    elif request.form.get('profile_music_title') == '':
                        # User cleared the music
                        try:
                            user.profile_music_title = None
                            user.profile_music_artist = None
                            user.profile_music_preview = None
                            user.profile_music_artwork = None
                        except Exception as clear_music_err:
                            current_app.logger.warning(f"profile music clear failed: {clear_music_err}")

                # â”€â”€ Theme preset + custom accent colors â”€â”€
                if not is_wallpaper_only:
                    try:
                        import json as _json_theme
                        theme_preset_val = (request.form.get('theme_preset') or '').strip()
                        user.theme = theme_preset_val
                        _tc_save = {}
                        tb = (request.form.get('theme_bg') or '').strip()
                        if tb: _tc_save['bg'] = tb
                        tb1 = (request.form.get('theme_brand1') or '').strip()
                        if tb1: _tc_save['brand1'] = tb1
                        tb2 = (request.form.get('theme_brand2') or '').strip()
                        if tb2: _tc_save['brand2'] = tb2
                        tb3 = (request.form.get('theme_brand3') or '').strip()
                        if tb3: _tc_save['brand3'] = tb3
                        if _tc_save:
                            user.theme_colors = _json_theme.dumps(_tc_save)
                    except Exception as _theme_err:
                        current_app.logger.warning(f"theme save failed: {_theme_err}")

                # â”€â”€ Custom Typography: profile font â”€â”€
                if not is_wallpaper_only:
                    _ALLOWED_FONTS = {
                        'default', 'boogaloo', 'permanent_marker', 'rubik_dirt',
                        'creepster', 'righteous', 'bangers'
                    }
                    try:
                        _pf = (request.form.get('profile_font') or '').strip().lower()
                        if _pf in _ALLOWED_FONTS:
                            user.profile_font = _pf if _pf != 'default' else ''
                    except Exception as _pf_err:
                        current_app.logger.warning(f"profile_font save failed: {_pf_err}")

                # Ensure session username always matches the saved profile user
                try:
                    session['username'] = user.username
                    # Keep session display_name in sync so it shows immediately
                    session['display_name'] = user.display_name or user.username
                    db.session.commit()
                    flash('Settings saved successfully!', 'success')
                except Exception as commit_err:
                    db.session.rollback()
                    current_app.logger.error(f"Settings save failed: {commit_err}")
                    flash("Error saving settings. Please try again.", "error")
                    return _redirect_settings_with_active_tab()

            # Preserve active tab so user lands back on the tab they were editing
            active_tab = request.form.get('_active_tab', '')
            redir = url_for('settings')
            if active_tab:
                redir += '#' + active_tab
            return redirect(redir)

        def _g(attr, default=False):
            """Safely get a user attribute with a default."""
            return getattr(user, attr, default) if user else default

        # Load saved theme colors from DB
        _tc_pref = {}
        _raw_tc = _g("theme_colors", None)
        if _raw_tc:
            try:
                import json as _json_pref
                _tc_pref = _json_pref.loads(_raw_tc)
            except Exception:
                pass

        preferences = {
            "display_name": (getattr(user, 'display_name', None) or user.username) if user else "Guest",
            "bio": user.bio if user and user.bio else "",
            "avatar_url": (user.avatar_url if user and user.avatar_url else url_for('static', filename='VFlogo_clean.png')),
            "profile_bg_url": user.profile_bg_url if user and getattr(user, "profile_bg_url", None) else "",
            "theme_bg": (_tc_pref.get("bg", "#0a0810")),
            "theme_brand1": (_tc_pref.get("brand1", "#ff9a3d")),
            "theme_brand2": (_tc_pref.get("brand2", "#ff6a00")),
            "theme_brand3": (_tc_pref.get("brand3", "#ff4800")),
            "theme_preset": (_g("theme", "") or ""),
            "ai_assist": bool(_g("ai_assist")),
            "retro_2011": bool(_g("retro_2011")),
            "safe_mode": bool(_g("safe_mode")),
            "energy_filter_enabled": bool(_g("energy_filter_enabled")),
            "email_notifications": bool(_g("email_notifications")),
            "live_collab": bool(_g("live_collab")),
            "auto_captions": bool(_g("auto_captions")),
            "default_visibility": (_g("default_visibility", "public") or "public"),
