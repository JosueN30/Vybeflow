    @app.get("/account")
    def account():
        from models import User
        # Get current user from session or create a guest user
        username = session.get('username') or 'Guest'
        user = User.query.filter_by(username=username).first()
        if not user and username != 'Guest':
            # Auto-create user if session exists but DB record doesn't
            email = f"{username}@VybeFlow.local"
            hashed = generate_password_hash(username + "VybeFlow", method='pbkdf2:sha256:260000')
            user = User(username=username, email=email, password_hash=hashed, avatar_url=url_for('static', filename='VFlogo_clean.png'))
            db.session.add(user)
            try:
                db.session.commit()
            except Exception:
                db.session.rollback()
                user = None
        if not user:
            # Create a temporary user object for display
            class GuestUser:
                username = 'Guest'
                email = 'guest@VybeFlow.local'
                bio = 'Welcome to VybeFlow!'
                avatar_url = '/static/VFlogo_clean.png'
                profile_bg_url = ''
                profile_music_title = None
                profile_music_artist = None
                profile_music_preview = None
                profile_music_artwork = None
                wallpaper_type = 'none'
                wallpaper_color1 = '#0a0810'
                wallpaper_color2 = '#1a1030'
                wallpaper_pattern = 'none'
                wallpaper_animation = 'none'
                wallpaper_motion = 'none'
                wallpaper_glitter = False
                wallpaper_music_sync = False
                wallpaper_image_url = ''
            user = GuestUser()
        # Guarantee avatar_url is never None/empty so templates don't render "None"
        default_avatar = url_for('static', filename='VFlogo_clean.png')
        if not getattr(user, 'avatar_url', None):
            user.avatar_url = default_avatar
        profile_bg_url = getattr(user, "profile_bg_url", "") or ""
        # Build wallpaper config for template
        wp_config = {
            'type': getattr(user, 'wallpaper_type', 'none') or 'none',
            'color1': getattr(user, 'wallpaper_color1', '#0a0810') or '#0a0810',
            'color2': getattr(user, 'wallpaper_color2', '#1a1030') or '#1a1030',
            'pattern': getattr(user, 'wallpaper_pattern', 'none') or 'none',
            'animation': getattr(user, 'wallpaper_animation', 'none') or 'none',
            'motion': getattr(user, 'wallpaper_motion', 'none') or 'none',
            'glitter': bool(getattr(user, 'wallpaper_glitter', False)),
            'music_sync': bool(getattr(user, 'wallpaper_music_sync', False)),
            'image_url': getattr(user, 'wallpaper_image_url', '') or '',
        }
        # Build active_theme vars so base.html re-injects the saved DB theme on
        # every page load, preventing the Theme Garage from resetting to default.
        _at = {}
        try:
            import json as _json_acc
            _raw_tc = getattr(user, 'theme_colors', None)
            if _raw_tc:
                _tc = _json_acc.loads(_raw_tc)
                _at = {
                    '--bg':     _tc.get('bg', '#0a0810'),
                    '--brand1': _tc.get('brand1', '#ff9a3d'),
                    '--brand2': _tc.get('brand2', '#ff6a00'),
                    '--brand3': _tc.get('brand3', '#ff4800'),
                    '--line':   'rgba(255,173,117,.20)',
                }
        except Exception:
            _at = {}
        _prefs = type('Prefs', (), {'profile_font': getattr(user, 'profile_font', '') or ''})()
        return render_template("account.html", user=user, current_user=user, profile_bg_url=profile_bg_url, wp=wp_config, is_own_profile=True, is_friend=False, friend_status='none', pending_request_id=None, active_theme=_at, preferences=_prefs) if os.path.exists(os.path.join(current_app.static_folder, "../templates/account.html")) else redirect(url_for("feed.feed_page"))

    @app.post("/user/<username>/friend/add", endpoint="add_friend")
    def add_friend(username):
        """Send a friend request to the given user."""
        from models import User, FriendRequest, Block, DeviceFingerprint, StalkerPatternLog
        import json as _json_fp
        current_username = (session.get('username') or '').strip()
        if not current_username:
            flash('You must be logged in.', 'error')
            return redirect(url_for('login'))
        sender = User.query.filter_by(username=current_username).first()
        receiver = User.query.filter_by(username=username).first()
        if not sender or not receiver or sender.id == receiver.id:
            flash('Invalid user.', 'error')
            return redirect(_safe_local_next(request.form.get('next'), url_for('feed.feed_page')))

        # â”€â”€ Ghost Wall: Relationship-Proximity Check â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
        # If ANY device fingerprint belonging to the sender was previously
        # used by an account that this receiver had blocked, auto-block + lockout.
        try:
            _sender_fps = [r.fingerprint_hash for r in DeviceFingerprint.query.filter_by(user_id=sender.id).all()]
            for _fp in _sender_fps:
                # Other accounts that share this fingerprint
                _fp_accounts = DeviceFingerprint.query.filter(
                    DeviceFingerprint.fingerprint_hash == _fp,
                    DeviceFingerprint.user_id != sender.id,
                ).all()
                for _rec in _fp_accounts:
                    # Does the receiver have an active block against any of these linked accounts?
                    _prior_block = Block.query.filter_by(
                        blocker_id=receiver.id,
                        blocked_id=_rec.user_id,
                        is_active=True,
                    ).first()
                    if _prior_block and not _prior_block.is_expired:
                        # Auto-block + log
                        _existing_ab = Block.query.filter_by(
                            blocker_id=receiver.id, blocked_id=sender.id, is_active=True
                        ).first()
                        if not _existing_ab:
                            _ab = Block(
                                blocker_id=receiver.id,
                                blocked_id=sender.id,
                                scope="device",
                                reason="Ghost Wall: new account shares device with previously blocked user",
                                blocked_device_fp=_fp,
                            )
                            _ab.set_duration("permanent")
                            db.session.add(_ab)
                        _log_entry = StalkerPatternLog(
                            suspect_user_id=sender.id,
                            target_user_id=receiver.id,
                            pattern_type="proximity_block_evasion",
                            details=_json_fp.dumps({
                                "shared_fp": _fp,
                                "original_blocked_id": _rec.user_id,
                            }),
                            severity="high",
                            auto_action_taken="auto_blocked",
                        )
                        db.session.add(_log_entry)
                        db.session.commit()
                        # Return broken-screen lockout
                        return redirect(url_for('blocked_view', username=receiver.username))
        except Exception as _gw_err:
            current_app.logger.warning("Ghost Wall proximity check error: %s", _gw_err)
        # â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

        # Check if already friends or pending
        existing = FriendRequest.query.filter(
            db.or_(
                db.and_(FriendRequest.sender_id == sender.id, FriendRequest.receiver_id == receiver.id),
                db.and_(FriendRequest.sender_id == receiver.id, FriendRequest.receiver_id == sender.id),
            )
        ).first()
        if existing:
            if existing.status == 'accepted':
                flash(f'You are already friends with @{username}!', 'info')
            elif existing.status == 'pending':
                flash(f'Friend request already pending with @{username}.', 'info')
            else:
                existing.status = 'pending'
                existing.sender_id = sender.id
                existing.receiver_id = receiver.id
                try:
                    db.session.commit()
                except Exception:
                    db.session.rollback()
                flash(f'Friend request sent to @{username}! ðŸ¤', 'success')
        else:
            fr = FriendRequest(sender_id=sender.id, receiver_id=receiver.id, status='pending')
            db.session.add(fr)
            try:
                db.session.commit()
            except Exception:
                db.session.rollback()
                flash('Failed to send friend request. Please try again.', 'error')
                return redirect(_safe_local_next(request.form.get('next'), url_for('feed.feed_page')))

            # â”€â”€ Vybe Pulse: notify receiver of squad request â”€â”€
            try:
                from routes.notifications import create_pulse
                _pulse = create_pulse(
                    recipient_id=receiver.id,
                    actor_id=sender.id,
                    pulse_type="squad_req",
                    message=f"{sender.username} wants to join your squad",
                    emoji="ðŸ‘¥",
                )
                if _pulse:
                    socketio.emit("vybe_pulse", _pulse.to_dict(), room=f"user_{receiver.id}")
            except Exception:
                pass
            # â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

            flash(f'Friend request sent to @{username}! ðŸ¤', 'success')
        return redirect(_safe_local_next(request.form.get('next'), url_for('feed.feed_page')))

    @app.get("/friends")
    def friends_page():
        """Friends dashboard â€” pending requests, friends list."""
        from models import User, FriendRequest
        current_username = (session.get('username') or '').strip()
        if not current_username:
            return redirect(url_for('login'))
        me = User.query.filter_by(username=current_username).first()
        if not me:
            return redirect(url_for('login'))
        # Incoming pending
        incoming = FriendRequest.query.filter_by(receiver_id=me.id, status='pending').all()
        # Outgoing pending
        outgoing = FriendRequest.query.filter_by(sender_id=me.id, status='pending').all()
        # Accepted friends
        accepted_sent = FriendRequest.query.filter_by(sender_id=me.id, status='accepted').all()
        accepted_recv = FriendRequest.query.filter_by(receiver_id=me.id, status='accepted').all()
        friend_ids = set()
        for fr in accepted_sent:
            friend_ids.add(fr.receiver_id)
        for fr in accepted_recv:
            friend_ids.add(fr.sender_id)
        friends = User.query.filter(User.id.in_(friend_ids)).all() if friend_ids else []
        return render_template('friends.html', incoming=incoming, outgoing=outgoing, friends=friends, current_user=me)

    # --- Upload file server ---

    @app.route("/uploads/<path:filename>")
    def uploaded_media(filename):
        """Serve files saved under uploads/ or static/uploads/ via /uploads/<path>."""
        # Correct MIME types for audio files (browsers need audio/* for <audio>/new Audio())
        _audio_mimes = {
            ".webm": "audio/webm",
            ".ogg": "audio/ogg",
            ".opus": "audio/ogg",
            ".mp3": "audio/mpeg",
            ".wav": "audio/wav",
            ".m4a": "audio/mp4",
            ".aac": "audio/aac",
            ".flac": "audio/flac",
        }
        ext = os.path.splitext(filename)[1].lower()
        mime = _audio_mimes.get(ext)

        # First check the direct uploads/ directory (used by voice notes)
        direct_root = os.path.join(current_app.root_path, "uploads")
        if os.path.isfile(os.path.join(direct_root, filename)):
            resp = send_from_directory(direct_root, filename, mimetype=mime)
        else:
            # Then check configured path or static/uploads/
            root = current_app.config.get("POST_UPLOAD_ABS") or os.path.join(
                current_app.root_path, "static", "uploads"
            )
            resp = send_from_directory(root, filename, mimetype=mime)

        # Allow same-origin audio playback without CORS issues
        resp.headers['Access-Control-Allow-Origin'] = '*'
        resp.headers['Accept-Ranges'] = 'bytes'
        return resp

    # --- Full-fat feed JSON used by the feed composer JS ---

    @app.get("/api/posts/list")
    def api_posts_list():
        """Return recent posts with full author + reaction + comment payload
        needed by the feed.html JavaScript.
        """
        from models import Post, User, Reaction, Comment, Follow, Track
        from datetime import datetime
        import json as _json

        def _get_fusions(post_id):
            """Return vibe fusions for a post."""
            try:
                from models import VibeFusion
                fusions = VibeFusion.query.filter_by(post_id=post_id).order_by(VibeFusion.created_at.desc()).limit(10).all()
                return [{"combo_key": f.combo_key, "combo_label": f.combo_label, "combo_tier": f.combo_tier} for f in fusions]
            except Exception:
                return []

        current_username = (session.get("username") or "").strip()
        current_user_obj = (
            User.query.filter_by(username=current_username).first()
            if current_username else None
        )
        current_uid = current_user_obj.id if current_user_obj else None

        # â”€â”€ Ghost Wall: block-evader feed filter â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
        # If the logged-in user's device fingerprint has been flagged as a
        # block-evader (StalkerPatternLog entry), we collect the set of
        # author IDs they are banned from seeing and filter those posts out
        # of the feed. This silently enforces blocks even on burner accounts.
        _evader_banned_author_ids: set = set()
        if current_uid:
            try:
                from models import DeviceFingerprint, StalkerPatternLog
                _my_fps = DeviceFingerprint.query.filter_by(user_id=current_uid).all()
                for _fp in _my_fps:
                    # Any StalkerPatternLog entry for this fingerprint means the
                    # device was used to evade a block.
                    for _log in StalkerPatternLog.query.filter_by(
                        evader_fingerprint=_fp.fingerprint_hash
                    ).all():
                        _evader_banned_author_ids.add(_log.victim_id)
            except Exception:
                pass
        # â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

        try:
            from sqlalchemy import func as _sqlfunc
            base_q = Post.query.order_by(Post.created_at.desc())

            # DB-level visibility filter (mirrors feed.py) — SQL subqueries, no Python lists
            # Fixes feed ghosting: without this, friends-visibility posts fill
            # the scan window and Python discards them all, returning empty pages.
            try:
                _vis_col = _sqlfunc.lower(_sqlfunc.coalesce(Post.visibility, 'public'))
                _pub_clause = _vis_col.in_(('public', 'everyone'))
                if current_uid:
                    # logged-in users see: public posts + friends/followers posts
                    # (friends = logged-in only; not restricted to strict followers
                    # so the feed stays populated for users with few follows)
                    # + their own posts regardless of visibility
                    _friends_clause = _vis_col.in_(('followers', 'friends'))
                    _own_clause = (Post.author_id == current_uid)
                    base_q = base_q.filter(_pub_clause | _friends_clause | _own_clause)
                else:
                    base_q = base_q.filter(_pub_clause)
            except Exception as _vis_err:
                current_app.logger.warning("posts/list visibility filter failed: %s", _vis_err)

            # Shadowban filter: exclude shadow-banned users from public feed (SQL subquery)
            try:
                _sb_subq = db.session.query(User.id).filter(
                    User.is_shadow_banned == True  # noqa: E712
                )
                if current_uid:
                    _sb_subq = _sb_subq.filter(User.id != current_uid)
                base_q = base_q.filter(~Post.author_id.in_(_sb_subq.scalar_subquery()))
            except Exception:
                pass

            # Block filter: hide posts from blocked/blocking users (SQL subqueries)
            if current_uid:
                try:
                    from models import Block
                    from sqlalchemy import union
                    _blocker_subq = db.session.query(Block.blocked_id).filter(
                        Block.blocker_id == current_uid, Block.is_active == True  # noqa: E712
                    ).scalar_subquery()
                    _blockee_subq = db.session.query(Block.blocker_id).filter(
                        Block.blocked_id == current_uid, Block.is_active == True  # noqa: E712
                    ).scalar_subquery()
                    base_q = base_q.filter(
                        ~Post.author_id.in_(_blocker_subq),
                        ~Post.author_id.in_(_blockee_subq),
                    )
                except Exception:
                    pass

            # Adult content filter
            try:
                _is_adult_verified = (
                    bool(getattr(current_user_obj, 'adult_verified', False)) and
                    not bool(getattr(current_user_obj, 'adult_access_revoked', False))
                ) if current_user_obj else False
                if not _is_adult_verified:
                    base_q = base_q.filter(Post.is_adult == False)  # noqa: E712
            except Exception:
                pass

            # Pagination support for infinite scroll
            _page_offset = max(0, int(request.args.get('offset', 0)))
            _page_limit  = min(max(1, int(request.args.get('limit', 20))), 50)
            # With DB-level filtering a 3x window is plenty
            _page_scan = _page_limit * 3
            posts = base_q.offset(_page_offset).limit(_page_scan + 1).all()
            _fetched_extra = len(posts) > _page_scan
            if _fetched_extra:
                posts = posts[:_page_scan]
        except Exception as e:
            current_app.logger.exception("posts/list query failed")
            return jsonify({"posts": [], "has_more": False}), 200
        now = datetime.now(timezone.utc)

        default_avatar = url_for("static", filename="VFlogo_clean.png")

        post_ids = [p.id for p in posts]
        reaction_map = {}
        my_reactions = {}
        if post_ids:
            for rxn in Reaction.query.filter(Reaction.post_id.in_(post_ids)).all():
                bucket = reaction_map.setdefault(rxn.post_id, {})
                bucket[rxn.emoji] = bucket.get(rxn.emoji, 0) + 1
                if current_uid and rxn.user_id == current_uid:
                    my_reactions[rxn.post_id] = rxn.emoji

        comments_map = {}
        if post_ids:
            all_comments = Comment.query.filter(Comment.post_id.in_(post_ids)).order_by(Comment.created_at.asc()).all()
            # Batch-load all comment author IDs at once
            _comment_author_ids = {c.author_id for c in all_comments if c.author_id}
            _comment_authors = {}
            if _comment_author_ids:
                for u in User.query.filter(User.id.in_(_comment_author_ids)).all():
                    _comment_authors[u.id] = u
            for c in all_comments:
                author = _comment_authors.get(c.author_id)
                comments_map.setdefault(c.post_id, []).append({
                    "id": c.id,
                    "post_id": c.post_id,
                    "parent_id": c.parent_id,
                    "content": c.content,
                    "created_at": c.created_at.isoformat() if c.created_at else None,
                    "author_username": (getattr(author, 'display_name', None) or author.username) if author else "User",
                    "voice_note_url": getattr(c, 'voice_note_url', None) or None,
                    "transcript": getattr(c, 'transcript', None) or None,
                    "author_id": c.author_id,
                    "can_edit": True,
                    "mood_tone": getattr(c, 'mood_tone', None) or None,
                    "sentiment": getattr(c, 'sentiment', None) or "neutral",
                    "like_count": getattr(c, 'like_count', 0) or 0,
                })

        # Batch-load all post authors and music tracks at once to avoid N+1 queries
        _post_author_ids = {p.author_id for p in posts if p.author_id}
        _post_authors = {}
        if _post_author_ids:
            for u in User.query.filter(User.id.in_(_post_author_ids)).all():
                _post_authors[u.id] = u

        # Batch-load follow relationships for visibility checks
        _following_set = set()
        if current_uid:
            _following_set = {
                f.following_id for f in
                Follow.query.filter_by(follower_id=current_uid).all()
            }

        # Batch-load music tracks
        _music_track_ids = {getattr(p, "music_track_id", None) for p in posts}
        _music_track_ids.discard(None)
        _music_tracks = {}
        if _music_track_ids:
            for mt in Track.query.filter(Track.id.in_(_music_track_ids)).all():
                _music_tracks[mt.id] = mt

        result = []
        _raw_consumed = 0
        _has_more_visible = False
        for _idx, p in enumerate(posts):
            _raw_consumed = _idx + 1
            try:
                if p.expires_at and p.expires_at <= now:
                    continue
                # Ghost Wall: hide posts from authors whom this device is banned from
                if _evader_banned_author_ids and p.author_id in _evader_banned_author_ids and not (current_uid and p.author_id == current_uid):
                    continue
                author = _post_authors.get(p.author_id)
                a_name = (getattr(author, 'display_name', None) or author.username) if author else "Unknown"
                a_avatar = (getattr(author, "avatar_url", None) or default_avatar) if author else default_avatar
                # Fix relative avatar paths that start with /uploads/
                if a_avatar and a_avatar.startswith("/uploads/"):
                    pass  # served by the route above
                elif a_avatar and not a_avatar.startswith(("/", "http")):
                    a_avatar = "/" + a_avatar

                is_own_post = (current_uid is not None and p.author_id == current_uid)

                # â”€â”€ Enforce author's profile_visibility setting â”€â”€
                if not is_own_post and author:
                    _pv = getattr(author, 'profile_visibility', 'public') or 'public'
                    if _pv == 'hidden':
                        continue  # Hidden profiles: skip all their posts
                    if _pv == 'private':
                        if not current_uid or p.author_id not in _following_set:
                            continue  # Private profiles: followers only

                vis = (p.visibility or "public").lower().replace(" ", "_")
                if vis in ("private", "only_me") and not is_own_post:
                    continue
                if vis in ("followers", "friends") and not is_own_post:
                    # friends/followers posts: visible to any logged-in user
                    # (hidden from unauthenticated requests only)
                    if not current_uid:
                        continue

                # Resolve music track info if linked
                _music_name = None
                _music_url = None
                _music_art = None
                mtid = getattr(p, "music_track_id", None)
                if mtid:
                    mt = _music_tracks.get(mtid)
                    if mt:
                        _music_name = (mt.title or "") + (" — " + mt.artist if mt.artist else "")
                        _music_url = mt.preview_url
                        _music_art = getattr(mt, "artwork_url", None)

                rxn_counts = reaction_map.get(p.id, {})
                my_rxn = my_reactions.get(p.id)
                # For GIF posts, prefer gif_url if media_url is empty
                _media_url = p.media_url
                _media_type = p.media_type
                _gif_url = getattr(p, "gif_url", None)
                if not _media_url and _gif_url:
                    _media_url = _gif_url
                    _media_type = "gif"

                # [BUG-05 FIX] Determine vault status before building the dict.
                # Vault posts: caption is encrypted client-side; returning the plaintext
                # field (if accidentally populated) would bypass the PIN lock.
                # We return an empty string for caption and expose the encrypted fields
                # so the client can render the locked post card correctly.
                _is_vault_post = bool(getattr(p, "is_vault", False))

                result.append({
                    "id": p.id,
                    # Mask plaintext caption for vault posts â€” encrypted text is in vault_caption_enc.
                    "caption": "" if _is_vault_post else (p.caption or ""),
                    "media_url": _media_url,
                    "media_type": _media_type,
                    "gif_url": _gif_url or None,
                    "thumbnail_url": getattr(p, "thumbnail_url", None),
                    "bg_style": getattr(p, "bg_style", None) or "default",
                    "bg_color": getattr(p, "bg_color", None) or None,
                    "font_style": getattr(p, "font_style", None) or "",
                    "font_color": getattr(p, "font_color", None) or "",
                    "visibility": p.visibility or "public",
                    "created_at": p.created_at.isoformat() if p.created_at else None,
                    "expires_at": p.expires_at.isoformat() if p.expires_at else None,
                    "like_count": sum(rxn_counts.values()),
                    "comment_count": len(comments_map.get(p.id, [])),
                    "reaction_counts": rxn_counts,
                    "current_reaction": my_rxn,
                    "liked": my_rxn in ("🔥", "❤️") if my_rxn else False,
                    "can_edit": (current_uid is not None and p.author_id == current_uid) or (not p.author_id),
                    "author_id": p.author_id,
                    "author_handle": getattr(author, 'username', None) if author else None,
                    "author_username": a_name,
                    "author_avatar_url": a_avatar,
                    "author": {
                        "id": p.author_id,
                        "username": getattr(author, 'username', None) if author else None,
                        "display_name": a_name,
                        "avatar_url": a_avatar,
                    },
                    "music_track": _music_name,
                    "music_preview_url": _music_url,
                    "music_artwork_url": _music_art,
                    # Vault fields â€” only populated for vault posts
                    "is_vault": _is_vault_post,
                    "vault_caption_enc": getattr(p, "vault_caption_enc", None) if _is_vault_post else None,
                    "vault_iv": getattr(p, "vault_iv", None) if _is_vault_post else None,
                    "vault_media_nonce": getattr(p, "vault_media_nonce", None) if _is_vault_post else None,
                    "is_adult": bool(getattr(p, "is_adult", False)),
                    "venue_tag": getattr(p, "venue_tag", None),
                    "city_tag": getattr(p, "city_tag", None),
                    "is_event": bool(getattr(p, "is_event", False)),
                    "event_title": getattr(p, "event_title", None),
                    "event_time": getattr(p, "event_time", None),
                    "guest_list_info": getattr(p, "guest_list_info", None),
                    "is_anonymous": bool(getattr(p, "is_anonymous", False)),
                    "anonymous_alias": getattr(p, "anonymous_alias", None),
                    "author_trust_score": getattr(author, "trust_score", 50) if author else 50,
                    "author_verified_human": bool(getattr(author, "is_verified_human", False)) if author else False,
                    "author_account_type": getattr(author, "account_type", "personal") if author else "personal",
                    "vibe_tag": getattr(p, "vibe_tag", None) or None,
                    "micro_vibe": getattr(p, "micro_vibe", None) or None,
                    "disappear_after": getattr(p, "disappear_after", None),
                    "screenshot_alert": bool(getattr(p, "screenshot_alert", False)),
                    "watermark_enabled": bool(getattr(p, "watermark_enabled", True)),
                    "needs_review": bool(getattr(p, "needs_review", False)),
                    "has_pin": bool(getattr(p, "post_pin_hash", None)),
                    "vibe_fusions": _get_fusions(p.id),
                    "comments": comments_map.get(p.id, []),
                    "stickers": [],
                    "share_url": "#",
                    # â”€â”€ Professional account fields (shown in PRO badge + portfolio link) â”€â”€
                    "author_professional_verified": bool(getattr(author, "professional_verified", False)) if author else False,
                    "author_business_category":     getattr(author, "business_category", None) if author else None,
                    "author_portfolio_url":         getattr(author, "portfolio_url", None) if author else None,
                    # â”€â”€ Engagement / retention fields â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
                    "view_count":    getattr(p, "view_count", 0) or 0,
                    "author_streak": getattr(author, "post_streak", 0) if author else 0,
                })
                # If anonymous post, mask author identity in the response
                _is_anon = bool(getattr(p, "is_anonymous", False))
                if _is_anon and result:
                    _alias = getattr(p, "anonymous_alias", None) or "Anonymous"
                    result[-1]["author_id"] = None
                    result[-1]["author_handle"] = None
                    result[-1]["author_username"] = _alias
                    result[-1]["author_avatar_url"] = default_avatar
                    result[-1]["author"] = {"id": None, "username": None, "display_name": _alias, "avatar_url": default_avatar}

                # Capture one extra visible post to determine has_more without
                # dropping visible rows or skipping pages.
                if len(result) > _page_limit:
                    _has_more_visible = True
                    # Do not consume the extra probe row in the raw cursor,
                    # otherwise the next page will skip this visible post.
                    result.pop()
                    _raw_consumed = max(_raw_consumed - 1, 0)
                    break
            except Exception as e:
                current_app.logger.warning(f"post serialise {p.id}: {e}")
                continue

        _next_offset_raw = _page_offset + (_raw_consumed if _raw_consumed else len(posts))
        return jsonify({
            "posts": result[:_page_limit],
            "offset": _page_offset,
            "limit": _page_limit,
            # Raw cursor for the next page request. Client should prefer this
            # over incrementing by visible post count.
            "next_offset_raw": _next_offset_raw,
            # has_more: true if we found one extra visible post OR there are
            # more raw rows to scan.
            "has_more": _has_more_visible or _fetched_extra,
        }), 200

    # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    #  SCREENSHOT ALERT API
    # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    @app.post("/api/posts/<int:post_id>/screenshot-alert")
    def api_screenshot_alert(post_id):
        """Record screenshot attempt and notify post author via SocketIO."""
        from models import Post, User
        current_username = (session.get("username") or "").strip()
        if not current_username:
            return jsonify({"error": "Login required"}), 401
        post = db.session.get(Post, post_id)
        if not post:
            return jsonify({"error": "Post not found"}), 404
        try:
            post.screenshot_count = (getattr(post, "screenshot_count", 0) or 0) + 1
            db.session.commit()
        except Exception:
            db.session.rollback()
        # Notify author via SocketIO
        if getattr(post, "screenshot_alert", False):
            author = db.session.get(User, post.author_id) if post.author_id else None
            if author:
                try:
                    # Use both room formats (dm_socket uses user:{id}, feed uses user_{username})
                    _alert_payload = {
                        "post_id": post_id,
                        "screenshotter": current_username,
                        "count": getattr(post, "screenshot_count", 1),
                    }
                    socketio.emit("screenshot_alert", _alert_payload, room=f"user_{author.username}")
                    socketio.emit("screenshot_alert", _alert_payload, room=f"user:{author.id}")
                except Exception:
                    pass
        return jsonify({"ok": True, "count": getattr(post, "screenshot_count", 1)})

    # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    #  POST PIN LOCK â€” set / verify PIN for adult posts
    # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

    @app.post("/api/posts/<int:post_id>/set-pin")
    def api_post_set_pin(post_id):
        """Author sets a 4-digit PIN to protect an adult/flagged post."""
        from models import Post, User
        from werkzeug.security import generate_password_hash as _gph
        current_username = (session.get("username") or "").strip()
        if not current_username:
            return jsonify({"error": "Login required"}), 401
        user = User.query.filter_by(username=current_username).first()
        if not user:
            return jsonify({"error": "User not found"}), 401
        post = db.session.get(Post, post_id)
        if not post:
            return jsonify({"error": "Post not found"}), 404
        if post.author_id != user.id:
            return jsonify({"error": "Not your post"}), 403
        data = request.get_json(silent=True) or {}
        pin = str(data.get("pin") or "").strip()
        if not pin or not pin.isdigit() or len(pin) != 4:
            return jsonify({"error": "PIN must be exactly 4 digits"}), 400
        try:
            post.post_pin_hash = _gph(pin)
            db.session.commit()
        except Exception:
            db.session.rollback()
            return jsonify({"error": "DB error"}), 500
        return jsonify({"ok": True, "has_pin": True})

    @app.post("/api/posts/<int:post_id>/verify-pin")
    def api_post_verify_pin(post_id):
        """Viewer submits the PIN to unlock an adult/flagged post media."""
        from models import Post, User
        from werkzeug.security import check_password_hash as _cph
        current_username = (session.get("username") or "").strip()
        if not current_username:
            return jsonify({"error": "Login required"}), 401
        user = User.query.filter_by(username=current_username).first()
        if not user:
            return jsonify({"error": "User not found"}), 401

        # Age-gate: viewer must be adult verified
        if not getattr(user, "adult_verified", False):
            return jsonify({"error": "Age verification required", "code": "adult_required"}), 403

        post = db.session.get(Post, post_id)
        if not post:
            return jsonify({"error": "Post not found"}), 404

        pin_hash = getattr(post, "post_pin_hash", None)
        if not pin_hash:
            # No PIN set â€” issue media token directly (legacy / no-PIN posts)
            return jsonify({"ok": True, "no_pin": True})

        # Rate-limit PIN attempts per session (max 5)
        _key = f"post_pin_guesses_{post_id}_{user.id}"
        _attempts = session.get(_key, 0)
        if _attempts >= 5:
            return jsonify({"error": "Too many attempts. Try again later.", "code": "rate_limited"}), 429

        data = request.get_json(silent=True) or {}
        pin = str(data.get("pin") or "").strip()
        if not pin:
            return jsonify({"error": "PIN required"}), 400
        if not _cph(pin_hash, pin):
            session[_key] = _attempts + 1
            remaining = 4 - _attempts
            return jsonify({
                "error": "Wrong PIN", "code": "wrong_pin",
                "attempts_left": max(0, remaining),
            }), 403
        # Correct â€” clear counter
        session.pop(_key, None)
        return jsonify({"ok": True})

    # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
    #  AGE VERIFICATION API
    # â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

