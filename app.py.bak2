# â”€â”€ GIF search cache (module-level so it survives create_app re-calls) â”€â”€
_GIF_CACHE_MAX = 256
_gif_cache = {}
_GIF_CACHE_TTL = 600  # seconds

def _gif_cache_put(key, value):
    if len(_gif_cache) >= _GIF_CACHE_MAX:
        try:
            del _gif_cache[next(iter(_gif_cache))]
        except (StopIteration, KeyError):
            pass
    _gif_cache[key] = value

# â”€â”€ Registration IP rate limiter (module-level, process-local, thread-safe) â”€â”€
# Defined here to avoid circular import issues with routes/passkeys.py.
import threading as _rl_threading
import time as _rl_time
from collections import defaultdict as _rl_defaultdict

_REG_RL_MAX_KEYS = 10000
_reg_rl_store: dict = _rl_defaultdict(list)
_reg_rl_lock = _rl_threading.Lock()

def _reg_ip_rate_limit(key: str, max_calls: int, window_seconds: int) -> bool:
    """Returns True (blocked) if key has exceeded max_calls within window_seconds."""
    now = _rl_time.monotonic()
    with _reg_rl_lock:
        # Evict stale keys to cap memory
        if len(_reg_rl_store) > _REG_RL_MAX_KEYS:
            _stale = [k for k, v in _reg_rl_store.items() if not v or v[-1] < now - window_seconds]
            for k in _stale[:len(_reg_rl_store) - _REG_RL_MAX_KEYS // 2]:
                del _reg_rl_store[k]
        bucket = _reg_rl_store[key]
        cutoff = now - window_seconds
        _reg_rl_store[key] = [t for t in bucket if t > cutoff]
        if len(_reg_rl_store[key]) >= max_calls:
            return True  # blocked
        _reg_rl_store[key].append(now)
        return False  # allowed

# â”€â”€ Email-safe check: skip test/fake email domains to prevent SMTP bounces â”€â”€
_FAKE_EMAIL_DOMAINS = ("@VybeFlow.local", "@ob.test", "@pk.test", "@sec.test",
                       "@lock.test", "@vault.test", "@audit.local", "@test.local")

def _is_real_email(email: str) -> bool:
    """Return True only for genuine deliverable email addresses."""
    return bool(email) and not any(email.endswith(d) for d in _FAKE_EMAIL_DOMAINS)


def _safe_local_next(next_url: str | None, fallback: str) -> str:
    """Return a safe same-origin relative redirect target, otherwise fallback."""
    nxt = (next_url or "").strip()
    if not nxt:
        return fallback
    try:
        parsed = urlparse(nxt)
    except Exception:
        return fallback
    # Block absolute URLs / scheme-relative URLs / non-path redirects.
    if parsed.scheme or parsed.netloc:
        return fallback
    if not nxt.startswith("/"):
        return fallback
    return nxt

