    @app.route("/change_password", methods=["POST"])
    def change_password():
        """Change password from settings page."""
        username = session.get('username')
        if not username:
            flash("You must be logged in to change your password.", "error")
            return redirect(url_for('login'))

        from models import User
        user = User.query.filter_by(username=username).first()
        if not user:
            flash("User not found.", "error")
            return redirect(url_for('settings'))

        current_pw = request.form.get('current_password', '').strip()
        new_pw = request.form.get('new_password', '').strip()
        confirm_pw = request.form.get('confirm_new_password', '').strip()

        if not current_pw or not new_pw:
            flash("All password fields are required.", "error")
            return redirect(url_for('settings') + '#settings-security')

        if not check_password_hash(user.password_hash, current_pw):
            flash("Current password is incorrect.", "error")
            return redirect(url_for('settings') + '#settings-security')

        if len(new_pw) < 6:
            flash("New password must be at least 6 characters.", "error")
            return redirect(url_for('settings') + '#settings-security')

        if new_pw != confirm_pw:
            flash("New passwords don't match.", "error")
            return redirect(url_for('settings') + '#settings-security')

        if new_pw == current_pw:
            flash("New password must be different from your current password.", "error")
            return redirect(url_for('settings') + '#settings-security')

        user.password_hash = generate_password_hash(new_pw, method='pbkdf2:sha256:260000')
        _safe_commit('change_password')
        flash("Password changed successfully!", "success")
        return redirect(url_for('settings') + '#settings-security')


    # NOTE: POST /api/posts/create is handled by the posts_api blueprint
    # (routes/posts_api.py). The blueprint is CSRF-exempt and registered first
    # at app startup. Do NOT add a duplicate route here â€” it creates ambiguous
    # routing and breaks CSRF exemption for the publish flow.
    #
    # The handler below was the old monolithic version and has been removed.
    # If you need to extend post-creation logic, edit routes/posts_api.py.

    @app.post("/api/posts/delete")
    def api_posts_delete():
        """Delete a post by ID."""
        try:
            from models import Post, User, Comment
            from __init__ import db

            current_username = (session.get('username') or '').strip()
            if not current_username:
                return jsonify({"error": "Not signed in"}), 401

            user = User.query.filter_by(username=current_username).first()
            if not user:
                return jsonify({"error": "User not found"}), 404

            payload = request.get_json(silent=True) if request.is_json else {}
            post_id_raw = (payload or {}).get('id') or request.form.get('id')
            if not post_id_raw:
                return jsonify({"error": "Post ID required"}), 400

            try:
                post_id = int(post_id_raw)
            except (TypeError, ValueError):
                return jsonify({"error": "Invalid post ID"}), 400

            post = Post.query.get(post_id)
            if not post:
                return jsonify({"error": "Post not found"}), 404

            # Owner or admin only
            if post.author_id != user.id and not bool(getattr(user, 'is_admin', False)):
                return jsonify({"error": "Not allowed"}), 403

            # Keep parity with the REST delete route: remove dependent comments first
            Comment.query.filter_by(post_id=post.id).delete()
            db.session.delete(post)
            db.session.commit()

            return jsonify({"success": True}), 200
        except Exception as e:
            current_app.logger.exception("Error deleting post")
            return jsonify({"error": "Could not delete post"}), 500

